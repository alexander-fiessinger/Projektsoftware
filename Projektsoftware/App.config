<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<appSettings>
		<!-- MySQL Datenbankverbindung -->
		<!-- Bitte konfigurieren Sie die Verbindung über: Menü → Einstellungen → Datenbankverbindung -->

		<!-- BEISPIEL 1: Lokale MySQL-Installation (XAMPP, WAMP, etc.) -->
		<add key="DB_Server" value="localhost" />
		<add key="DB_Port" value="3306" />
		<add key="DB_Database" value="projektsoftware" />
		<add key="DB_User" value="root" />
		<add key="DB_Password" value="" />
		<add key="DB_SslMode" value="None" />

		<!-- BEISPIEL 2: Remote MySQL-Server -->
		<!--
		<add key="DB_Server" value="mysql.ihrhoster.de" />
		<add key="DB_Port" value="3306" />
		<add key="DB_Database" value="ihre_datenbank" />
		<add key="DB_User" value="ihr_benutzer" />
		<add key="DB_Password" value="ihr_passwort" />
		<add key="DB_SslMode" value="Required" />
		-->

		<!-- BEISPIEL 3: SSH-Tunnel (für sicheren Remote-Zugriff) -->
		<!--
		<add key="DB_Server" value="127.0.0.1" />
		<add key="DB_Port" value="3307" />
		<add key="DB_Database" value="ihre_datenbank" />
		<add key="DB_User" value="ihr_benutzer" />
		<add key="DB_Password" value="ihr_passwort" />
		<add key="DB_SslMode" value="Preferred" />
		-->
	</appSettings>
</configuration>
