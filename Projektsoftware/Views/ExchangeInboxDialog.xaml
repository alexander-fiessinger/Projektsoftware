<Window x:Class="Projektsoftware.Views.ExchangeInboxDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📬 E-Mail Posteingang" Height="700" Width="1050"
        WindowStartupLocation="CenterOwner">
    <DockPanel>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="#F5F5F5" BorderBrush="#DDD"
                BorderThickness="0,0,0,1" Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <Button Content="🔄 Aktualisieren" Width="130" Height="32" Click="Refresh_Click"
                            Background="#2196F3" Foreground="White" FontWeight="Bold"
                            BorderThickness="0" Margin="0,0,8,0"/>
                    <Button Content="🎫 Als Ticket anlegen" Width="160" Height="32" Click="CreateTicket_Click"
                            Background="#4CAF50" Foreground="White" FontWeight="Bold"
                            BorderThickness="0" Margin="0,0,8,0"/>
                    <Button Content="👤 Kunde zuweisen" Width="145" Height="32" Click="AssignCustomer_Click"
                            Background="#FF9800" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                </StackPanel>
                <TextBlock Grid.Column="1" x:Name="StatusTextBlock" VerticalAlignment="Center"
                           HorizontalAlignment="Center" FontStyle="Italic" Foreground="#555"/>
                <Button Grid.Column="2" Content="Schließen" Width="90" Height="32" Click="Close_Click"
                        Background="#9E9E9E" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
            </Grid>
        </Border>

        <!-- E-Mail-Liste + Vorschau -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="2*" MinHeight="120"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="*" MinHeight="100"/>
            </Grid.RowDefinitions>

            <!-- E-Mail-Liste -->
            <DataGrid Grid.Row="0" x:Name="EmailsDataGrid"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionMode="Single" CanUserResizeRows="False"
                      GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                      SelectionChanged="EmailsDataGrid_SelectionChanged">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRead}" Value="False">
                                <Setter Property="FontWeight" Value="Bold"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="●" Binding="{Binding ReadStatus}" Width="24" MinWidth="24"/>
                    <DataGridTextColumn Header="Datum" Width="145"
                                        Binding="{Binding Date, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"/>
                    <DataGridTextColumn Header="Von" Binding="{Binding FromDisplay}" Width="230"/>
                    <DataGridTextColumn Header="Betreff" Binding="{Binding Subject}" Width="*"/>
                    <DataGridTextColumn Header="Kunde (auto)" Binding="{Binding CustomerDisplay}" Width="190"/>
                </DataGrid.Columns>
            </DataGrid>

            <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch" Background="#CCCCCC"/>

            <!-- E-Mail-Vorschau -->
            <Border Grid.Row="2" Background="#FAFAFA">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#EEEEEE" Padding="10,6"
                            BorderBrush="#DDD" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock x:Name="PreviewSubjectText" FontWeight="Bold" FontSize="14"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="PreviewFromText" Foreground="#444" FontSize="12" Margin="0,2,0,0"/>
                            <TextBlock x:Name="PreviewDateText" Foreground="#777" FontSize="11" Margin="0,1,0,0"/>
                            <TextBlock x:Name="PreviewCustomerText" FontSize="12" Margin="0,2,0,0"
                                       Foreground="#1976D2"/>
                        </StackPanel>
                    </Border>

                    <TextBox Grid.Row="1" x:Name="BodyTextBox" IsReadOnly="True"
                             TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             FontFamily="Segoe UI" FontSize="12" Padding="10,8"
                             Background="#FAFAFA" BorderThickness="0"
                             AcceptsReturn="True"/>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
