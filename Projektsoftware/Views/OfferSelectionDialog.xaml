<Window x:Class="Projektsoftware.Views.OfferSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Angebot auswählen" Height="500" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="📋 Angebot für Vertrag auswählen"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="{StaticResource PrimaryBrush}"
                   Margin="0,0,0,10"/>

        <TextBlock Grid.Row="1"
                   Text="Wählen Sie ein bestehendes Angebot aus, dessen Positionen als Vertragsgegenstände übernommen werden sollen."
                   TextWrapping="Wrap"
                   FontSize="12"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   Margin="0,0,0,12"/>

        <DataGrid x:Name="OffersDataGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  IsReadOnly="True"
                  MouseDoubleClick="OffersDataGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nr." Binding="{Binding Number}" Width="100"/>
                <DataGridTextColumn Header="Datum" Binding="{Binding DocumentDate}" Width="100"/>
                <DataGridTextColumn Header="Kunde" Binding="{Binding CustomerDisplay}" Width="*"/>
                <DataGridTextColumn Header="Titel" Binding="{Binding Title}" Width="*"/>
                <DataGridTextColumn Header="Betrag (brutto)" Binding="{Binding TotalGrossDisplay}" Width="120"/>
                <DataGridTextColumn Header="Status" Binding="{Binding DisplayStatus}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Abbrechen" Style="{StaticResource ModernButton}"
                    Background="{StaticResource NeutralBrush}" Foreground="White"
                    Padding="16,8" Margin="0,0,10,0"
                    Click="Cancel_Click"/>
            <Button Content="✓ Übernehmen" Style="{StaticResource ModernButton}"
                    Background="{StaticResource SuccessBrush}" Foreground="White"
                    Padding="16,8"
                    Click="Select_Click"/>
        </StackPanel>
    </Grid>
</Window>
