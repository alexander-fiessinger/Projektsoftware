<Window x:Class="Projektsoftware.Views.EasybillCustomerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Easybill Kunde" Height="700" Width="600"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <DockPanel>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button Content="Speichern" Width="100" Height="35" Margin="0,0,10,0" Click="Save_Click" 
                    Background="#4CAF50" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
            <Button Content="Abbrechen" Width="100" Height="35" Click="Cancel_Click"
                    Background="#9E9E9E" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                <TextBlock Text="📝 Kundeninformationen" FontSize="16" FontWeight="Bold" Margin="0,0,0,20"/>

                <TextBlock Text="Firma" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="CompanyNameTextBox" Height="30" Margin="0,0,0,15"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Vorname" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="FirstNameTextBox" Height="30" Margin="0,0,0,15"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Nachname" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="LastNameTextBox" Height="30" Margin="0,0,0,15"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="E-Mail *" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="EmailTextBox" Height="30" Margin="0,0,0,15"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Telefon 1" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="Phone1TextBox" Height="30" Margin="0,0,0,15"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Telefon 2" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="Phone2TextBox" Height="30" Margin="0,0,0,15"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Straße" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="StreetTextBox" Height="30" Margin="0,0,0,15"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="PLZ" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="ZipcodeTextBox" Height="30" Margin="0,0,0,15"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Stadt" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="CityTextBox" Height="30" Margin="0,0,0,15"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Land" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox x:Name="CountryComboBox" Height="30" Margin="0,0,0,15">
                    <ComboBoxItem Content="DE" IsSelected="True"/>
                    <ComboBoxItem Content="AT"/>
                    <ComboBoxItem Content="CH"/>
                    <ComboBoxItem Content="FR"/>
                    <ComboBoxItem Content="IT"/>
                    <ComboBoxItem Content="NL"/>
                    <ComboBoxItem Content="BE"/>
                    <ComboBoxItem Content="LU"/>
                </ComboBox>

                <TextBlock Text="USt-IdNr." FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="VatIdTextBox" Height="30" Margin="0,0,0,15"/>

                <TextBlock Text="Notiz" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="NoteTextBox" Height="80" Margin="0,0,0,15" TextWrapping="Wrap" AcceptsReturn="True"/>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
