<Window x:Class="Projektsoftware.Views.AuditLogDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📋 Audit-Log"
        Height="600" Width="900"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="📋 Audit-Log"
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="#2196F3"
                   Margin="0,0,0,12"/>

        <!-- Filter row -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="FilterTextBox"
                     Grid.Column="0"
                     Height="30"
                     Padding="8,4"
                     FontSize="13"
                     VerticalContentAlignment="Center"
                     TextChanged="FilterTextBox_TextChanged"
                     Tag="Suche nach Benutzer, Typ, Aktion, Details…">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <VisualBrush Stretch="None" AlignmentX="Left">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="Suche nach Benutzer, Typ, Aktion, Details…"
                                                           Foreground="#AAAAAA"
                                                           FontSize="13"
                                                           Margin="8,4"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>
            <TextBlock x:Name="CountText"
                       Grid.Column="1"
                       VerticalAlignment="Center"
                       Foreground="#777"
                       FontSize="12"
                       Margin="12,0,0,0"/>
        </Grid>

        <!-- DataGrid -->
        <Border Grid.Row="2"
                BorderBrush="#DDDDDD"
                BorderThickness="1"
                CornerRadius="4">
            <DataGrid x:Name="AuditGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      BorderThickness="0"
                      RowHeight="28"
                      FontSize="12"
                      SelectionMode="Single"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Zeitstempel"    Binding="{Binding TimestampText}" Width="140"/>
                    <DataGridTextColumn Header="Benutzer"       Binding="{Binding UserName}"      Width="120"/>
                    <DataGridTextColumn Header=""               Binding="{Binding ActionIcon}"    Width="30"/>
                    <DataGridTextColumn Header="Aktion"         Binding="{Binding Action}"        Width="100"/>
                    <DataGridTextColumn Header="Typ"            Binding="{Binding EntityType}"    Width="90"/>
                    <DataGridTextColumn Header="ID"             Binding="{Binding EntityId}"      Width="60"/>
                    <DataGridTextColumn Header="Details"        Binding="{Binding Details}"       Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Button Grid.Row="3"
                Content="Schließen"
                Width="100"
                Height="32"
                HorizontalAlignment="Right"
                Margin="0,12,0,0"
                Click="Close_Click"/>
    </Grid>
</Window>
