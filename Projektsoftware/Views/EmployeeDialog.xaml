<Window x:Class="Projektsoftware.Views.EmployeeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mitarbeiter" Height="550" Width="500"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <DockPanel>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button Content="Speichern" Width="100" Height="35" Margin="0,0,10,0" Click="Save_Click" 
                    Background="#4CAF50" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
            <Button Content="Abbrechen" Width="100" Height="35" Click="Cancel_Click"
                    Background="#9E9E9E" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                <TextBlock Text="Vorname *" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="FirstNameTextBox" Height="30" Margin="0,0,0,15"/>

                <TextBlock Text="Nachname *" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="LastNameTextBox" Height="30" Margin="0,0,0,15"/>

                <TextBlock Text="E-Mail" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="EmailTextBox" Height="30" Margin="0,0,0,15"/>

                <TextBlock Text="Telefon" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="PhoneTextBox" Height="30" Margin="0,0,0,15"/>

                <TextBlock Text="Position" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="PositionTextBox" Height="30" Margin="0,0,0,15"/>

                <TextBlock Text="Abteilung" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="DepartmentTextBox" Height="30" Margin="0,0,0,15"/>

                <TextBlock Text="Stundensatz (€)" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="HourlyRateTextBox" Height="30" Margin="0,0,0,15"/>

                <TextBlock Text="Einstellungsdatum *" FontWeight="Bold" Margin="0,0,0,5"/>
                <DatePicker x:Name="HireDatePicker" Height="30" Margin="0,0,0,15"/>

                <CheckBox x:Name="IsActiveCheckBox" Content="Aktiv" FontWeight="Bold" IsChecked="True"/>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
