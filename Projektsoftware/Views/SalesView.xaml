<UserControl x:Class="Projektsoftware.Views.SalesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#F1F5F9" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📅 Sales" FontSize="18" FontWeight="Bold" Foreground="#1E293B"
                               VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <TextBlock x:Name="SubtitleText" Text="Neukunden-Terminplanung via sales@af-software-engineering.de"
                               FontSize="12" Foreground="#64748B" VerticalAlignment="Center"/>
                </StackPanel>
                <!-- Termine-Toolbar -->
                <StackPanel x:Name="AppointmentToolbar" Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="PollRsvpBtn" Content="🔄 RSVP prüfen" Height="34" Padding="12,0"
                            Margin="0,0,8,0" Background="#0F766E" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Click="PollRsvp_Click"
                            ToolTip="Postfach nach Termin-Antworten durchsuchen"/>
                    <Button Content="⚙ EWS" Height="34" Padding="10,0"
                            Margin="0,0,8,0" Background="#64748B" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Click="EwsSettings_Click"/>
                    <Button Content="+ Neuer Termin" Height="34" Padding="12,0"
                            Background="#2563EB" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Click="NewAppointment_Click"/>
                </StackPanel>
                <!-- Leads-Toolbar -->
                <StackPanel x:Name="LeadToolbar" Grid.Column="1" Orientation="Horizontal" Visibility="Collapsed">
                    <Button Content="+ Neuer Lead" Height="34" Padding="12,0"
                            Background="#7C3AED" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Click="NewLead_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tab-Content -->
        <TabControl x:Name="MainTabControl" Grid.Row="1" BorderThickness="0" Background="Transparent"
                    SelectionChanged="MainTabControl_SelectionChanged">

            <!-- Tab: Termine -->
            <TabItem Header="📅 Termine">
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="320"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8">
                        <DataGrid x:Name="AppointmentsGrid"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  SelectionMode="Single" GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column" BorderThickness="0"
                                  RowHeight="40" FontSize="13" AlternatingRowBackground="#F8FAFC"
                                  MouseDoubleClick="Grid_DoubleClick"
                                  SelectionChanged="AppointmentsGrid_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Status" Binding="{Binding RsvpIcon}" Width="60"/>
                                <DataGridTextColumn Header="Datum" Binding="{Binding AppointmentDate, StringFormat={}{0:dd.MM.yyyy}}" Width="90"/>
                                <DataGridTextColumn Header="Uhrzeit" Binding="{Binding AppointmentDate, StringFormat={}{0:HH:mm}}" Width="70"/>
                                <DataGridTextColumn Header="Betreff" Binding="{Binding Title}" Width="*"/>
                                <DataGridTextColumn Header="Kontakt" Binding="{Binding ContactName}" Width="140"/>
                                <DataGridTextColumn Header="Unternehmen" Binding="{Binding ContactCompany}" Width="140"/>
                                <DataGridTextColumn Header="E-Mail" Binding="{Binding ContactEmail}" Width="180"/>
                                <DataGridTextColumn Header="RSVP" Binding="{Binding RsvpSummary}" Width="140"/>
                                <DataGridTemplateColumn Header="Aktionen" Width="160">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="✏️" ToolTip="Bearbeiten"
                                                        Width="32" Height="28" Margin="2,0"
                                                        Background="Transparent" BorderThickness="1" BorderBrush="#CBD5E1"
                                                        Cursor="Hand" Click="Edit_Click"/>
                                                <Button Content="📧" ToolTip="Einladung erneut senden"
                                                        Width="32" Height="28" Margin="2,0"
                                                        Background="Transparent" BorderThickness="1" BorderBrush="#CBD5E1"
                                                        Cursor="Hand" Click="ResendInvite_Click"/>
                                                <Button Content="🗑" ToolTip="Löschen"
                                                        Width="32" Height="28" Margin="2,0"
                                                        Background="Transparent" BorderThickness="1" BorderBrush="#FCA5A5"
                                                        Cursor="Hand" Click="Delete_Click"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <Border Grid.Column="2" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="16">
                        <StackPanel x:Name="DetailPanel">
                            <TextBlock Text="Termin auswählen" FontSize="13" Foreground="#94A3B8"
                                       FontStyle="Italic" HorizontalAlignment="Center" Margin="0,40,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Tab: Leads -->
            <TabItem Header="📋 Leads">
                <Grid Margin="16">
                    <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8">
                        <DataGrid x:Name="LeadsGrid"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  SelectionMode="Single" GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column" BorderThickness="0"
                                  RowHeight="40" FontSize="13" AlternatingRowBackground="#F8FAFC"
                                  MouseDoubleClick="LeadsGrid_DoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Status" Binding="{Binding StatusIcon}" Width="60"/>
                                <DataGridTextColumn Header="Datum" Binding="{Binding LeadDate, StringFormat={}{0:dd.MM.yyyy}}" Width="90"/>
                                <DataGridTextColumn Header="Bezeichnung" Binding="{Binding Title}" Width="*"/>
                                <DataGridTextColumn Header="Kontakt" Binding="{Binding ContactName}" Width="140"/>
                                <DataGridTextColumn Header="Unternehmen" Binding="{Binding ContactCompany}" Width="160"/>
                                <DataGridTextColumn Header="Quelle" Binding="{Binding Source}" Width="110"/>
                                <DataGridTextColumn Header="Datei" Binding="{Binding FileStatus}" Width="90"/>
                                <DataGridTemplateColumn Header="Aktionen" Width="130">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="✏️" ToolTip="Bearbeiten"
                                                        Width="32" Height="28" Margin="2,0"
                                                        Background="Transparent" BorderThickness="1" BorderBrush="#CBD5E1"
                                                        Cursor="Hand" Click="EditLead_Click"/>
                                                <Button Content="📂" ToolTip="Leadbogen öffnen"
                                                        Width="32" Height="28" Margin="2,0"
                                                        Background="Transparent" BorderThickness="1" BorderBrush="#CBD5E1"
                                                        Cursor="Hand" Click="OpenLead_Click"/>
                                                <Button Content="🗑" ToolTip="Löschen"
                                                        Width="32" Height="28" Margin="2,0"
                                                        Background="Transparent" BorderThickness="1" BorderBrush="#FCA5A5"
                                                        Cursor="Hand" Click="DeleteLead_Click"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>
