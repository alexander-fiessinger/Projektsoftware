<Window x:Class="Projektsoftware.Views.TicketSmtpSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ticket-SMTP Konfiguration" Height="480" Width="650"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <DockPanel>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button Content="Test-E-Mail senden" Width="150" Height="35" Margin="0,0,10,0" Click="SendTestEmail_Click"
                    Background="#2196F3" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
            <Button Content="Verbindung testen" Width="140" Height="35" Margin="0,0,10,0" Click="TestConnection_Click"
                    Background="#FF9800" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
            <Button Content="Speichern" Width="100" Height="35" Margin="0,0,10,0" Click="Save_Click"
                    Background="#4CAF50" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
            <Button Content="Abbrechen" Width="100" Height="35" Click="Cancel_Click"
                    Background="#9E9E9E" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
        </StackPanel>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="25">
                <TextBlock Text="🎫 Ticket-SMTP Konfiguration" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                <TextBlock Text="Separates SMTP-Konto für den Versand von Ticket-E-Mails."
                           FontSize="12" Foreground="#666" TextWrapping="Wrap" Margin="0,0,0,20"/>

                <TextBlock Text="Absender-Name (z. B. Support Team)" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="SenderNameTextBox" Height="32" Margin="0,0,0,15"/>

                <TextBlock Text="Server *" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="SmtpServerTextBox" Height="32" Margin="0,0,0,15"/>

                <TextBlock Text="Login-ID *" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="EmailTextBox" Height="32" Margin="0,0,0,15"/>

                <TextBlock Text="Passwort *" FontWeight="Bold" Margin="0,0,0,5"/>
                <PasswordBox x:Name="PasswordBox" Height="32" Margin="0,0,0,15"/>

                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="SMTP-Port *" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="PortTextBox" Height="32" Text="465"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                        <CheckBox x:Name="UseSslCheckBox" Content="SSL/TLS (empfohlen)" Height="32" IsChecked="True"/>
                    </StackPanel>
                </Grid>

                <CheckBox x:Name="AcceptInvalidCertificatesCheckBox" Margin="0,0,0,4"
                          Content="SSL-Zertifikatsfehler ignorieren"/>
                <TextBlock TextWrapping="Wrap" Margin="20,0,0,20" Foreground="#757575" FontSize="11"
                           Text="Aktivieren wenn der Servername nicht mit dem SSL-Zertifikat übereinstimmt."/>

                <TextBlock x:Name="StatusTextBlock" Text="" Margin="0,5,0,0" FontWeight="Bold" TextWrapping="Wrap"/>
                <Border x:Name="SuccessPanel" Visibility="Collapsed" Background="#C8E6C9" Padding="12" Margin="0,10,0,0" CornerRadius="5">
                    <TextBlock x:Name="SuccessText" TextWrapping="Wrap" Foreground="#2E7D32"/>
                </Border>
                <Border x:Name="ErrorPanel" Visibility="Collapsed" Background="#FFCDD2" Padding="12" Margin="0,10,0,0" CornerRadius="5">
                    <TextBlock x:Name="ErrorText" TextWrapping="Wrap" Foreground="#C62828"/>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
