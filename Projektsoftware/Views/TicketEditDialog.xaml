<Window x:Class="Projektsoftware.Views.TicketEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ticket bearbeiten" 
        Height="750" 
        Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock x:Name="TicketNumberText" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="#2196F3"/>
            <TextBlock x:Name="CreatedAtText" 
                       FontSize="12" 
                       Foreground="#666" 
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Kundendaten (Read-only) -->
                <GroupBox Header="Kundendaten" Margin="0,0,0,15" Padding="15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="Name:"/>
                        <TextBox Grid.Row="0" Grid.Column="1" 
                                 x:Name="CustomerNameTextBox" 
                                 IsReadOnly="True" 
                                 Background="#F5F5F5" 
                                 Margin="5"/>

                        <Label Grid.Row="1" Grid.Column="0" Content="E-Mail:"/>
                        <TextBox Grid.Row="1" Grid.Column="1" 
                                 x:Name="CustomerEmailTextBox" 
                                 IsReadOnly="True" 
                                 Background="#F5F5F5" 
                                 Margin="5"/>

                        <Label Grid.Row="2" Grid.Column="0" Content="Telefon:"/>
                        <TextBox Grid.Row="2" Grid.Column="1" 
                                 x:Name="CustomerPhoneTextBox" 
                                 IsReadOnly="True" 
                                 Background="#F5F5F5" 
                                 Margin="5"/>
                    </Grid>
                </GroupBox>

                <!-- Ticket-Details (Read-only) -->
                <GroupBox Header="Ticket-Details" Margin="0,0,0,15" Padding="15">
                    <StackPanel>
                        <Label Content="Betreff:"/>
                        <TextBox x:Name="SubjectTextBox" 
                                 IsReadOnly="True" 
                                 Background="#F5F5F5" 
                                 Margin="5"/>

                        <Label Content="Beschreibung:"/>
                        <TextBox x:Name="DescriptionTextBox" 
                                 Height="100" 
                                 TextWrapping="Wrap" 
                                 IsReadOnly="True" 
                                 Background="#F5F5F5"
                                 VerticalScrollBarVisibility="Auto" 
                                 Margin="5"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <Label Content="Kategorie:"/>
                                <TextBox x:Name="CategoryTextBox" 
                                         IsReadOnly="True" 
                                         Background="#F5F5F5" 
                                         Margin="5"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <Label Content="Priorität:"/>
                                <ComboBox x:Name="PriorityComboBox" Margin="5">
                                    <ComboBoxItem Content="Niedrig"/>
                                    <ComboBoxItem Content="Mittel"/>
                                    <ComboBoxItem Content="Hoch"/>
                                    <ComboBoxItem Content="Dringend"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!-- Bearbeitung -->
                <GroupBox Header="Bearbeitung" Margin="0,0,0,15" Padding="15">
                    <StackPanel>
                        <Label Content="Status:"/>
                        <ComboBox x:Name="StatusComboBox" Margin="5">
                            <ComboBoxItem Content="Neu"/>
                            <ComboBoxItem Content="In Bearbeitung"/>
                            <ComboBoxItem Content="Warten auf Rückmeldung"/>
                            <ComboBoxItem Content="Gelöst"/>
                            <ComboBoxItem Content="Geschlossen"/>
                        </ComboBox>

                        <Label Content="Zugewiesen an:"/>
                        <ComboBox x:Name="AssignedToComboBox" 
                                  Margin="5"
                                  DisplayMemberPath="FullName"
                                  SelectedValuePath="Id"/>

                        <Label Content="Lösung/Kommentar:"/>
                        <TextBox x:Name="ResolutionTextBox" 
                                 Height="100" 
                                 TextWrapping="Wrap" 
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto" 
                                 Margin="5"/>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,20,0,0">
            <Button Content="Abbrechen" 
                    Width="120" 
                    Height="35" 
                    Margin="0,0,10,0" 
                    Click="Cancel_Click"/>
            <Button Content="Speichern" 
                    Width="120" 
                    Height="35" 
                    Click="Save_Click"
                    Background="#4CAF50"
                    Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
