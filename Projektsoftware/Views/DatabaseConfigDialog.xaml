<Window x:Class="Projektsoftware.Views.DatabaseConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Datenbankverbindung konfigurieren" Height="600" Width="600"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize" MinHeight="550" MinWidth="550">
    <DockPanel Margin="20">
        <!-- Buttons am unteren Rand fixiert -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Verbindung testen" 
                    Width="140" 
                    Height="40" 
                    Margin="0,0,10,0"
                    Click="TestConnection_Click"
                    Background="#FF9800" 
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Cursor="Hand"/>
            <Button Content="Speichern" 
                    Width="110" 
                    Height="40" 
                    Margin="0,0,10,0"
                    Click="Save_Click"
                    Background="#4CAF50" 
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Cursor="Hand"/>
            <Button Content="Abbrechen" 
                    Width="110" 
                    Height="40"
                    Click="Cancel_Click"
                    Background="#9E9E9E" 
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Cursor="Hand"/>
        </StackPanel>

        <!-- Scrollbarer Inhalt -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock FontSize="18" FontWeight="Bold" Margin="0,0,0,20" Foreground="#1976D2">
                    MySQL Datenbankverbindung zu Dogado
                </TextBlock>

                <TextBlock Text="Server-Adresse *" Margin="0,0,0,5" FontWeight="Bold"/>
                <TextBox x:Name="ServerTextBox" Margin="0,0,0,15" Height="30"
                         ToolTip="Für SSH-Tunnel: 127.0.0.1 | Für Direktverbindung: h761307.mysql.dogado.net"/>

                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Port *" Margin="0,0,0,5" FontWeight="Bold"/>
                        <TextBox x:Name="PortTextBox" Height="30" ToolTip="SSH-Tunnel: 3307 | Direkt: 3306"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="SSL-Modus" Margin="0,0,0,5" FontWeight="Bold"/>
                        <ComboBox x:Name="SslModeComboBox" SelectedIndex="0" Height="30">
                            <ComboBoxItem Content="Preferred"/>
                            <ComboBoxItem Content="Required"/>
                            <ComboBoxItem Content="None"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Datenbankname *" Margin="0,0,0,5" FontWeight="Bold"/>
                <TextBox x:Name="DatabaseTextBox" Margin="0,0,0,15" Height="30"/>

                <TextBlock Text="Benutzername *" Margin="0,0,0,5" FontWeight="Bold"/>
                <TextBox x:Name="UserTextBox" Margin="0,0,0,15" Height="30"/>

                <TextBlock Text="Passwort *" Margin="0,0,0,5" FontWeight="Bold"/>
                <PasswordBox x:Name="PasswordBox" Margin="0,0,0,15" Height="30"/>

                <Border Background="#E3F2FD" Padding="15" Margin="0,10,0,0" CornerRadius="5" BorderBrush="#1976D2" BorderThickness="1">
                    <StackPanel>
                        <TextBlock FontWeight="Bold" FontSize="14" Foreground="#1976D2" Margin="0,0,0,10">💡 Tipp:</TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,5" FontSize="13">
                            <Run FontWeight="Bold">SSH-Tunnel:</Run> Server=127.0.0.1, Port=3307
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" FontSize="13">
                            <Run FontWeight="Bold">Direktverbindung:</Run> Server=h761307.mysql.dogado.net, Port=3306
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
