<Window x:Class="Projektsoftware.Views.MeetingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:System="clr-namespace:System;assembly=mscorlib"
        Title="Meeting erstellen"
        Height="680" Width="580"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock x:Name="HeaderTextBlock"
                       Text="Meeting erstellen"
                       FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"/>
        </StackPanel>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Titel -->
                <TextBlock Text="Titel *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="TitleTextBox" Height="35" Margin="0,0,0,15"
                         VerticalContentAlignment="Center"/>

                <!-- Datum + Uhrzeiten -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Datum *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <DatePicker x:Name="MeetingDatePicker" Height="35"
                                    SelectedDateChanged="DateTime_Changed"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Beginn *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox x:Name="StartTimeBox" Height="35" Text="09:00"
                                 VerticalContentAlignment="Center"
                                 TextChanged="DateTime_Changed"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Ende *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox x:Name="EndTimeBox" Height="35" Text="10:00"
                                 VerticalContentAlignment="Center"
                                 TextChanged="DateTime_Changed"/>
                    </StackPanel>
                </Grid>

                <!-- Dauer-Vorschau -->
                <TextBlock x:Name="DurationPreviewTextBlock"
                           FontSize="12" Foreground="#888" Margin="0,-10,0,15"/>

                <!-- Ort -->
                <TextBlock Text="Ort / Raum" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="LocationTextBox" Height="35" Margin="0,0,0,15"
                         VerticalContentAlignment="Center"/>

                <!-- Projekt -->
                <TextBlock Text="Projekt (optional)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <ComboBox x:Name="ProjectComboBox" Height="35" Margin="0,0,0,15"
                          DisplayMemberPath="Name"/>

                <!-- Teilnehmer -->
                <TextBlock Text="Teilnehmer (E-Mail-Adressen, kommagetrennt)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="ParticipantsTextBox" Height="60" Margin="0,0,0,5"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"/>
                <TextBlock Text="Hinweis: Bei Webex-Meetings werden Einladungen an diese Adressen gesendet."
                           FontSize="11" Foreground="#888" Margin="0,0,0,15"/>

                <!-- Beschreibung -->
                <TextBlock Text="Beschreibung / Agenda" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="DescriptionTextBox" Height="70" Margin="0,0,0,20"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"/>

                <!-- Webex-Bereich -->
                <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8"
                        Padding="15" Background="#F8F9FA">
                    <StackPanel>
                        <CheckBox x:Name="WebexCheckBox"
                                  Content="Webex-Meeting erstellen"
                                  FontWeight="SemiBold" FontSize="14"
                                  Margin="0,0,0,10"
                                  Checked="WebexCheckBox_Checked"
                                  Unchecked="WebexCheckBox_Unchecked"/>

                        <!-- Webex Details (nur sichtbar wenn aktiv) -->
                        <StackPanel x:Name="WebexDetailsPanel" Visibility="Collapsed">
                            <Border x:Name="WebexInfoBorder" Background="#E3F2FD"
                                    Padding="12" CornerRadius="5" Margin="0,0,0,10"
                                    Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="Meeting-Link:" FontWeight="SemiBold" FontSize="12"/>
                                    <TextBlock x:Name="WebexLinkTextBlock"
                                               FontSize="12" Foreground="#1565C0"
                                               Cursor="Hand" TextDecorations="Underline"
                                               MouseLeftButtonDown="WebexLink_Click"
                                               TextWrapping="Wrap" Margin="0,3,0,5"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Passwort:" FontWeight="SemiBold" FontSize="12" Margin="0,0,8,0"/>
                                        <TextBlock x:Name="WebexPasswordTextBlock" FontSize="12" FontFamily="Consolas"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                        <TextBlock Text="Host Key:" FontWeight="SemiBold" FontSize="12" Margin="0,0,8,0"/>
                                        <TextBlock x:Name="WebexHostKeyTextBlock" FontSize="12" FontFamily="Consolas"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock x:Name="WebexStatusTextBlock"
                                       FontSize="12" Foreground="#666" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Abbrechen" Width="110" Height="38" Margin="0,0,10,0"
                    Click="Cancel_Click"
                    Background="#f44336" Foreground="White" BorderThickness="0"
                    Cursor="Hand" FontWeight="SemiBold"/>
            <Button x:Name="SaveButton" Content="Speichern" Width="140" Height="38"
                    Click="Save_Click"
                    Background="#4CAF50" Foreground="White" BorderThickness="0"
                    Cursor="Hand" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</Window>
