<Window x:Class="Projektsoftware.Views.UpdateSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update-Einstellungen"
        Height="370" Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Update-Einstellungen"
                       FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"/>
            <TextBlock FontSize="13" Foreground="#666" Margin="0,5,0,0" TextWrapping="Wrap">
                Geben Sie die URL zum Update-Manifest an. Die Anwendung prüft diese URL
                beim Start auf neue Versionen.
            </TextBlock>
        </StackPanel>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Manifest URL -->
                <TextBlock Text="Manifest-URL *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="ManifestUrlBox"
                         Height="35" Margin="0,0,0,5"
                         VerticalContentAlignment="Center"
                         FontFamily="Consolas"/>
                <TextBlock FontSize="11" Foreground="#888" Margin="0,0,0,20" TextWrapping="Wrap">
                    URL zu einer JSON-Datei mit folgendem Format:
                    {"version":"1.1.0","downloadUrl":"https://…/setup.exe","releaseNotes":"- Änderungen"}
                </TextBlock>

                <!-- Auto-Check -->
                <CheckBox x:Name="AutoCheckCheckBox"
                          Content="Beim Programmstart automatisch auf Updates prüfen"
                          IsChecked="True" Margin="0,0,0,20"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Abbrechen" Width="110" Height="38" Margin="0,0,10,0"
                    Click="Cancel_Click"
                    Background="#f44336" Foreground="White" BorderThickness="0"
                    Cursor="Hand" FontWeight="SemiBold"/>
            <Button Content="Speichern" Width="110" Height="38"
                    Click="Save_Click"
                    Background="#4CAF50" Foreground="White" BorderThickness="0"
                    Cursor="Hand" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</Window>
