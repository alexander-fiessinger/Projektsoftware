<Window x:Class="Projektsoftware.Views.GanttDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gantt-Diagramm" Height="600" Width="1100"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Gantt-Diagramm" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

        <DockPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock Text="Projekt:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <Button DockPanel.Dock="Right" Content="Anzeigen" Width="100" Margin="8,0,0,0" Click="Show_Click"/>
            <ComboBox x:Name="ProjectCombo" DisplayMemberPath="Name"/>
        </DockPanel>

        <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="GanttItems">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,2" Height="28">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding TaskName}" VerticalAlignment="Center" Margin="4,0"/>
                            <TextBlock Grid.Column="1" Text="{Binding StartDate, StringFormat={}{0:dd.MM.yy}}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding EndDate, StringFormat={}{0:dd.MM.yy}}" VerticalAlignment="Center"/>
                            <Canvas Grid.Column="3" Background="#FAFAFA" Height="24" VerticalAlignment="Center">
                                <Rectangle Canvas.Left="{Binding OffsetLeft}" Width="{Binding BarWidth}" Height="20"
                                           Fill="{Binding BarColor}" RadiusX="3" RadiusY="3"/>
                                <TextBlock Canvas.Left="{Binding OffsetLeft}" Text="{Binding ProgressText}" Foreground="White" FontSize="10" Margin="4,2,0,0"/>
                            </Canvas>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Schließen" Width="100" Click="Close_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
