<Window x:Class="Projektsoftware.Views.PublicTicketFormApp"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Support Anfrage - Projektierungssoftware" 
        Height="700" 
        Width="750"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Icon="pack://application:,,,/Resources/icon.ico">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,5,0,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,5,0,12"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Header mit Branding -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" 
                Background="#2196F3" 
                Padding="30,25">
            <StackPanel>
                <TextBlock Text="📨 Support-Anfrage" 
                           FontSize="32" 
                           FontWeight="Bold" 
                           Foreground="White"/>
                <TextBlock Text="Projektierungssoftware Professional" 
                           FontSize="16" 
                           Foreground="White" 
                           Opacity="0.9"
                           Margin="0,5,0,0"/>
                <TextBlock Text="Wir helfen Ihnen gerne weiter!" 
                           FontSize="14" 
                           Foreground="White" 
                           Opacity="0.8"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto"
                      Padding="30,20">
            <StackPanel MaxWidth="650">
                <!-- Info-Box -->
                <Border Background="#E3F2FD" 
                        BorderBrush="#2196F3" 
                        BorderThickness="1" 
                        Padding="15" 
                        Margin="0,0,0,25" 
                        CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="ℹ️ Hinweis" 
                                   FontWeight="Bold" 
                                   FontSize="14" 
                                   Foreground="#1976D2"/>
                        <TextBlock Text="Bitte füllen Sie das Formular vollständig aus. Wir werden uns innerhalb von 24 Stunden bei Ihnen melden." 
                                   TextWrapping="Wrap" 
                                   Margin="0,5,0,0" 
                                   Foreground="#424242"/>
                    </StackPanel>
                </Border>

                <!-- Kontaktdaten -->
                <TextBlock Text="Ihre Kontaktdaten" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="#2196F3" 
                           Margin="0,0,0,15"/>

                <Label Content="Name oder Firma *"/>
                <TextBox x:Name="CustomerNameTextBox" 
                         ToolTip="Ihr vollständiger Name oder Firmenname"/>

                <Label Content="E-Mail-Adresse *"/>
                <TextBox x:Name="CustomerEmailTextBox" 
                         ToolTip="Ihre E-Mail-Adresse für Rückmeldungen"/>

                <Label Content="Telefonnummer (optional)"/>
                <TextBox x:Name="CustomerPhoneTextBox" 
                         ToolTip="Ihre Telefonnummer für Rückfragen"/>

                <Separator Margin="0,20"/>

                <!-- Anliegen -->
                <TextBlock Text="Ihr Anliegen" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="#2196F3" 
                           Margin="0,10,0,15"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <Label Content="Kategorie *"/>
                        <ComboBox x:Name="CategoryComboBox" SelectedIndex="0">
                            <ComboBoxItem Content="Allgemeine Anfrage"/>
                            <ComboBoxItem Content="Technisches Problem"/>
                            <ComboBoxItem Content="Abrechnung / Rechnung"/>
                            <ComboBoxItem Content="Feature-Wunsch"/>
                            <ComboBoxItem Content="Fehlermeldung"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <Label Content="Dringlichkeit *"/>
                        <ComboBox x:Name="PriorityComboBox" SelectedIndex="1">
                            <ComboBoxItem Content="⚪ Niedrig"/>
                            <ComboBoxItem Content="🔵 Normal"/>
                            <ComboBoxItem Content="🟠 Hoch"/>
                            <ComboBoxItem Content="🔴 Sehr dringend"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <Label Content="Betreff *"/>
                <TextBox x:Name="SubjectTextBox" 
                         ToolTip="Kurze Zusammenfassung Ihres Anliegens"/>

                <Label Content="Detaillierte Beschreibung *"/>
                <TextBox x:Name="DescriptionTextBox" 
                         Height="180" 
                         TextWrapping="Wrap" 
                         AcceptsReturn="True" 
                         VerticalScrollBarVisibility="Auto"
                         ToolTip="Bitte beschreiben Sie Ihr Anliegen so detailliert wie möglich"/>

                <TextBlock Text="* Pflichtfelder" 
                           FontSize="11" 
                           Foreground="#666" 
                           FontStyle="Italic"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer mit Buttons -->
        <Border Grid.Row="2" 
                Background="#F5F5F5" 
                BorderBrush="#E0E0E0" 
                BorderThickness="0,1,0,0" 
                Padding="30,20">
            <Grid MaxWidth="650">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           Text="Ihre Daten werden vertraulich behandelt." 
                           VerticalAlignment="Center" 
                           FontSize="11" 
                           Foreground="#666"/>

                <StackPanel Grid.Column="1" 
                            Orientation="Horizontal">
                    <Button Content="Abbrechen" 
                            Width="130" 
                            Height="40" 
                            Margin="0,0,15,0" 
                            Click="Cancel_Click"
                            FontSize="14"
                            Background="#E0E0E0"/>
                    <Button Content="✉️ Anfrage absenden" 
                            Width="180" 
                            Height="40" 
                            Click="Submit_Click"
                            FontSize="14"
                            FontWeight="Bold"
                            Background="#4CAF50"
                            Foreground="White"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
