<Window x:Class="Projektsoftware.Views.PurchaseDocumentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Belegablage" Width="540" Height="490"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="TitleText" Text="📁 Neuen Beleg ablegen"
                   FontSize="18" FontWeight="Bold" Foreground="#1A237E" Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Lieferant" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ComboBox x:Name="SupplierCombo" Height="32" FontSize="13"
                          DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,12"/>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="170"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Bezeichnung *" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox x:Name="DocumentNameBox" Height="32" Padding="6,4" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Belegtyp" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox x:Name="DocumentTypeCombo" Height="32" FontSize="13">
                            <ComboBoxItem Content="Rechnung" IsSelected="True"/>
                            <ComboBoxItem Content="Lieferschein"/>
                            <ComboBoxItem Content="Angebot"/>
                            <ComboBoxItem Content="Gutschrift"/>
                            <ComboBoxItem Content="Sonstiges"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="Belegdatum *" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <DatePicker x:Name="DocumentDatePicker" Height="32" FontSize="13" Width="200" HorizontalAlignment="Left"/>
                </StackPanel>

                <Border Background="#F5F5F5" BorderBrush="#BDBDBD" BorderThickness="1"
                        CornerRadius="4" Padding="12,10" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="📎 Dateianhang" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <DockPanel>
                            <Button x:Name="SelectFileBtn" DockPanel.Dock="Left"
                                    Content="Datei auswählen…" Height="32" Padding="10,4"
                                    Margin="0,0,10,0" Background="#1A237E" Foreground="White"
                                    BorderThickness="0" Click="SelectFile_Click"/>
                            <TextBlock x:Name="SelectedFileText" VerticalAlignment="Center"
                                       Foreground="#616161" FontStyle="Italic"
                                       Text="Keine Datei ausgewählt"
                                       TextTrimming="CharacterEllipsis"/>
                        </DockPanel>
                        <TextBlock x:Name="FileSizeText" FontSize="11" Foreground="#9E9E9E"
                                   Margin="0,4,0,0" Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="Notizen" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox x:Name="NotesBox" Height="60" Padding="6,4" FontSize="13"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Abbrechen" Width="100" Height="36" Margin="0,0,8,0"
                    IsCancel="True" Click="Cancel_Click"/>
            <Button Content="💾 Speichern" Width="120" Height="36"
                    Background="#1A237E" Foreground="White" BorderThickness="0"
                    IsDefault="True" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
