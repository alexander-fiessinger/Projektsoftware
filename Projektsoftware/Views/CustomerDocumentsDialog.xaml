<Window x:Class="Projektsoftware.Views.CustomerDocumentsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kundendokumente" Height="600" Width="950"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="📄 Kundendokumente"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"/>
            <TextBlock x:Name="CustomerNameTextBlock"
                       FontSize="15"
                       Foreground="Gray"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Toolbar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <Button Content="📎 Dokument hinzufügen"
                    Width="190"
                    Height="36"
                    Margin="0,0,10,0"
                    Click="AddDocument_Click"
                    Background="{StaticResource SuccessBrush}"
                    Foreground="White"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Cursor="Hand"/>
            <Button Content="🔄 Aktualisieren"
                    Width="140"
                    Height="36"
                    Click="Refresh_Click"
                    Background="{StaticResource NeutralBrush}"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"/>
        </StackPanel>

        <!-- Data Grid -->
        <DataGrid x:Name="DocumentsDataGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  MouseDoubleClick="DocumentsDataGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Dateiname" Binding="{Binding FileName}" Width="*" IsReadOnly="True"/>
                <DataGridTextColumn Header="Typ" Binding="{Binding FileType}" Width="70" IsReadOnly="True"/>
                <DataGridTextColumn Header="Größe" Binding="{Binding FileSizeFormatted}" Width="90" IsReadOnly="True"/>
                <DataGridTextColumn Header="Beschreibung" Binding="{Binding Description}" Width="200" IsReadOnly="True"/>
                <DataGridTextColumn Header="Hochgeladen von" Binding="{Binding UploadedBy}" Width="130" IsReadOnly="True"/>
                <DataGridTextColumn Header="Datum" Binding="{Binding UploadedAt, StringFormat=dd.MM.yyyy HH:mm}" Width="130" IsReadOnly="True"/>
                <DataGridTemplateColumn Header="Aktionen" Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="📂" ToolTip="Öffnen"
                                        Margin="2" Padding="7,3"
                                        Click="OpenDocument_Click"
                                        Style="{StaticResource ActionButton}"
                                        Foreground="{StaticResource PrimaryBrush}"/>
                                <Button Content="📁" ToolTip="Im Explorer anzeigen"
                                        Margin="2" Padding="7,3"
                                        Click="ShowInExplorer_Click"
                                        Style="{StaticResource ActionButton}"/>
                                <Button Content="🗑️" ToolTip="Löschen"
                                        Margin="2" Padding="7,3"
                                        Click="DeleteDocument_Click"
                                        Style="{StaticResource DangerActionButton}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status Bar -->
        <Border Grid.Row="3"
                Background="#F5F5F5"
                BorderBrush="#CCCCCC"
                BorderThickness="0,1,0,0"
                Padding="10"
                Margin="0,15,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="StatusTextBlock"
                           Text="Bereit"
                           VerticalAlignment="Center"
                           Margin="0,0,20,0"/>
                <TextBlock x:Name="CountTextBlock"
                           Text="0 Dokumente"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
