<Window x:Class="Projektsoftware.Views.CustomerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kunde bearbeiten" Height="650" Width="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" 
                   Text="👤 Kunde anlegen/bearbeiten"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="{StaticResource PrimaryBrush}"
                   Margin="0,0,0,20"/>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Company Name -->
                <TextBlock Text="Firmenname:" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="CompanyNameTextBox" 
                         Height="35"
                         Margin="0,0,0,15"
                         VerticalContentAlignment="Center"/>

                <!-- First Name -->
                <TextBlock Text="Vorname:" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="FirstNameTextBox" 
                         Height="35"
                         Margin="0,0,0,15"
                         VerticalContentAlignment="Center"/>

                <!-- Last Name -->
                <TextBlock Text="Nachname:" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="LastNameTextBox" 
                         Height="35"
                         Margin="0,0,0,15"
                         VerticalContentAlignment="Center"/>

                <!-- Email -->
                <TextBlock Text="E-Mail:" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="EmailTextBox" 
                         Height="35"
                         Margin="0,0,0,15"
                         VerticalContentAlignment="Center"/>

                <!-- Phone -->
                <TextBlock Text="Telefon:" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="PhoneTextBox" 
                         Height="35"
                         Margin="0,0,0,15"
                         VerticalContentAlignment="Center"/>

                <!-- Street -->
                <TextBlock Text="Straße:" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="StreetTextBox" 
                         Height="35"
                         Margin="0,0,0,15"
                         VerticalContentAlignment="Center"/>

                <!-- ZIP and City -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="PLZ:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="ZipCodeTextBox" 
                                 Height="35"
                                 VerticalContentAlignment="Center"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Stadt:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="CityTextBox" 
                                 Height="35"
                                 VerticalContentAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- Country -->
                <TextBlock Text="Land:" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="CountryTextBox" 
                         Text="Deutschland"
                         Height="35"
                         Margin="0,0,0,15"
                         VerticalContentAlignment="Center"/>

                <!-- VAT ID -->
                <TextBlock Text="USt-ID:" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="VatIdTextBox" 
                         Height="35"
                         Margin="0,0,0,15"
                         VerticalContentAlignment="Center"/>

                <!-- Note -->
                <TextBlock Text="Notizen:" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="NoteTextBox" 
                         Height="80"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,0,0,15"/>

                <!-- Sync to Easybill -->
                <CheckBox x:Name="SyncToEasybillCheckBox"
                          Content="✓ Automatisch zu Easybill synchronisieren"
                          IsChecked="True"
                          FontWeight="Bold"
                          Margin="0,10,0,0"/>
                
                <TextBlock x:Name="SyncStatusTextBlock"
                           Text=""
                           Foreground="Gray"
                           FontStyle="Italic"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="Speichern"
                    Width="120"
                    Height="40"
                    Margin="0,0,10,0"
                    Click="Save_Click"
                    Background="{StaticResource PrimaryBrush}"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Cursor="Hand"/>
            <Button Content="Abbrechen"
                    Width="120"
                    Height="40"
                    Click="Cancel_Click"
                    Background="#E0E0E0"
                    BorderThickness="0"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
