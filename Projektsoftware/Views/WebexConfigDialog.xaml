<Window x:Class="Projektsoftware.Views.WebexConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Webex Konfiguration"
        Height="480" Width="560"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Webex Integration konfigurieren"
                       FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"/>
            <TextBlock FontSize="13" Foreground="#666" Margin="0,5,0,0" TextWrapping="Wrap">
                Geben Sie Ihr Webex Personal Access Token ein, um Meetings direkt aus der
                Software zu erstellen. Das Token erhalten Sie unter developer.webex.com.
            </TextBlock>
        </StackPanel>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Access Token -->
                <TextBlock Text="Personal Access Token *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <PasswordBox x:Name="AccessTokenBox"
                             Height="35" Margin="0,0,0,5"
                             VerticalContentAlignment="Center"
                             FontFamily="Consolas"/>
                <TextBlock FontSize="11" Foreground="#888" Margin="0,0,0,15" TextWrapping="Wrap">
                    Token unter https://developer.webex.com/docs/getting-started abrufen.
                    Personal Access Tokens sind 12 Stunden gültig. Für dauerhaften Zugriff
                    bitte eine Integration (OAuth) oder einen Bot erstellen.
                </TextBlock>

                <!-- Bot Name -->
                <TextBlock Text="Anzeigename (optional)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="BotNameBox"
                         Height="35" Margin="0,0,0,15"
                         VerticalContentAlignment="Center"
                         Text="Projektierungssoftware"/>

                <!-- Send Invite Emails -->
                <CheckBox x:Name="SendEmailsCheckBox"
                          Content="Einladungs-E-Mails an Teilnehmer senden"
                          IsChecked="True" Margin="0,0,0,20"/>

                <!-- Status Box -->
                <Border x:Name="StatusBorder"
                        Padding="12" CornerRadius="5"
                        Visibility="Collapsed" Margin="0,0,0,10">
                    <TextBlock x:Name="StatusTextBlock"
                               FontSize="13" TextWrapping="Wrap" Foreground="White"/>
                </Border>

                <!-- Verbindung testen -->
                <Button x:Name="TestButton"
                        Content="Verbindung testen"
                        Height="36" HorizontalAlignment="Left" Padding="15,0"
                        Click="Test_Click"
                        Background="#2196F3" Foreground="White"
                        BorderThickness="0" Cursor="Hand" FontWeight="SemiBold"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Abbrechen" Width="110" Height="38" Margin="0,0,10,0"
                    Click="Cancel_Click"
                    Background="#f44336" Foreground="White" BorderThickness="0"
                    Cursor="Hand" FontWeight="SemiBold"/>
            <Button Content="Speichern" Width="110" Height="38"
                    Click="Save_Click"
                    Background="#4CAF50" Foreground="White" BorderThickness="0"
                    Cursor="Hand" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</Window>
