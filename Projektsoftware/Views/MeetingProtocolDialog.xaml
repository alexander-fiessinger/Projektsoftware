<Window x:Class="Projektsoftware.Views.MeetingProtocolDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Besprechungsprotokoll" Height="700" Width="700"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Titel *" Grid.Row="0" Margin="0,0,0,5" FontWeight="Bold"/>
            <TextBox x:Name="TitleTextBox" Grid.Row="0" Margin="0,25,0,10"/>

            <TextBlock Text="Projekt *" Grid.Row="1" Margin="0,0,0,5" FontWeight="Bold"/>
            <ComboBox x:Name="ProjectComboBox" 
                      Grid.Row="1" 
                      Margin="0,25,0,10"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Id"/>

            <Grid Grid.Row="2" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Besprechungsdatum *" Margin="0,0,0,5" FontWeight="Bold"/>
                    <DatePicker x:Name="MeetingDatePicker"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Uhrzeit *" Margin="0,0,0,5" FontWeight="Bold"/>
                    <TextBox x:Name="MeetingTimeTextBox" Text="10:00"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="Ort" Grid.Row="3" Margin="0,0,0,5" FontWeight="Bold"/>
            <TextBox x:Name="LocationTextBox" Grid.Row="3" Margin="0,25,0,10"/>

            <TextBlock Text="Teilnehmer" Grid.Row="4" Margin="0,0,0,5" FontWeight="Bold"/>
            <TextBox x:Name="ParticipantsTextBox" 
                     Grid.Row="4" 
                     Margin="0,25,0,10" 
                     Height="60" 
                     TextWrapping="Wrap" 
                     AcceptsReturn="True"/>

            <TextBlock Text="Tagesordnung" Grid.Row="5" Margin="0,0,0,5" FontWeight="Bold"/>
            <TextBox x:Name="AgendaTextBox" 
                     Grid.Row="5" 
                     Margin="0,25,0,10" 
                     Height="80" 
                     TextWrapping="Wrap" 
                     AcceptsReturn="True"/>

            <TextBlock Text="Diskussion" Grid.Row="6" Margin="0,0,0,5" FontWeight="Bold"/>
            <TextBox x:Name="DiscussionTextBox" 
                     Grid.Row="6" 
                     Margin="0,25,0,10" 
                     Height="80" 
                     TextWrapping="Wrap" 
                     AcceptsReturn="True"/>

            <TextBlock Text="Beschlüsse" Grid.Row="7" Margin="0,0,0,5" FontWeight="Bold"/>
            <TextBox x:Name="DecisionsTextBox" 
                     Grid.Row="7" 
                     Margin="0,25,0,10" 
                     Height="80" 
                     TextWrapping="Wrap" 
                     AcceptsReturn="True"/>

            <TextBlock Text="Aufgaben / To-Do" Grid.Row="8" Margin="0,0,0,5" FontWeight="Bold"/>
            <TextBox x:Name="ActionItemsTextBox" 
                     Grid.Row="8" 
                     Margin="0,25,0,10" 
                     Height="80" 
                     TextWrapping="Wrap" 
                     AcceptsReturn="True"/>

            <TextBlock Text="Nächster Termin" Grid.Row="9" Margin="0,0,0,5" FontWeight="Bold"/>
            <TextBox x:Name="NextMeetingTextBox" Grid.Row="9" Margin="0,25,0,10"/>

            <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="SaveButton"
                        Content="Speichern" 
                        Width="100" 
                        Height="35" 
                        Margin="0,0,10,0"
                        Click="Save_Click"
                        Background="#4CAF50" 
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"/>
                <Button Content="Schließen" 
                        Width="100" 
                        Height="35"
                        Click="Cancel_Click"
                        Background="#9E9E9E" 
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>
