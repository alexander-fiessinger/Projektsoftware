<Window x:Class="Projektsoftware.Views.EasybillSendEmailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📧 Dokument per E-Mail versenden" 
        Height="500" 
        Width="600"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="📧 Dokument per E-Mail versenden" 
                       FontSize="20" 
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"/>
            <TextBlock x:Name="DocumentInfoTextBlock"
                       Text="Dokument: ..."
                       FontSize="13"
                       Foreground="#666"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- An -->
        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="An (E-Mail) *" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="ToTextBox" 
                     Height="35"
                     Padding="10,8"
                     FontSize="13"/>
        </StackPanel>

        <!-- CC -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="CC (optional)" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="CcTextBox" 
                     Height="35"
                     Padding="10,8"
                     FontSize="13"/>
        </StackPanel>

        <!-- BCC -->
        <StackPanel Grid.Row="3" Margin="0,0,0,12">
            <TextBlock Text="BCC (optional)" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="BccTextBox" 
                     Height="35"
                     Padding="10,8"
                     FontSize="13"/>
        </StackPanel>

        <!-- Betreff -->
        <StackPanel Grid.Row="4" Margin="0,0,0,12">
            <TextBlock Text="Betreff *" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="SubjectTextBox" 
                     Height="35"
                     Padding="10,8"
                     FontSize="13"/>
        </StackPanel>

        <!-- Nachricht -->
        <StackPanel Grid.Row="5" Margin="0,0,0,15">
            <TextBlock Text="Nachricht *" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="MessageTextBox" 
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Padding="10"
                     FontSize="13"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="6" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right">
            <Button Content="Abbrechen" 
                    Width="100" 
                    Height="35"
                    Margin="0,0,10,0"
                    Click="Cancel_Click"
                    Background="#9E9E9E" 
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"/>
            <Button Content="📧 Senden" 
                    Width="100" 
                    Height="35"
                    Click="Send_Click"
                    Background="{StaticResource PrimaryBrush}"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</Window>
