<Window x:Class="Projektsoftware.Views.ProjectTemplatesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Projektvorlagen" Height="560" Width="820"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Projektvorlagen" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ListBox x:Name="TemplatesList" DisplayMemberPath="Name" SelectionChanged="TemplatesList_SelectionChanged"/>

            <DataGrid Grid.Column="1" x:Name="TasksGrid" Margin="8,0,0,0" AutoGenerateColumns="False"
                      IsReadOnly="True" HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Aufgabe" Binding="{Binding Title}" Width="*"/>
                    <DataGridTextColumn Header="Priorität" Binding="{Binding Priority}" Width="100"/>
                    <DataGridTextColumn Header="Fällig nach (Tage)" Binding="{Binding DueAfterDays}" Width="140"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <GroupBox Grid.Row="2" Header="Neues Projekt aus Vorlage anlegen" Margin="0,10,0,0">
            <Grid Margin="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="NewProjectName" Margin="4" Padding="4"/>
                <TextBox x:Name="NewClientName" Grid.Column="1" Margin="4" Padding="4"/>
                <Button Grid.Column="2" Content="Projekt erstellen" Width="140" Margin="4" Click="CreateProject_Click"/>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Vorlage löschen" Width="140" Click="DeleteTemplate_Click"/>
            <Button Content="Schließen" Width="100" Margin="8,0,0,0" Click="Close_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
