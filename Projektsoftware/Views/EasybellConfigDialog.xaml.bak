<Window x:Class="Projektsoftware.Views.EasybellConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Easybell Telefon-Konfiguration" Height="520" Width="600"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <DockPanel>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button Content="Verbindung testen" Width="140" Height="35" Margin="0,0,10,0"
                    Click="TestConnection_Click"
                    Background="#FF9800" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
            <Button Content="Speichern" Width="100" Height="35" Margin="0,0,10,0"
                    Click="Save_Click"
                    Background="#4CAF50" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
            <Button Content="Abbrechen" Width="100" Height="35"
                    Click="Cancel_Click"
                    Background="#9E9E9E" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                <TextBlock Text="📞 Easybell Telefon-Einstellungen" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

                <Border Background="#E3F2FD" Padding="15" Margin="0,0,0,20" CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="ℹ️ Wo finde ich meine Zugangsdaten?" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,5">
                            Verwenden Sie Ihren Easybell-Portalbenutzernamen (E-Mail) und Ihr Portalpasswort.
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,5">
                            1. Melden Sie sich im Easybell-Kundencenter an (https://www.easybell.de)
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,5">
                            2. Ihre Login-E-Mail ist der Benutzername
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap">
                            3. Tragen Sie außerdem Ihre Durchwahl für Click-to-Call ein (z.B. +49301234560)
                        </TextBlock>
                    </StackPanel>
                </Border>

                <TextBlock Text="Benutzername (E-Mail) *" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="UsernameTextBox" Height="30" Margin="0,0,0,15"/>

                <TextBlock Text="Passwort *" FontWeight="Bold" Margin="0,0,0,5"/>
                <PasswordBox x:Name="PasswordBox" Height="30" Margin="0,0,0,15"/>

                <TextBlock Text="Durchwahl / Nebenstelle (für Click-to-Call) *" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="ExtensionTextBox" Height="30" Margin="0,0,0,5"/>
                <TextBlock Text="Beispiel: +49301234560 oder 0" FontSize="11"
                           Foreground="#888" Margin="0,0,0,15"/>

                <TextBlock Text="API-URL" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="ApiUrlTextBox" Height="30" Margin="0,0,0,5"
                         Text="https://api.easybell.de/v1"/>
                <TextBlock Text="Nur ändern, wenn Easybell eine andere URL vorgibt." FontSize="11"
                           Foreground="#888" Margin="0,0,0,15"/>

                <TextBlock x:Name="StatusTextBlock" Text="" Margin="0,10,0,0"
                           FontWeight="Bold" TextWrapping="Wrap"/>

                <Border x:Name="TestResultPanel" Visibility="Collapsed"
                        Background="#C8E6C9" Padding="15" Margin="0,10,0,0" CornerRadius="5">
                    <TextBlock x:Name="TestResultText" TextWrapping="Wrap" Foreground="#2E7D32"/>
                </Border>

                <Border x:Name="ErrorPanel" Visibility="Collapsed"
                        Background="#FFCDD2" Padding="15" Margin="0,10,0,0" CornerRadius="5">
                    <TextBlock x:Name="ErrorText" TextWrapping="Wrap" Foreground="#C62828"/>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
