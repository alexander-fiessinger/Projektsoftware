<Window x:Class="Projektsoftware.Views.TicketDetailsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ticket-Details" 
        Height="800" 
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!-- Linke Seite: Ticket-Infos -->
        <Border Grid.Column="0" 
                Background="#F5F5F5" 
                BorderBrush="#E0E0E0" 
                BorderThickness="0,0,1,0" 
                Padding="20">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Header -->
                    <TextBlock x:Name="TicketNumberText" 
                               Text="#000000" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="#2196F3"
                               Margin="0,0,0,5"/>
                    
                    <TextBlock x:Name="StatusBadge" 
                               Text="NEU" 
                               FontSize="12" 
                               FontWeight="Bold" 
                               Padding="8,4"
                               Background="#FF9800"
                               Foreground="White"
                               HorizontalAlignment="Left"
                               Margin="0,0,0,20"/>

                    <!-- Kunde -->
                    <TextBlock Text="👤 Kunde" 
                               FontWeight="Bold" 
                               FontSize="14" 
                               Margin="0,10,0,5"/>
                    <TextBlock x:Name="CustomerNameText" 
                               FontSize="13" 
                               Margin="0,0,0,5"/>
                    <TextBlock x:Name="CustomerEmailText" 
                               Foreground="#666" 
                               FontSize="12" 
                               Margin="0,0,0,5"/>
                    <TextBlock x:Name="CustomerPhoneText" 
                               Foreground="#666" 
                               FontSize="12" 
                               Margin="0,0,0,15"/>

                    <!-- Betreff & Beschreibung -->
                    <TextBlock Text="📝 Betreff" 
                               FontWeight="Bold" 
                               FontSize="14" 
                               Margin="0,10,0,5"/>
                    <TextBlock x:Name="SubjectText" 
                               TextWrapping="Wrap" 
                               FontSize="13" 
                               Margin="0,0,0,15"/>

                    <TextBlock Text="📄 Beschreibung" 
                               FontWeight="Bold" 
                               FontSize="14" 
                               Margin="0,10,0,5"/>
                    <TextBlock x:Name="DescriptionText" 
                               TextWrapping="Wrap" 
                               FontSize="12" 
                               Foreground="#333" 
                               Margin="0,0,0,15"/>

                    <!-- Kategorisierung -->
                    <Separator Margin="0,10"/>
                    
                    <Grid Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" 
                                   Text="Priorität:" 
                                   FontWeight="Bold" 
                                   Margin="0,0,10,10"/>
                        <TextBlock x:Name="PriorityText" 
                                   Grid.Row="0" Grid.Column="1" 
                                   Margin="0,0,0,10"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" 
                                   Text="Kategorie:" 
                                   FontWeight="Bold" 
                                   Margin="0,0,10,10"/>
                        <TextBlock x:Name="CategoryText" 
                                   Grid.Row="1" Grid.Column="1" 
                                   Margin="0,0,0,10"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" 
                                   Text="Zugewiesen:" 
                                   FontWeight="Bold" 
                                   Margin="0,0,10,10"/>
                        <TextBlock x:Name="AssignedToText" 
                                   Grid.Row="2" Grid.Column="1" 
                                   Margin="0,0,0,10"/>
                    </Grid>

                    <!-- Zeitstempel -->
                    <Separator Margin="0,10"/>
                    
                    <TextBlock Text="🕐 Zeitstempel" 
                               FontWeight="Bold" 
                               FontSize="14" 
                               Margin="0,10,0,5"/>
                    <TextBlock x:Name="CreatedAtText" 
                               FontSize="11" 
                               Foreground="#666" 
                               Margin="0,0,0,3"/>
                    <TextBlock x:Name="UpdatedAtText" 
                               FontSize="11" 
                               Foreground="#666" 
                               Margin="0,0,0,3"/>
                    <TextBlock x:Name="ResolvedAtText" 
                               FontSize="11" 
                               Foreground="#666" 
                               Margin="0,0,0,15"/>

                    <!-- Zeiterfassung Summary -->
                    <Border Background="White" 
                            BorderBrush="#E0E0E0" 
                            BorderThickness="1" 
                            CornerRadius="5" 
                            Padding="15" 
                            Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="⏱️ Zeiterfassung" 
                                       FontWeight="Bold" 
                                       FontSize="14" 
                                       Margin="0,0,0,10"/>
                            <TextBlock x:Name="TotalTimeText" 
                                       Text="0 Stunden" 
                                       FontSize="20" 
                                       FontWeight="Bold" 
                                       Foreground="#2196F3"/>
                            <TextBlock Text="Gesamtzeit" 
                                       FontSize="11" 
                                       Foreground="#999"/>
                        </StackPanel>
                    </Border>

                    <!-- Aktionen -->
                    <Button Content="✏️ Ticket bearbeiten" 
                            Margin="0,20,0,10" 
                            Height="40" 
                            Click="EditTicket_Click"
                            Background="#2196F3"
                            Foreground="White"/>
                    <Button Content="📕 Als PDF exportieren" 
                            Margin="0,0,0,10" 
                            Height="40" 
                            Click="ExportPdf_Click"
                            Background="#E91E63"
                            Foreground="White"/>
                    <Button Content="👥 Kunden-Historie" 
                            Height="40" 
                            Click="ViewCustomerHistory_Click"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Rechte Seite: Tabs -->
        <TabControl Grid.Column="1" 
                    Margin="0">
            <!-- Tab: Kommentare -->
            <TabItem Header="💬 Kommentare">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Kommentarliste -->
                    <ScrollViewer Grid.Row="0" 
                                  VerticalScrollBarVisibility="Auto" 
                                  Margin="0,0,0,15">
                        <ItemsControl x:Name="CommentsListBox">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding IsInternal, Converter={StaticResource BoolToColorConverter}}" 
                                            BorderBrush="#E0E0E0" 
                                            BorderThickness="1" 
                                            CornerRadius="5" 
                                            Padding="15" 
                                            Margin="0,0,0,10">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" 
                                                           Text="{Binding EmployeeName}" 
                                                           FontWeight="Bold" 
                                                           FontSize="13"/>
                                                <TextBlock Grid.Column="1" 
                                                           Text="{Binding CommentTypeText}" 
                                                           FontSize="11" 
                                                           Foreground="White" 
                                                           Background="#666" 
                                                           Padding="5,2" 
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                            <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}}" 
                                                       FontSize="11" 
                                                       Foreground="#999" 
                                                       Margin="0,2,0,10"/>
                                            <TextBlock Text="{Binding Comment}" 
                                                       TextWrapping="Wrap" 
                                                       FontSize="12"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Neuer Kommentar -->
                    <Border Grid.Row="1" 
                            Background="#F9F9F9" 
                            BorderBrush="#E0E0E0" 
                            BorderThickness="1" 
                            CornerRadius="5" 
                            Padding="15">
                        <StackPanel>
                            <TextBlock Text="✍️ Neuer Kommentar" 
                                       FontWeight="Bold" 
                                       FontSize="14" 
                                       Margin="0,0,0,10"/>
                            <TextBox x:Name="NewCommentBox" 
                                     Height="80" 
                                     TextWrapping="Wrap" 
                                     AcceptsReturn="True" 
                                     VerticalScrollBarVisibility="Auto"
                                     Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox x:Name="IsInternalCheckBox" 
                                          Grid.Column="0" 
                                          Content="Interne Notiz" 
                                          IsChecked="True" 
                                          VerticalAlignment="Center"/>
                                <Button Grid.Column="2" 
                                        Content="💾 Kommentar speichern" 
                                        Width="180" 
                                        Height="35" 
                                        Click="SaveComment_Click"
                                        Background="#4CAF50"
                                        Foreground="White"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Tab: Zeiterfassung -->
            <TabItem Header="⏱️ Zeiterfassung">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Zeitliste -->
                    <DataGrid x:Name="TimeLogsDataGrid" 
                              Grid.Row="0" 
                              AutoGenerateColumns="False" 
                              IsReadOnly="True"
                              Margin="0,0,0,15">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Datum" 
                                                Binding="{Binding LoggedAt, StringFormat={}{0:dd.MM.yyyy}}" 
                                                Width="100"/>
                            <DataGridTextColumn Header="Uhrzeit" 
                                                Binding="{Binding LoggedAt, StringFormat={}{0:HH:mm}}" 
                                                Width="80"/>
                            <DataGridTextColumn Header="Mitarbeiter" 
                                                Binding="{Binding EmployeeName}" 
                                                Width="150"/>
                            <DataGridTextColumn Header="Beschreibung" 
                                                Binding="{Binding Description}" 
                                                Width="*"/>
                            <DataGridTextColumn Header="Zeit" 
                                                Binding="{Binding DurationText}" 
                                                Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Neue Zeit erfassen -->
                    <Border Grid.Row="1" 
                            Background="#F9F9F9" 
                            BorderBrush="#E0E0E0" 
                            BorderThickness="1" 
                            CornerRadius="5" 
                            Padding="15">
                        <StackPanel>
                            <TextBlock Text="➕ Zeit erfassen" 
                                       FontWeight="Bold" 
                                       FontSize="14" 
                                       Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBox x:Name="TimeDescriptionBox" 
                                         Grid.Column="0" 
                                         Height="35" 
                                         VerticalContentAlignment="Center"
                                         Margin="0,0,10,0">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="TextBox">
                                                        <Border Background="White" 
                                                                BorderBrush="#CCCCCC" 
                                                                BorderThickness="1">
                                                            <Grid>
                                                                <ScrollViewer x:Name="PART_ContentHost" 
                                                                              Margin="10,0,0,0" 
                                                                              VerticalAlignment="Center"/>
                                                                <TextBlock Text="Beschreibung..." 
                                                                           Foreground="#999" 
                                                                           Margin="10,0,0,0" 
                                                                           VerticalAlignment="Center"
                                                                           IsHitTestVisible="False">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Grid>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                                
                                <TextBox x:Name="HoursBox" 
                                         Grid.Column="1" 
                                         Height="35" 
                                         Text="0" 
                                         VerticalContentAlignment="Center"
                                         HorizontalContentAlignment="Center"
                                         Margin="0,0,5,0"/>
                                <TextBlock Grid.Column="1" 
                                           Text="h" 
                                           HorizontalAlignment="Right" 
                                           VerticalAlignment="Center" 
                                           Margin="0,0,10,0" 
                                           Foreground="#999" 
                                           IsHitTestVisible="False"/>
                                
                                <TextBox x:Name="MinutesBox" 
                                         Grid.Column="2" 
                                         Height="35" 
                                         Text="0" 
                                         VerticalContentAlignment="Center"
                                         HorizontalContentAlignment="Center"
                                         Margin="0,0,5,0"/>
                                <TextBlock Grid.Column="2" 
                                           Text="min" 
                                           HorizontalAlignment="Right" 
                                           VerticalAlignment="Center" 
                                           Margin="0,0,10,0" 
                                           Foreground="#999" 
                                           IsHitTestVisible="False"/>
                                
                                <Button Grid.Column="3" 
                                        Content="💾 Zeit speichern" 
                                        Width="150" 
                                        Height="35" 
                                        Click="SaveTime_Click"
                                        Background="#4CAF50"
                                        Foreground="White"
                                        Margin="10,0,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Tab: Historie -->
            <TabItem Header="📜 Änderungshistorie">
                <Grid Margin="20">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Änderungshistorie wird in zukünftiger Version implementiert." 
                                       FontSize="14" 
                                       Foreground="#999" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center" 
                                       Margin="0,50,0,0"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
