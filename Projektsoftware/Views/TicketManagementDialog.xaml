<Window x:Class="Projektsoftware.Views.TicketManagementDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ticket-Verwaltung" 
        Height="750" 
        Width="1400"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" 
                       Text="📋 Support-Tickets" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="#2196F3"/>

            <Button Grid.Column="1" 
                    Content="📊 Dashboard" 
                    Width="130" 
                    Height="35" 
                    Click="Dashboard_Click"
                    Background="#673AB7"
                    Foreground="White"/>
        </Grid>

        <!-- Search Bar -->
        <Border Grid.Row="1" 
                Background="#F5F5F5" 
                CornerRadius="5" 
                Padding="10" 
                Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="SearchBox" 
                         Grid.Column="0" 
                         Height="35" 
                         VerticalContentAlignment="Center"
                         FontSize="14"
                         TextChanged="SearchBox_TextChanged">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border Background="White" 
                                                BorderBrush="#CCCCCC" 
                                                BorderThickness="1" 
                                                CornerRadius="5">
                                            <Grid>
                                                <ScrollViewer x:Name="PART_ContentHost" 
                                                              Margin="10,0,0,0" 
                                                              VerticalAlignment="Center"/>
                                                <TextBlock Text="🔍 Suche nach Ticket#, Kunde, E-Mail, Betreff..." 
                                                           Foreground="#999" 
                                                           Margin="10,0,0,0" 
                                                           VerticalAlignment="Center"
                                                           IsHitTestVisible="False">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <Button Grid.Column="1" 
                        Content="❌" 
                        Width="35" 
                        Height="35" 
                        Margin="5,0,0,0" 
                        Click="ClearSearch_Click"
                        ToolTip="Suche löschen"/>

                <CheckBox x:Name="AutoRefreshCheckBox" 
                          Grid.Column="2" 
                          Content="Auto-Refresh (30s)" 
                          VerticalAlignment="Center" 
                          Margin="15,0,0,0"
                          Checked="AutoRefresh_Changed"
                          Unchecked="AutoRefresh_Changed"/>
            </Grid>
        </Border>

        <!-- Toolbar -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    Margin="0,0,0,15">
            <Button Content="➕ Neues Ticket" 
                    Width="150" 
                    Height="35" 
                    Margin="0,0,10,0" 
                    Click="NewTicket_Click"
                    Background="#4CAF50"
                    Foreground="White"/>
            <Button Content="✏️ Bearbeiten" 
                    Width="120" 
                    Height="35" 
                    Margin="0,0,10,0" 
                    Click="EditTicket_Click"
                    x:Name="EditButton"
                    IsEnabled="False"/>
            <Button Content="👁️ Details" 
                    Width="100" 
                    Height="35" 
                    Margin="0,0,10,0" 
                    Click="ViewDetails_Click"
                    x:Name="ViewDetailsButton"
                    IsEnabled="False"/>
            <Button Content="🗑️ Löschen" 
                    Width="100" 
                    Height="35" 
                    Margin="0,0,10,0" 
                    Click="DeleteTicket_Click"
                    x:Name="DeleteButton"
                    IsEnabled="False"
                    Background="#F44336"
                    Foreground="White"/>
            <Button Content="📧 E-Mail" 
                    Width="110" 
                    Height="35" 
                    Margin="0,0,10,0" 
                    Click="SendEmail_Click"
                    x:Name="SendEmailButton"
                    IsEnabled="False"
                    Background="#2196F3"
                    Foreground="White"/>
            <Button Content="⚙️ Ticket-SMTP" 
                    Width="130" 
                    Height="35" 
                    Margin="0,0,10,0" 
                    Click="ConfigureTicketSmtp_Click"
                    ToolTip="Ticket-SMTP Konfiguration öffnen"/>
            <Separator Width="20" Background="Transparent"/>

            <!-- Filter -->
            <TextBlock Text="Status:" 
                       VerticalAlignment="Center" 
                       Margin="0,0,5,0"/>
            <ComboBox x:Name="StatusFilterComboBox" 
                      Width="150" 
                      Height="35" 
                      SelectionChanged="FilterChanged"
                      SelectedIndex="0">
                <ComboBoxItem Content="Alle"/>
                <ComboBoxItem Content="Neu"/>
                <ComboBoxItem Content="In Bearbeitung"/>
                <ComboBoxItem Content="Gelöst"/>
                <ComboBoxItem Content="Geschlossen"/>
            </ComboBox>

            <TextBlock Text="Priorität:" 
                       VerticalAlignment="Center" 
                       Margin="10,0,5,0"/>
            <ComboBox x:Name="PriorityFilterComboBox" 
                      Width="130" 
                      Height="35" 
                      SelectionChanged="FilterChanged"
                      SelectedIndex="0">
                <ComboBoxItem Content="Alle"/>
                <ComboBoxItem Content="Niedrig"/>
                <ComboBoxItem Content="Mittel"/>
                <ComboBoxItem Content="Hoch"/>
                <ComboBoxItem Content="Dringend"/>
            </ComboBox>

            <TextBlock Text="Kategorie:" 
                       VerticalAlignment="Center" 
                       Margin="10,0,5,0"/>
            <ComboBox x:Name="CategoryFilterComboBox" 
                      Width="150" 
                      Height="35" 
                      SelectionChanged="FilterChanged"
                      SelectedIndex="0">
                <ComboBoxItem Content="Alle"/>
                <ComboBoxItem Content="Allgemein"/>
                <ComboBoxItem Content="Technisch"/>
                <ComboBoxItem Content="Abrechnung"/>
                <ComboBoxItem Content="Feature-Anfrage"/>
                <ComboBoxItem Content="Fehler"/>
            </ComboBox>

            <Separator Width="10" Background="Transparent"/>
            <Button Content="🔄" 
                    Width="40" 
                    Height="35" 
                    Margin="0,0,5,0" 
                    Click="Refresh_Click"
                    ToolTip="Aktualisieren"/>
            <Button Content="📄 CSV" 
                    Width="90" 
                    Height="35" 
                    Margin="0,0,5,0"
                    Click="Export_Click"
                    ToolTip="Nach CSV exportieren"/>
            <Button Content="📕 PDF" 
                    Width="90" 
                    Height="35" 
                    Click="ExportPdf_Click"
                    ToolTip="Als PDF exportieren"
                    Background="#E91E63"
                    Foreground="White"/>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid Grid.Row="3" 
                  x:Name="TicketsDataGrid" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionChanged="TicketsDataGrid_SelectionChanged"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  AlternatingRowBackground="#F5F5F5"
                  MouseDoubleClick="TicketsDataGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Ticket #" 
                                    Binding="{Binding TicketNumber}" 
                                    Width="100"/>
                <DataGridTextColumn Header="Erstellt" 
                                    Binding="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}}" 
                                    Width="130"/>
                <DataGridTextColumn Header="Kunde" 
                                    Binding="{Binding CustomerName}" 
                                    Width="150"/>
                <DataGridTextColumn Header="E-Mail" 
                                    Binding="{Binding CustomerEmail}" 
                                    Width="180"/>
                <DataGridTextColumn Header="Betreff" 
                                    Binding="{Binding Subject}" 
                                    Width="*"/>
                <DataGridTextColumn Header="Kategorie" 
                                    Binding="{Binding CategoryText}" 
                                    Width="120"/>
                <DataGridTextColumn Header="Priorität" 
                                    Binding="{Binding PriorityText}" 
                                    Width="100"/>
                <DataGridTextColumn Header="Status" 
                                    Binding="{Binding StatusText}" 
                                    Width="120"/>
                <DataGridTextColumn Header="Zugewiesen" 
                                    Binding="{Binding AssignedToEmployeeName}" 
                                    Width="150"/>
            </DataGrid.Columns>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <!-- Dringend - Rot -->
                        <DataTrigger Binding="{Binding Priority}" Value="3">
                            <Setter Property="Background" Value="#FFEBEE"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </DataTrigger>
                        <!-- Hoch - Orange -->
                        <DataTrigger Binding="{Binding Priority}" Value="2">
                            <Setter Property="Background" Value="#FFF3E0"/>
                        </DataTrigger>
                        <!-- Gelöst - Grün -->
                        <DataTrigger Binding="{Binding Status}" Value="3">
                            <Setter Property="Background" Value="#E8F5E9"/>
                        </DataTrigger>
                        <!-- Geschlossen - Grau -->
                        <DataTrigger Binding="{Binding Status}" Value="4">
                            <Setter Property="Background" Value="#EEEEEE"/>
                            <Setter Property="Foreground" Value="#999999"/>
                        </DataTrigger>
                    </Style.Triggers>
                    <EventSetter Event="MouseDoubleClick" Handler="TicketsDataGrid_MouseDoubleClick"/>
                </Style>
            </DataGrid.RowStyle>
        </DataGrid>

        <!-- Status Bar -->
        <StackPanel Grid.Row="4" 
                    Orientation="Horizontal" 
                    Margin="0,15,0,0">
            <TextBlock x:Name="StatusTextBlock" 
                       Text="Tickets werden geladen..." 
                       FontSize="12" 
                       Foreground="#666"
                       VerticalAlignment="Center"/>
            <Separator Width="20" Background="Transparent"/>
            <TextBlock x:Name="LastUpdateTextBlock" 
                       Text="" 
                       FontSize="11" 
                       Foreground="#999"
                       VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
