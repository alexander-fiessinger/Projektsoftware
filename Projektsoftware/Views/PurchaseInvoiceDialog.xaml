<Window x:Class="Projektsoftware.Views.PurchaseInvoiceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Eingangsrechnung" Width="520" Height="520"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="TitleText" Text="📥 Neue Eingangsrechnung"
                   FontSize="18" FontWeight="Bold" Foreground="#1A237E" Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Lieferant *" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ComboBox x:Name="SupplierCombo" Height="32" FontSize="13"
                          DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,10"/>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Rechnungsnummer *" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox x:Name="InvoiceNumberBox" Height="32" Padding="6,4" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Zugehörige Bestellung" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox x:Name="PurchaseOrderCombo" Height="32" FontSize="13"
                                  DisplayMemberPath="OrderNumber" SelectedValuePath="Id"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Rechnungsdatum *" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <DatePicker x:Name="InvoiceDatePicker" Height="32" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Fälligkeitsdatum" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <DatePicker x:Name="DueDatePicker" Height="32" FontSize="13"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Betrag Netto (€)" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox x:Name="TotalNetBox" Height="32" Padding="6,4" FontSize="13" Text="0,00"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Betrag Brutto (€)" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox x:Name="TotalGrossBox" Height="32" Padding="6,4" FontSize="13" Text="0,00"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Status" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox x:Name="StatusCombo" Height="32" FontSize="13">
                            <ComboBoxItem Content="Offen" IsSelected="True"/>
                            <ComboBoxItem Content="Bezahlt"/>
                            <ComboBoxItem Content="Storniert"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Bezahlt am" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <DatePicker x:Name="PaymentDatePicker" Height="32" FontSize="13"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Notizen" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox x:Name="NotesBox" Height="70" Padding="6,4" FontSize="13"
                         TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Abbrechen" Width="100" Height="36" Margin="0,0,8,0" IsCancel="True" Click="Cancel_Click"/>
            <Button Content="💾 Speichern" Width="120" Height="36"
                    Background="#1A237E" Foreground="White" BorderThickness="0"
                    IsDefault="True" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
