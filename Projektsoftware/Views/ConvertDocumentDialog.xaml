<Window x:Class="Projektsoftware.Views.ConvertDocumentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🔄 Dokument konvertieren"
        Height="380" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="🔄 Dokument konvertieren"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"/>
            <TextBlock Text="Daten in einen neuen Dokumenttyp übernehmen"
                       FontSize="13" Foreground="#666" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Source Document Info -->
        <Border Grid.Row="1"
                Background="#EEF2FF"
                BorderBrush="{StaticResource PrimaryBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="15,12"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Quell-Dokument:" FontWeight="SemiBold" Foreground="#555"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="SourceTypeTextBlock" Foreground="{StaticResource PrimaryBrush}" FontWeight="Bold"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Nummer:" FontWeight="SemiBold" Foreground="#555" Margin="0,5,0,0"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="SourceNumberTextBlock" Foreground="#333" Margin="0,5,0,0"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Kunde:" FontWeight="SemiBold" Foreground="#555" Margin="0,5,0,0"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="SourceCustomerTextBlock" Foreground="#333" Margin="0,5,0,0"/>
            </Grid>
        </Border>

        <!-- Target Type Selection -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="Konvertieren zu *" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <ComboBox x:Name="TargetTypeComboBox"
                      Height="35"
                      Margin="0,0,0,15"/>
            <CheckBox x:Name="IsDraftCheckBox"
                      Content="Als Entwurf erstellen (zum Überprüfen vor Freigabe)"
                      IsChecked="True"
                      FontSize="13"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Abbrechen"
                    Width="100" Height="36" Margin="0,0,10,0"
                    IsCancel="True"
                    Background="#F5F5F5" Foreground="#333"
                    BorderThickness="1" BorderBrush="#CCC"
                    Cursor="Hand"
                    Click="Cancel_Click"/>
            <Button x:Name="ConvertButton"
                    Content="🔄 Konvertieren"
                    Width="140" Height="36"
                    Background="{StaticResource PrimaryBrush}"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    Cursor="Hand"
                    Click="Convert_Click"/>
        </StackPanel>
    </Grid>
</Window>
