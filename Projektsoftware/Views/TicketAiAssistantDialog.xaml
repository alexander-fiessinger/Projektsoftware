<Window x:Class="Projektsoftware.Views.TicketAiAssistantDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🤖 KI-Assistent für Ticket" 
        Height="700" 
        Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="#0E639C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1177BB"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#3E3E3E"/>
                    <Setter Property="Foreground" Value="#888888"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#3E3E3E"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4E4E4E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3E3E3E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock x:Name="HeaderText" 
                       FontSize="18" 
                       FontWeight="Bold"/>
            <TextBlock x:Name="SubHeaderText" 
                       FontSize="12" 
                       Foreground="#AAAAAA" 
                       Margin="0,5,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- AI Functions -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,15">
            <Button Content="🏷️ Kategorisieren" 
                    x:Name="CategorizeButton" 
                    Click="CategorizeButton_Click"
                    ToolTip="Automatisch Kategorie und Priorität vorschlagen"/>
            <Button Content="💬 Antworten generieren" 
                    x:Name="GenerateResponseButton" 
                    Click="GenerateResponseButton_Click"
                    ToolTip="3 Antwortvorschläge erstellen"/>
            <Button Content="🔍 Ähnliche Tickets" 
                    x:Name="FindSimilarButton" 
                    Click="FindSimilarButton_Click"
                    ToolTip="Bereits gelöste ähnliche Tickets finden"/>
            <Button Content="📧 E-Mail-Vorschlag" 
                    x:Name="EmailSuggestionButton" 
                    Click="EmailSuggestionButton_Click"
                    ToolTip="Professionelle E-Mail-Antwort generieren"/>
            <Button Content="📝 Zusammenfassung" 
                    x:Name="SummarizeButton" 
                    Click="SummarizeButton_Click"
                    ToolTip="Ticket-Zusammenfassung erstellen"/>
        </WrapPanel>

        <!-- Result Area -->
        <Border Grid.Row="2" 
                Background="#2D2D2D" 
                BorderBrush="#3E3E3E" 
                BorderThickness="1"
                CornerRadius="4"
                Padding="15">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Loading Indicator -->
                    <StackPanel x:Name="LoadingPanel" 
                                Visibility="Collapsed" 
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock Text="⏳ KI arbeitet..." 
                                   FontSize="16" 
                                   Foreground="#4EC9B0"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Dies kann einige Sekunden dauern..." 
                                   FontSize="12" 
                                   Foreground="#888888"
                                   Margin="0,10,0,0"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Result Content -->
                    <StackPanel x:Name="ResultPanel">
                        <TextBlock x:Name="ResultTitleText" 
                                   FontSize="14" 
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"
                                   Foreground="#4EC9B0"/>

                        <TextBox x:Name="ResultTextBox" 
                                 TextWrapping="Wrap" 
                                 AcceptsReturn="True"
                                 MinHeight="300"
                                 VerticalScrollBarVisibility="Auto"
                                 IsReadOnly="False"
                                 FontFamily="Consolas"
                                 FontSize="12"/>

                        <!-- Action Buttons for Result -->
                        <WrapPanel Margin="0,10,0,0">
                            <Button Content="📋 Kopieren" 
                                    x:Name="CopyButton" 
                                    Click="CopyButton_Click"
                                    Style="{StaticResource SecondaryButton}"/>
                            <Button Content="✅ Übernehmen" 
                                    x:Name="ApplyButton" 
                                    Click="ApplyButton_Click"
                                    Visibility="Collapsed"/>
                            <Button Content="🔄 Neu generieren" 
                                    x:Name="RegenerateButton" 
                                    Click="RegenerateButton_Click"
                                    Style="{StaticResource SecondaryButton}"
                                    Visibility="Collapsed"/>
                        </WrapPanel>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Bottom Buttons -->
        <StackPanel Grid.Row="3" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,15,0,0">
            <Button Content="⚙️ Einstellungen" 
                    x:Name="SettingsButton" 
                    Click="SettingsButton_Click"
                    Style="{StaticResource SecondaryButton}"/>
            <Button Content="Schließen" 
                    Click="CloseButton_Click"
                    Style="{StaticResource SecondaryButton}"/>
        </StackPanel>
    </Grid>
</Window>
