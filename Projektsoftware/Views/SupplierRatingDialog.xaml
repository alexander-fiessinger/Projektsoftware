<Window x:Class="Projektsoftware.Views.SupplierRatingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lieferanten-Bewertung" Height="560" Width="900"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Lieferanten-Bewertungen" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

        <DataGrid Grid.Row="1" x:Name="RatingsGrid" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Datum" Binding="{Binding RatingDate, StringFormat={}{0:dd.MM.yyyy}}" Width="100"/>
                <DataGridTextColumn Header="Lieferant-ID" Binding="{Binding SupplierId}" Width="100"/>
                <DataGridTextColumn Header="Bewertung" Binding="{Binding StarsDisplay}" Width="120"/>
                <DataGridTextColumn Header="Qualität" Binding="{Binding QualityRating}" Width="80"/>
                <DataGridTextColumn Header="Lieferung" Binding="{Binding DeliveryRating}" Width="80"/>
                <DataGridTextColumn Header="Preis" Binding="{Binding PriceRating}" Width="80"/>
                <DataGridTextColumn Header="Service" Binding="{Binding ServiceRating}" Width="80"/>
                <DataGridTextColumn Header="Notizen" Binding="{Binding ReviewText}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Aktualisieren" Width="120" Click="Refresh_Click"/>
            <Button Content="Schließen" Width="100" Margin="8,0,0,0" Click="Close_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
