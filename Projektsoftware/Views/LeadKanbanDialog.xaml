<Window x:Class="Projektsoftware.Views.LeadKanbanDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lead-Pipeline (Kanban)" Height="640" Width="1100"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Lead-Pipeline" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Content="Aktualisieren" Margin="20,0,0,0" Padding="10,4" Click="Refresh_Click"/>
        </StackPanel>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="#888" BorderThickness="1" Margin="4" Background="#F0F8FF">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Neu" FontWeight="Bold" FontSize="14" Padding="8" Background="#4A90E2" Foreground="White"/>
                    <ListBox x:Name="ListNeu" BorderThickness="0" Background="Transparent" AllowDrop="True"
                             Drop="Column_Drop" Tag="Neu" SelectionMode="Single" ItemTemplate="{DynamicResource LeadTemplate}"
                             PreviewMouseLeftButtonDown="Item_PreviewMouseLeftButtonDown"
                             MouseMove="Item_MouseMove"/>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" BorderBrush="#888" BorderThickness="1" Margin="4" Background="#FFF8DC">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="In Bearbeitung" FontWeight="Bold" FontSize="14" Padding="8" Background="#E6A23C" Foreground="White"/>
                    <ListBox x:Name="ListBearbeitung" BorderThickness="0" Background="Transparent" AllowDrop="True"
                             Drop="Column_Drop" Tag="InBearbeitung" ItemTemplate="{DynamicResource LeadTemplate}"
                             PreviewMouseLeftButtonDown="Item_PreviewMouseLeftButtonDown"
                             MouseMove="Item_MouseMove"/>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" BorderBrush="#888" BorderThickness="1" Margin="4" Background="#E8F5E9">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Qualifiziert" FontWeight="Bold" FontSize="14" Padding="8" Background="#67C23A" Foreground="White"/>
                    <ListBox x:Name="ListQualifiziert" BorderThickness="0" Background="Transparent" AllowDrop="True"
                             Drop="Column_Drop" Tag="Qualifiziert" ItemTemplate="{DynamicResource LeadTemplate}"
                             PreviewMouseLeftButtonDown="Item_PreviewMouseLeftButtonDown"
                             MouseMove="Item_MouseMove"/>
                </DockPanel>
            </Border>

            <Border Grid.Column="3" BorderBrush="#888" BorderThickness="1" Margin="4" Background="#FFEBEE">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Abgelehnt" FontWeight="Bold" FontSize="14" Padding="8" Background="#F56C6C" Foreground="White"/>
                    <ListBox x:Name="ListAbgelehnt" BorderThickness="0" Background="Transparent" AllowDrop="True"
                             Drop="Column_Drop" Tag="Abgelehnt" ItemTemplate="{DynamicResource LeadTemplate}"
                             PreviewMouseLeftButtonDown="Item_PreviewMouseLeftButtonDown"
                             MouseMove="Item_MouseMove"/>
                </DockPanel>
            </Border>
        </Grid>

        <DockPanel.Resources>
            <DataTemplate x:Key="LeadTemplate">
                <Border Margin="4" Padding="8" Background="White" BorderBrush="#CCC" BorderThickness="1" CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="{Binding Title}" FontWeight="Bold" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding ContactCompany}" Foreground="#555" FontSize="11"/>
                        <TextBlock Text="{Binding ContactName}" Foreground="#777" FontSize="11"/>
                        <TextBlock Text="{Binding LeadDate, StringFormat={}{0:dd.MM.yyyy}}" Foreground="#999" FontSize="10"/>
                    </StackPanel>
                </Border>
            </DataTemplate>
        </DockPanel.Resources>
    </DockPanel>
</Window>
