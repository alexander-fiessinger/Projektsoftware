<Window x:Class="Projektsoftware.Views.EasybillTimeExportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Projektsoftware.Converters"
        Title="Zeiten zu Easybill exportieren" Height="600" Width="900"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize">
    
    <Window.Resources>
        <converters:EuroCurrencyConverter x:Key="EuroCurrencyConverter"/>
        <converters:HourlyRateCalculatorConverter x:Key="HourlyRateCalculatorConverter"/>
        <converters:TimeSpanToHoursConverter x:Key="TimeSpanToHoursConverter"/>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Zeiten zu Easybill exportieren" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Kunde:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
            <ComboBox x:Name="CustomerComboBox" 
                      Grid.Column="1" 
                      Height="30"
                      DisplayMemberPath="DisplayName"
                      SelectionChanged="CustomerComboBox_SelectionChanged"/>

            <TextBlock Grid.Column="3" Text="Easybill-Projekt:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
            <ComboBox x:Name="ProjectComboBox" 
                      Grid.Column="4" 
                      Height="30"
                      DisplayMemberPath="Name"/>

            <TextBlock Grid.Column="6" Text="Stundensatz (€):" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
            <TextBox x:Name="HourlyRateTextBox" 
                     Grid.Column="7" 
                     Height="30" 
                     Text="100,00"
                     VerticalContentAlignment="Center"/>

            <Button Grid.Column="9" 
                    Content="🔄 Laden" 
                    Height="30" 
                    Padding="10,0"
                    Click="LoadTimeEntries_Click"
                    Background="#2196F3" 
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"/>
        </Grid>

        <DataGrid x:Name="TimeEntriesDataGrid" 
                  Grid.Row="2"
                  AutoGenerateColumns="False" 
                  CanUserAddRows="False"
                  SelectionMode="Extended"
                  IsReadOnly="True"
                  Margin="0,0,0,15">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="✓" Binding="{Binding IsSelected}" Width="40"/>
                <DataGridTextColumn Header="Datum" Binding="{Binding Date, StringFormat=dd.MM.yyyy}" Width="100"/>
                <DataGridTextColumn Header="Mitarbeiter" Binding="{Binding EmployeeName}" Width="150"/>
                <DataGridTextColumn Header="Projekt" Binding="{Binding ProjectName}" Width="150"/>
                <DataGridTextColumn Header="Tätigkeit" Binding="{Binding Activity}" Width="*"/>
                <DataGridTextColumn Header="Stunden" Binding="{Binding Duration, Converter={StaticResource TimeSpanToHoursConverter}}" Width="80"/>
                <DataGridTextColumn Header="Betrag" Width="100">
                    <DataGridTextColumn.Binding>
                        <MultiBinding Converter="{StaticResource HourlyRateCalculatorConverter}">
                            <Binding Path="Duration"/>
                            <Binding Path="HourlyRate"/>
                        </MultiBinding>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,15">
            <TextBlock Text="Gesamt: " FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBlock x:Name="TotalHoursText" Text="0,0 Stunden" VerticalAlignment="Center" Margin="0,0,20,0"/>
            <TextBlock Text="Betrag: " FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBlock x:Name="TotalAmountText" Text="0,00 €" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="📤 Nach Easybill exportieren" 
                    Width="200" 
                    Height="35" 
                    Margin="0,0,10,0"
                    Click="Export_Click"
                    Background="#4CAF50" 
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Cursor="Hand"/>
            <Button Content="Schließen" 
                    Width="100" 
                    Height="35"
                    Click="Close_Click"
                    Background="#9E9E9E" 
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
