<Window x:Class="Projektsoftware.Views.EasybillProjectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Easybill-Projekt anlegen" Height="550" Width="600"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button Content="In Easybill anlegen" Width="150" Height="35" Margin="0,0,10,0" Click="CreateInEasybill_Click" 
                    Background="#4CAF50" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
            <Button Content="Abbrechen" Width="100" Height="35" Click="Cancel_Click"
                    Background="#9E9E9E" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                <TextBlock Text="📋 Neues Easybill-Projekt erstellen" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

                <TextBlock Text="Lokales Projekt" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox x:Name="LocalProjectComboBox" 
                          Height="30" 
                          Margin="0,0,0,15" 
                          DisplayMemberPath="Name"
                          SelectionChanged="LocalProject_SelectionChanged"/>
                <TextBlock Text="Wählen Sie ein lokales Projekt aus, das mit Easybill synchronisiert werden soll." 
                           FontSize="11" Foreground="Gray" Margin="0,-10,0,15"/>

                <Border Background="#E3F2FD" CornerRadius="5" Padding="15" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="ℹ Info" FontWeight="Bold" Foreground="#1976D2" Margin="0,0,0,5"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#1976D2">
                            Das Projekt wird in Easybill angelegt und automatisch mit dem lokalen Projekt verknüpft.
                            Zeiteinträge können dann direkt diesem Projekt zugeordnet werden.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <TextBlock Text="Easybill-Kunde *" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox x:Name="CustomerComboBox" 
                          Height="30" 
                          Margin="0,0,0,15" 
                          DisplayMemberPath="DisplayName"
                          SelectionChanged="Customer_SelectionChanged"/>

                <TextBlock Text="Projektname *" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="ProjectNameTextBox" Height="30" Margin="0,0,0,15"/>

                <TextBlock Text="Beschreibung" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="DescriptionTextBox" Height="80" Margin="0,0,0,15" TextWrapping="Wrap" AcceptsReturn="True"/>

                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Stundensatz (€)" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="HourlyRateTextBox" Height="30" Text="100,00"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Budget-Typ" FontWeight="Bold" Margin="0,0,0,5"/>
                        <ComboBox x:Name="BudgetTypeComboBox" Height="30" SelectedIndex="0">
                            <ComboBoxItem Content="Stunden"/>
                            <ComboBoxItem Content="Geld"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Budget-Betrag" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="BudgetAmountTextBox" Height="30" Margin="0,0,0,15" Text="0"/>

                <TextBlock Text="Fälligkeitsdatum" FontWeight="Bold" Margin="0,0,0,5"/>
                <DatePicker x:Name="DueDatePicker" Height="30" Margin="0,0,0,15"/>

                <TextBlock Text="Status" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox x:Name="StatusComboBox" Height="30" Margin="0,0,0,15" SelectedIndex="0">
                    <ComboBoxItem Content="Offen"/>
                    <ComboBoxItem Content="Abgeschlossen"/>
                    <ComboBoxItem Content="Abgebrochen"/>
                </ComboBox>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
