<Window x:Class="Projektsoftware.Views.LeadStatisticsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lead-Statistik" Height="560" Width="780"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Lead-Statistik (letzte 90 Tage)" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>

        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,12">
            <Border BorderBrush="#DDD" BorderThickness="1" Margin="4" Padding="10" CornerRadius="6">
                <StackPanel>
                    <TextBlock Text="Gesamt" FontSize="11" Foreground="#666"/>
                    <TextBlock x:Name="TotalText" Text="–" FontSize="22" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border BorderBrush="#67C23A" BorderThickness="1" Margin="4" Padding="10" CornerRadius="6">
                <StackPanel>
                    <TextBlock Text="Gewonnen" FontSize="11" Foreground="#666"/>
                    <TextBlock x:Name="WonText" Text="–" FontSize="22" FontWeight="Bold" Foreground="#67C23A"/>
                </StackPanel>
            </Border>
            <Border BorderBrush="#F56C6C" BorderThickness="1" Margin="4" Padding="10" CornerRadius="6">
                <StackPanel>
                    <TextBlock Text="Verloren" FontSize="11" Foreground="#666"/>
                    <TextBlock x:Name="LostText" Text="–" FontSize="22" FontWeight="Bold" Foreground="#F56C6C"/>
                </StackPanel>
            </Border>
            <Border BorderBrush="#4A90E2" BorderThickness="1" Margin="4" Padding="10" CornerRadius="6">
                <StackPanel>
                    <TextBlock Text="Conversion" FontSize="11" Foreground="#666"/>
                    <TextBlock x:Name="ConversionText" Text="–" FontSize="22" FontWeight="Bold" Foreground="#4A90E2"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <GroupBox Grid.Row="2" Header="Quellen-Auswertung">
            <DataGrid x:Name="SourcesGrid" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Quelle" Binding="{Binding Source}" Width="*"/>
                    <DataGridTextColumn Header="Leads" Binding="{Binding Total}" Width="100"/>
                    <DataGridTextColumn Header="Gewonnen" Binding="{Binding Won}" Width="100"/>
                    <DataGridTextColumn Header="Conversion" Binding="{Binding ConversionPercent, StringFormat={}{0:N1} %}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Aktualisieren" Width="120" Click="Refresh_Click"/>
            <Button Content="Schließen" Width="100" Margin="8,0,0,0" Click="Close_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
