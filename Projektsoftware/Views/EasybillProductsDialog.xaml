<Window x:Class="Projektsoftware.Views.EasybillProductsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📦 Easybill Produkte und Artikel" 
        Height="650" 
        Width="1100"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="📦 Easybill Produkte und Artikel" 
                       FontSize="24" 
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"/>
            <TextBlock Text="Verwalten Sie Ihre Produkte und Dienstleistungen"
                       FontSize="14"
                       Foreground="#666"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Actions -->
        <StackPanel Grid.Row="1" 
                    Orientation="Horizontal" 
                    Margin="0,0,0,15"
                    HorizontalAlignment="Right">
            <Button Content="🔄 Aktualisieren"
                    Width="130"
                    Height="35"
                    Margin="0,0,10,0"
                    Click="Refresh_Click"
                    Background="{StaticResource PrimaryBrush}"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    FontWeight="SemiBold"/>
            <Button Content="➕ Neues Produkt"
                    Width="140"
                    Height="35"
                    Click="AddProduct_Click"
                    Background="#4CAF50"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    FontWeight="SemiBold"/>
        </StackPanel>

        <!-- Products DataGrid -->
        <Border Grid.Row="2" 
                BorderBrush="#DDD" 
                BorderThickness="1" 
                CornerRadius="5"
                Background="White">
            <DataGrid x:Name="ProductsDataGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      AlternatingRowBackground="#F9F9F9"
                      RowHeight="40"
                      FontSize="13">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Typ" Binding="{Binding DisplayType}" Width="120"/>
                    <DataGridTextColumn Header="Nummer" Binding="{Binding Number}" Width="120"/>
                    <DataGridTextColumn Header="Beschreibung" Binding="{Binding Description}" Width="*" MinWidth="200"/>
                    <DataGridTextColumn Header="Verkaufspreis" Binding="{Binding SalePrice, StringFormat='{}{0:N2} €'}" Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextAlignment" Value="Right"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Einheit" Binding="{Binding Unit}" Width="80"/>
                    <DataGridTextColumn Header="MwSt." Binding="{Binding VatPercent, StringFormat='{}{0}%'}" Width="60"/>
                    
                    <DataGridTemplateColumn Header="Aktionen" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="✏️ Bearbeiten" 
                                            Width="80" 
                                            Height="28"
                                            Margin="2"
                                            Click="EditProduct_Click"
                                            Background="#2196F3"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            FontSize="11"/>
                                    <Button Content="❌ Löschen" 
                                            Width="70" 
                                            Height="28"
                                            Margin="2"
                                            Click="DeleteProduct_Click"
                                            Background="#F44336"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            FontSize="11"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="3" 
                Background="#F5F5F5" 
                BorderBrush="#DDD" 
                BorderThickness="1" 
                CornerRadius="5"
                Padding="10"
                Margin="0,15,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="StatusTextBlock" 
                           Text="Bereit" 
                           FontSize="12"
                           Foreground="#666"/>
                <TextBlock x:Name="ProductCountTextBlock"
                           Text=""
                           FontSize="12"
                           Foreground="#666"
                           Margin="20,0,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
