<Window x:Class="Projektsoftware.Views.ChangePasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🔑 Passwort ändern" 
        Height="450" 
        Width="450"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="🔑 Passwort ändern" 
                       FontSize="20" 
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"/>
            <TextBlock x:Name="UsernameTextBlock"
                       Text="Benutzer: ..."
                       FontSize="14"
                       Foreground="#666"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Neues Passwort -->
        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="Neues Passwort *" FontWeight="Bold" Margin="0,0,0,5"/>
            <PasswordBox x:Name="NewPasswordBox" 
                         Height="35"
                         PasswordChar="●"/>
        </StackPanel>

        <!-- Passwort bestätigen -->
        <StackPanel Grid.Row="2" Margin="0,0,0,15">
            <TextBlock Text="Passwort bestätigen *" FontWeight="Bold" Margin="0,0,0,5"/>
            <PasswordBox x:Name="ConfirmPasswordBox" 
                         Height="35"
                         PasswordChar="●"/>
        </StackPanel>

        <!-- Hinweis -->
        <Border Grid.Row="3" 
                Background="#E3F2FD"
                BorderBrush="#2196F3"
                BorderThickness="1"
                CornerRadius="5"
                Padding="10"
                Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="ℹ️" FontSize="16" Margin="0,0,10,0"/>
                <TextBlock Text="Das Passwort muss mindestens 4 Zeichen lang sein."
                           TextWrapping="Wrap"
                           Foreground="#1976D2"/>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="5" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="Abbrechen" 
                    Width="100" 
                    Height="35"
                    Margin="0,0,10,0"
                    Click="Cancel_Click"
                    Background="#9E9E9E" 
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"/>
            <Button Content="✓ Ändern" 
                    Width="100" 
                    Height="35"
                    Click="Save_Click"
                    Background="{StaticResource PrimaryBrush}"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</Window>

