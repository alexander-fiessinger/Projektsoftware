<Window x:Class="Projektsoftware.Views.EasybillConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Easybill API-Konfiguration" Height="450" Width="600"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <DockPanel>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button Content="Verbindung testen" Width="130" Height="35" Margin="0,0,10,0" Click="TestConnection_Click" 
                    Background="#FF9800" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
            <Button Content="Speichern" Width="100" Height="35" Margin="0,0,10,0" Click="Save_Click" 
                    Background="#4CAF50" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
            <Button Content="Abbrechen" Width="100" Height="35" Click="Cancel_Click"
                    Background="#9E9E9E" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                <TextBlock Text="🔌 Easybill API-Einstellungen" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

                <Border Background="#E3F2FD" Padding="15" Margin="0,0,0,20" CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="ℹ️ Wo finde ich meinen API-Schlüssel?" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,5">
                            1. Melden Sie sich bei Easybill an (https://www.easybill.de)
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,5">
                            2. Gehen Sie zu: Einstellungen → API-Schlüssel
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,5">
                            3. Erstellen Sie einen neuen API-Schlüssel
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,0">
                            4. Kopieren Sie den Schlüssel und fügen Sie ihn unten ein
                        </TextBlock>
                    </StackPanel>
                </Border>

                <TextBlock Text="API-Schlüssel *" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="ApiKeyTextBox" Height="30" Margin="0,0,0,10"/>
                
                <TextBlock Text="API-URL" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="ApiUrlTextBox" Height="30" Margin="0,0,0,10" 
                         Text="https://api.easybill.de/rest/v1"/>

                <TextBlock x:Name="StatusTextBlock" 
                           Text="" 
                           Margin="0,10,0,0" 
                           FontWeight="Bold"
                           TextWrapping="Wrap"/>

                <Border x:Name="TestResultPanel" 
                        Visibility="Collapsed"
                        Background="#C8E6C9" 
                        Padding="15" 
                        Margin="0,10,0,0" 
                        CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="✅ Verbindung erfolgreich!" FontWeight="Bold" Foreground="#2E7D32" Margin="0,0,0,5"/>
                        <TextBlock x:Name="CustomerCountText" Text="" Foreground="#2E7D32"/>
                    </StackPanel>
                </Border>

                <Border x:Name="ErrorPanel" 
                        Visibility="Collapsed"
                        Background="#FFCDD2" 
                        Padding="15" 
                        Margin="0,10,0,0" 
                        CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="❌ Verbindungsfehler" FontWeight="Bold" Foreground="#C62828" Margin="0,0,0,5"/>
                        <TextBlock x:Name="ErrorMessageText" TextWrapping="Wrap" Foreground="#C62828"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
