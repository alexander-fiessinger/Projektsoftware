<Window x:Class="Projektsoftware.Views.UserEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Benutzer bearbeiten" 
        Height="700" 
        Width="500"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Benutzername -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Benutzername *" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="UsernameTextBox"/>
        </StackPanel>

        <!-- Mitarbeiter -->
        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="Mitarbeiter (optional)" FontWeight="Bold" Margin="0,0,0,5"/>
            <ComboBox x:Name="EmployeeComboBox" 
                      DisplayMemberPath="FullName"
                      SelectedValuePath="Id">
                <ComboBox.ItemContainerStyle>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Padding" Value="5"/>
                    </Style>
                </ComboBox.ItemContainerStyle>
            </ComboBox>
        </StackPanel>

        <!-- Passwort (nur bei Neuanlage) -->
        <StackPanel x:Name="PasswordPanel" Grid.Row="2" Margin="0,0,0,15" Visibility="Collapsed">
            <TextBlock Text="Passwort *" FontWeight="Bold" Margin="0,0,0,5"/>
            <PasswordBox x:Name="PasswordBox" PasswordChar="●"/>
        </StackPanel>

        <!-- Passwort bestätigen (nur bei Neuanlage) -->
        <StackPanel x:Name="ConfirmPasswordPanel" Grid.Row="3" Margin="0,0,0,15" Visibility="Collapsed">
            <TextBlock Text="Passwort bestätigen *" FontWeight="Bold" Margin="0,0,0,5"/>
            <PasswordBox x:Name="ConfirmPasswordBox" PasswordChar="●"/>
        </StackPanel>

        <!-- E-Mail für Einladung (nur bei Neuanlage) -->
        <StackPanel x:Name="EmailPanel" Grid.Row="2" Margin="0,0,0,15">
            <TextBlock Text="E-Mail-Adresse *" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="EmailTextBox"/>
            <TextBlock Text="Das vorübergehende Passwort wird an diese Adresse gesendet."
                       FontSize="11" Foreground="#888" Margin="0,3,0,0"/>
        </StackPanel>

        <!-- Rolle -->
        <StackPanel Grid.Row="4" Margin="0,0,0,15">
            <TextBlock Text="Rolle *" FontWeight="Bold" Margin="0,0,0,5"/>
            <ComboBox x:Name="RoleComboBox" SelectionChanged="RoleComboBox_SelectionChanged">
                <ComboBoxItem Content="User" IsSelected="True"/>
                <ComboBoxItem Content="Admin"/>
            </ComboBox>
        </StackPanel>

        <!-- Status -->
        <StackPanel Grid.Row="5" Margin="0,0,0,15">
            <CheckBox x:Name="IsActiveCheckBox" 
                      Content="Benutzer ist aktiv"
                      IsChecked="True"
                      FontWeight="SemiBold"/>
        </StackPanel>

        <!-- Berechtigungen -->
        <GroupBox x:Name="PermissionsGroupBox" Grid.Row="6" Header="Modul-Berechtigungen" 
                  FontWeight="Bold" Margin="0,0,0,10">
            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="200">
                <StackPanel x:Name="PermissionsPanel" Margin="5">
                    <!-- Checkboxen werden im Code-Behind dynamisch erzeugt -->
                </StackPanel>
            </ScrollViewer>
        </GroupBox>

        <!-- Buttons -->
        <StackPanel Grid.Row="7" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="Abbrechen" 
                    Width="100" 
                    Height="35"
                    Margin="0,0,10,0"
                    Click="Cancel_Click"
                    Background="#9E9E9E" 
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"/>
            <Button Content="Speichern" 
                    Width="100" 
                    Height="35"
                    Click="Save_Click"
                    Background="#4CAF50" 
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
