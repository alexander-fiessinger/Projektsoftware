<Window x:Class="Projektsoftware.Views.TimeEntryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zeiterfassung" Height="550" Width="500"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Projekt *" Grid.Row="0" Margin="0,0,0,5" FontWeight="Bold"/>
        <ComboBox x:Name="ProjectComboBox" 
                  Grid.Row="0" 
                  Margin="0,25,0,10"
                  DisplayMemberPath="Name"
                  IsEditable="False"/>

        <TextBlock Text="Mitarbeitername *" Grid.Row="1" Margin="0,0,0,5" FontWeight="Bold"/>
        <ComboBox x:Name="EmployeeComboBox" 
                  Grid.Row="1" 
                  Margin="0,25,0,10" 
                  DisplayMemberPath="FullName" 
                  IsEditable="True"/>

        <TextBlock Text="Kunde" Grid.Row="2" Margin="0,0,0,5" FontWeight="Bold"/>
        <Grid Grid.Row="2" Margin="0,25,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ComboBox x:Name="CustomerComboBox" 
                      Grid.Column="0"
                      IsEditable="True"
                      DisplayMemberPath="DisplayName"/>

            <Button Content="📋" 
                    Grid.Column="2"
                    Width="35"
                    Height="30"
                    Click="OpenEasybillCustomers_Click"
                    Background="#2196F3" 
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    ToolTip="Easybill-Kunden verwalten"/>
        </Grid>

        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Datum *" Margin="0,0,0,5" FontWeight="Bold"/>
                <DatePicker x:Name="DatePicker"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Dauer (Stunden) *" Margin="0,0,0,5" FontWeight="Bold"/>
                <TextBox x:Name="DurationTextBox" Text="8"/>
            </StackPanel>
        </Grid>

        <TextBlock Text="Tätigkeit" Grid.Row="4" Margin="0,0,0,5" FontWeight="Bold"/>
        <TextBox x:Name="ActivityTextBox" Grid.Row="4" Margin="0,25,0,10"/>

        <TextBlock Text="Beschreibung" Grid.Row="5" Margin="0,0,0,5" FontWeight="Bold"/>
        <TextBox x:Name="DescriptionTextBox" 
                 Grid.Row="5" 
                 Margin="0,25,0,10" 
                 Height="80" 
                 TextWrapping="Wrap" 
                 AcceptsReturn="True"/>

        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Speichern" 
                    Width="100" 
                    Height="35" 
                    Margin="0,0,10,0"
                    Click="Save_Click"
                    Background="#4CAF50" 
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"/>
            <Button Content="Abbrechen" 
                    Width="100" 
                    Height="35"
                    Click="Cancel_Click"
                    Background="#9E9E9E" 
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
