<Window x:Class="Projektsoftware.Views.InvoiceOverviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🧾 Rechnungsübersicht"
        Height="720"
        Width="1080"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="🧾 Rechnungsübersicht"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"/>
            <TextBlock Text="Offene, überfällige und bezahlte Rechnungen aus Easybill mit Detailangaben."
                       FontSize="14"
                       Foreground="#666"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- KPI-Zeile -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="#16A34A" CornerRadius="6" Padding="14,10">
                <StackPanel>
                    <TextBlock Text="Bezahlt" Foreground="White" FontSize="12" Opacity="0.9"/>
                    <TextBlock x:Name="KpiPaidText" Text="–" Foreground="White" FontSize="18" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Background="#D97706" CornerRadius="6" Padding="14,10">
                <StackPanel>
                    <TextBlock Text="Offen" Foreground="White" FontSize="12" Opacity="0.9"/>
                    <TextBlock x:Name="KpiOpenText" Text="–" Foreground="White" FontSize="18" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="4" Background="#DC2626" CornerRadius="6" Padding="14,10">
                <StackPanel>
                    <TextBlock Text="Überfällig" Foreground="White" FontSize="12" Opacity="0.9"/>
                    <TextBlock x:Name="KpiOverdueText" Text="–" Foreground="White" FontSize="18" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="6" Background="#64748B" CornerRadius="6" Padding="14,10">
                <StackPanel>
                    <TextBlock Text="Entwürfe" Foreground="White" FontSize="12" Opacity="0.9"/>
                    <TextBlock x:Name="KpiDraftText" Text="–" Foreground="White" FontSize="18" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Filterleiste -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Filter:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#444"/>
            <ComboBox x:Name="FilterComboBox" Width="200" Height="30" SelectionChanged="FilterComboBox_SelectionChanged">
                <ComboBoxItem Content="Alle Rechnungen" IsSelected="True"/>
                <ComboBoxItem Content="Nur offene"/>
                <ComboBoxItem Content="Nur überfällige"/>
                <ComboBoxItem Content="Nur bezahlte"/>
                <ComboBoxItem Content="Nur Entwürfe"/>
            </ComboBox>
            <TextBlock x:Name="ResultCountText" Text="" VerticalAlignment="Center" Margin="15,0,0,0" Foreground="#666"/>
            <TextBlock Text="💡 Doppelklick auf eine Zeile öffnet die Rechnung"
                       VerticalAlignment="Center" Margin="15,0,0,0" Foreground="#999" FontStyle="Italic"/>
        </StackPanel>

        <!-- Detail-Tabelle -->
        <DataGrid Grid.Row="3"
                  x:Name="InvoicesDataGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  RowHeight="34"
                  Background="White"
                  BorderBrush="#DDD"
                  BorderThickness="1"
                  SelectionMode="Single"
                  MouseDoubleClick="InvoicesDataGrid_MouseDoubleClick">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="ToolTip" Value="Doppelklick öffnet die Rechnung als PDF"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Rechnung" Binding="{Binding NumberDisplay}" Width="120"/>
                <DataGridTextColumn Header="Kunde" Binding="{Binding CustomerDisplay}" Width="*"/>
                <DataGridTextColumn Header="Datum" Binding="{Binding DocumentDateDisplay}" Width="100"/>
                <DataGridTextColumn Header="Fällig" Binding="{Binding DueDateDisplay}" Width="100"/>
                <DataGridTextColumn Header="Betrag" Binding="{Binding GrossAmountDisplay}" Width="110">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Offen" Binding="{Binding OpenAmountDisplay}" Width="110">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Bezahlt am" Binding="{Binding PaidAtDisplay}" Width="100"/>
                <DataGridTextColumn Header="Status" Binding="{Binding StatusDisplay}" Width="150"/>
                <DataGridTemplateColumn Header="" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Öffnen"
                                    Padding="8,2"
                                    Margin="2"
                                    Cursor="Hand"
                                    Click="OpenInvoice_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <TextBlock x:Name="EmptyHintText"
                       Text="Keine Rechnungen für den gewählten Filter."
                       Foreground="#999"
                       VerticalAlignment="Center"
                       Margin="0,0,20,0"
                       Visibility="Collapsed"/>
            <Button Content="Schließen" Width="120" Height="34" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
