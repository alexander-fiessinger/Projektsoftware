<Window x:Class="Projektsoftware.Views.CrmDealDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Deal / Chance"
        Width="520" Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="TitleText" Text="Deal anlegen"
                   FontSize="18" FontWeight="SemiBold"
                   Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Titel *" Margin="0,0,0,4" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox x:Name="TitleBox" Height="34" Margin="0,0,0,12"/>

                <TextBlock Text="Kunde (optional)" Margin="0,0,0,4" Foreground="{StaticResource TextSecondaryBrush}"/>
                <ComboBox x:Name="CustomerCombo" Height="34" Margin="0,0,0,12"
                          DisplayMemberPath="DisplayName" SelectedValuePath="Id"/>

                <TextBlock Text="Ansprechpartner (optional)" Margin="0,0,0,4" Foreground="{StaticResource TextSecondaryBrush}"/>
                <ComboBox x:Name="ContactCombo" Height="34" Margin="0,0,0,12"
                          DisplayMemberPath="DisplayName" SelectedValuePath="Id"/>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Wert (€)" Margin="0,0,0,4" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBox x:Name="ValueBox" Height="34" Text="0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Wahrscheinlichkeit (%)" Margin="0,0,0,4" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBox x:Name="ProbabilityBox" Height="34" Text="50"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Phase *" Margin="0,0,0,4" Foreground="{StaticResource TextSecondaryBrush}"/>
                <ComboBox x:Name="StageCombo" Height="34" Margin="0,0,0,12">
                    <ComboBoxItem Content="🔵 Lead" Tag="0" IsSelected="True"/>
                    <ComboBoxItem Content="🟡 Qualifiziert" Tag="1"/>
                    <ComboBoxItem Content="🟠 Angebot" Tag="2"/>
                    <ComboBoxItem Content="🔴 Verhandlung" Tag="3"/>
                    <ComboBoxItem Content="✅ Gewonnen" Tag="4"/>
                    <ComboBoxItem Content="❌ Verloren" Tag="5"/>
                </ComboBox>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Erwarteter Abschluss" Margin="0,0,0,4" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <DatePicker x:Name="CloseDatePicker" Height="34"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Zugewiesen an" Margin="0,0,0,4" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBox x:Name="AssignedToBox" Height="34"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Grund bei Verlust" Margin="0,0,0,4" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox x:Name="LostReasonBox" Height="34" Margin="0,0,0,12"/>

                <TextBlock Text="Notizen" Margin="0,0,0,4" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox x:Name="NotesBox" Height="80" TextWrapping="Wrap"
                         AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,4"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Abbrechen" Width="100" Height="34" Margin="0,0,10,0"
                    Click="Cancel_Click"/>
            <Button Content="Speichern" Width="100" Height="34"
                    Style="{StaticResource ModernButton}"
                    Background="{StaticResource SuccessBrush}" Foreground="White"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
