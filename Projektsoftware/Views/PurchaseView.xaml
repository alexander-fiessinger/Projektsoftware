<UserControl x:Class="Projektsoftware.Views.PurchaseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI, Segoe UI Emoji"
             Loaded="UserControl_Loaded">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header KPIs -->
        <UniformGrid Grid.Row="0" Columns="4" Margin="0,0,0,14">
            <Border Background="#1A237E" CornerRadius="8" Margin="0,0,6,0" Padding="14,10">
                <StackPanel>
                    <TextBlock Text="🏭 Lieferanten" Foreground="White" FontSize="11" FontWeight="SemiBold" Opacity="0.85"/>
                    <TextBlock x:Name="TotalSuppliersText" Text="–" Foreground="White" FontSize="26" FontWeight="Bold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="#283593" CornerRadius="8" Margin="0,0,6,0" Padding="14,10">
                <StackPanel>
                    <TextBlock Text="🛒 Offene Bestellungen" Foreground="White" FontSize="11" FontWeight="SemiBold" Opacity="0.85" TextWrapping="Wrap"/>
                    <TextBlock x:Name="OpenOrdersText" Text="–" Foreground="White" FontSize="26" FontWeight="Bold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="#1B5E20" CornerRadius="8" Margin="0,0,6,0" Padding="14,10">
                <StackPanel>
                    <TextBlock Text="📁 Belege gesamt" Foreground="White" FontSize="11" FontWeight="SemiBold" Opacity="0.85" TextWrapping="Wrap"/>
                    <TextBlock x:Name="TotalDocumentsText" Text="–" Foreground="White" FontSize="26" FontWeight="Bold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="#00695C" CornerRadius="8" Padding="14,10">
                <StackPanel>
                    <TextBlock Text="☁ In Easybill" Foreground="White" FontSize="11" FontWeight="SemiBold" Opacity="0.85" TextWrapping="Wrap"/>
                    <TextBlock x:Name="SyncedDocumentsText" Text="–" Foreground="White" FontSize="26" FontWeight="Bold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="{StaticResource NeutralLightBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="5" Padding="10,6" Margin="0,0,0,10">
            <DockPanel>
                <TextBox x:Name="SearchBox" DockPanel.Dock="Left" Width="260" Height="32"
                         VerticalContentAlignment="Center" FontSize="13"
                         TextChanged="SearchBox_TextChanged">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border Background="White" BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1" CornerRadius="4">
                                            <Grid>
                                                <ScrollViewer x:Name="PART_ContentHost" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="🔍  Suche…" Foreground="{StaticResource TextSecondaryBrush}"
                                                           Margin="10,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Style>
                </TextBox>
                <WrapPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <Button Content="🔄 Aktualisieren" Style="{StaticResource ActionButton}"
                            Height="32" Padding="10,4" Margin="0,0,6,0" Click="Refresh_Click"/>
                    <Button Content="+ Lieferant" Style="{StaticResource ActionButton}"
                            Height="32" Padding="10,4" Margin="0,0,6,0"
                            Background="#1A237E" Foreground="White" Click="NewSupplier_Click"/>
                    <Button Content="+ Bestellung" Style="{StaticResource ActionButton}"
                            Height="32" Padding="10,4" Margin="0,0,6,0"
                            Background="#283593" Foreground="White" Click="NewOrder_Click"/>
                    <Button Content="+ Dokument" Style="{StaticResource ActionButton}"
                            Height="32" Padding="10,4"
                            Background="#1B5E20" Foreground="White" Click="NewDocument_Click"/>
                </WrapPanel>
            </DockPanel>
        </Border>

        <!-- Tabs -->
        <TabControl Grid.Row="2" x:Name="MainTabControl">

            <!-- Lieferanten Tab -->
            <TabItem Header="🏭 Lieferanten">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="SuppliersGrid" Grid.Row="0" AutoGenerateColumns="False"
                              CanUserAddRows="False" IsReadOnly="True" SelectionMode="Single"
                              RowBackground="White" AlternatingRowBackground="#F5F5F5"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              MouseDoubleClick="SupplierGrid_DoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="200"/>
                            <DataGridTextColumn Header="Ansprechpartner" Binding="{Binding ContactPerson}" Width="160"/>
                            <DataGridTextColumn Header="E-Mail" Binding="{Binding Email}" Width="200"/>
                            <DataGridTextColumn Header="Telefon" Binding="{Binding Phone}" Width="130"/>
                            <DataGridTextColumn Header="Stadt" Binding="{Binding City}" Width="120"/>
                            <DataGridTextColumn Header="IBAN" Binding="{Binding BankIban}" Width="200"/>
                            <DataGridTextColumn Header="Easybill" Binding="{Binding EasybillSyncStatus}" Width="120"/>
                            <DataGridTemplateColumn Header="Aktionen" Width="200">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="✏️" Width="50" Height="26" Margin="2"
                                                    Style="{StaticResource ActionButton}" Click="EditSupplier_Click"
                                                    ToolTip="Bearbeiten"/>
                                            <Button Content="🗑" Width="50" Height="26" Margin="2"
                                                    Style="{StaticResource ActionButton}" Foreground="#D32F2F"
                                                    Click="DeleteSupplier_Click" ToolTip="Löschen"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock Grid.Row="1" x:Name="SupplierCountText" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="4,4,0,0"/>
                </Grid>
            </TabItem>

            <!-- Bestellungen Tab -->
            <TabItem Header="🛒 Bestellungen">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- Status Filter -->
                    <WrapPanel Grid.Row="0" Margin="0,6,0,8">
                        <TextBlock Text="Status:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
                        <RadioButton x:Name="AllOrdersFilter" Content="Alle" IsChecked="True"
                                     Margin="0,0,10,0" VerticalAlignment="Center" Checked="OrderFilter_Changed"/>
                        <RadioButton Content="🟡 Offen" Margin="0,0,10,0" VerticalAlignment="Center"
                                     Tag="Offen" Checked="OrderFilter_Changed"/>
                        <RadioButton Content="🔵 Bestellt" Margin="0,0,10,0" VerticalAlignment="Center"
                                     Tag="Bestellt" Checked="OrderFilter_Changed"/>
                        <RadioButton Content="🟠 Teilw. geliefert" Margin="0,0,10,0" VerticalAlignment="Center"
                                     Tag="Teilweise geliefert" Checked="OrderFilter_Changed"/>
                        <RadioButton Content="🟢 Geliefert" Margin="0,0,10,0" VerticalAlignment="Center"
                                     Tag="Geliefert" Checked="OrderFilter_Changed"/>
                    </WrapPanel>
                    <DataGrid x:Name="OrdersGrid" Grid.Row="1" AutoGenerateColumns="False"
                              CanUserAddRows="False" IsReadOnly="True" SelectionMode="Single"
                              RowBackground="White" AlternatingRowBackground="#F5F5F5"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              MouseDoubleClick="OrderGrid_DoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nr." Binding="{Binding OrderNumber}" Width="100"/>
                            <DataGridTextColumn Header="Lieferant" Binding="{Binding SupplierName}" Width="180"/>
                            <DataGridTextColumn Header="Bestelldatum" Binding="{Binding OrderDate, StringFormat='dd.MM.yyyy'}" Width="120"/>
                            <DataGridTextColumn Header="Lieferdatum (erw.)" Binding="{Binding DeliveryDateExpected, StringFormat='dd.MM.yyyy'}" Width="140"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding StatusDisplay}" Width="160"/>
                            <DataGridTextColumn Header="Netto" Binding="{Binding TotalNetDisplay}" Width="110"/>
                            <DataGridTextColumn Header="Brutto" Binding="{Binding TotalGrossDisplay}" Width="110"/>
                            <DataGridTemplateColumn Header="Aktionen" Width="160">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="✏️" Width="50" Height="26" Margin="2"
                                                    Style="{StaticResource ActionButton}" Click="EditOrder_Click"
                                                    ToolTip="Bearbeiten"/>
                                            <Button Content="🗑" Width="50" Height="26" Margin="2"
                                                    Style="{StaticResource ActionButton}" Foreground="#D32F2F"
                                                    Click="DeleteOrder_Click" ToolTip="Löschen"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock Grid.Row="2" x:Name="OrderCountText" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="4,4,0,0"/>
                </Grid>
            </TabItem>

            <!-- Belegablage Tab -->
            <TabItem Header="📁 Belegablage">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- Typ-Filter -->
                    <WrapPanel Grid.Row="0" Margin="0,6,0,8">
                        <TextBlock Text="Typ:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
                        <RadioButton x:Name="AllDocFilter" Content="Alle" IsChecked="True"
                                     Margin="0,0,10,0" VerticalAlignment="Center" Checked="DocumentFilter_Changed"/>
                        <RadioButton Content="📄 Rechnung" Margin="0,0,10,0" VerticalAlignment="Center"
                                     Tag="Rechnung" Checked="DocumentFilter_Changed"/>
                        <RadioButton Content="📦 Lieferschein" Margin="0,0,10,0" VerticalAlignment="Center"
                                     Tag="Lieferschein" Checked="DocumentFilter_Changed"/>
                        <RadioButton Content="📋 Angebot" Margin="0,0,10,0" VerticalAlignment="Center"
                                     Tag="Angebot" Checked="DocumentFilter_Changed"/>
                        <RadioButton Content="💳 Gutschrift" Margin="0,0,10,0" VerticalAlignment="Center"
                                     Tag="Gutschrift" Checked="DocumentFilter_Changed"/>
                    </WrapPanel>
                    <DataGrid x:Name="DocumentsGrid" Grid.Row="1" AutoGenerateColumns="False"
                              CanUserAddRows="False" IsReadOnly="True" SelectionMode="Single"
                              RowBackground="White" AlternatingRowBackground="#F5F5F5"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              MouseDoubleClick="DocumentGrid_DoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Bezeichnung" Binding="{Binding DocumentName}" Width="200"/>
                            <DataGridTextColumn Header="Typ" Binding="{Binding TypeDisplay}" Width="120"/>
                            <DataGridTextColumn Header="Lieferant" Binding="{Binding SupplierName}" Width="180"/>
                            <DataGridTextColumn Header="Datum" Binding="{Binding DocumentDate, StringFormat='dd.MM.yyyy'}" Width="110"/>
                            <DataGridTextColumn Header="Datei" Binding="{Binding FileStatus}" Width="120"/>
                            <DataGridTextColumn Header="Easybill" Binding="{Binding EasybillSyncStatus}" Width="130"/>
                            <DataGridTemplateColumn Header="Aktionen" Width="200">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="✏️" Width="50" Height="26" Margin="2"
                                                    Style="{StaticResource ActionButton}" Click="EditDocument_Click"
                                                    ToolTip="Bearbeiten"/>
                                            <Button Content="📂" Width="40" Height="26" Margin="2"
                                                    Style="{StaticResource ActionButton}"
                                                    Background="#1565C0" Foreground="White"
                                                    Click="OpenDocumentFile_Click" ToolTip="Datei öffnen"/>
                                            <Button Content="☁" Width="40" Height="26" Margin="2"
                                                    Style="{StaticResource ActionButton}"
                                                    Background="#00695C" Foreground="White"
                                                    Click="SyncDocument_Click" ToolTip="Mit Easybill synchronisieren"/>
                                            <Button Content="🗑" Width="40" Height="26" Margin="2"
                                                    Style="{StaticResource ActionButton}" Foreground="#D32F2F"
                                                    Click="DeleteDocument_Click" ToolTip="Löschen"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock Grid.Row="2" x:Name="DocumentCountText" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="4,4,0,0"/>
                    <Border Grid.Row="2" Background="#E8F5E9" BorderBrush="#A5D6A7" BorderThickness="1"
                            CornerRadius="4" Padding="8,4" Margin="0,24,0,0">
                        <TextBlock FontSize="11" Foreground="#2E7D32" TextWrapping="Wrap"
                                   Text="ℹ️  Hochgeladene Belege werden lokal gespeichert und automatisch mit Easybill synchronisiert (Belege → Uploads). Dokumente können dem entsprechenden Lieferantenkonto zugeordnet werden."/>
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>
