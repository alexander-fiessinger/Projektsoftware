<Window x:Class="Projektsoftware.Views.InvoiceSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rechnung auswählen" Height="500" Width="650"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" x:Name="TitleTextBlock"
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

        <!-- Description -->
        <TextBlock Grid.Row="1" x:Name="DescriptionTextBlock"
                   TextWrapping="Wrap" Foreground="#666" Margin="0,0,0,8"/>

        <!-- Invoice List -->
        <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5">
            <DockPanel>
                <TextBox x:Name="SearchBox"
                         DockPanel.Dock="Top"
                         Height="32" Padding="8,4"
                         FontSize="12"
                         BorderBrush="#E0E0E0" BorderThickness="0,0,0,1"
                         Background="{StaticResource SurfaceBrush}"
                         TextChanged="SearchBox_TextChanged"
                         VerticalContentAlignment="Center">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush Stretch="None" AlignmentX="Left">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="🔍  Suchen nach Nummer oder Kunde…"
                                                               Foreground="#AAAAAA" FontSize="12" Margin="8,0,0,0"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
                <ListBox x:Name="InvoicesListBox"
                     SelectionMode="Single"
                     MouseDoubleClick="InvoicesListBox_MouseDoubleClick">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="5">
                            <TextBlock Text="{Binding Number}" FontWeight="Bold" FontSize="14"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="Kunde: " FontSize="11" Foreground="#666"/>
                                    <TextBlock Text="{Binding CustomerName}" FontSize="11" Foreground="#666" Margin="3,0,12,0"/>
                                    <TextBlock Text="Datum: " FontSize="11" Foreground="#666"/>
                                    <TextBlock Text="{Binding DocumentDate}" FontSize="11" Foreground="#666" Margin="3,0,12,0"/>
                                    <TextBlock Text="Status: " FontSize="11" Foreground="#666"/>
                                    <TextBlock Text="{Binding DisplayStatus}" FontSize="11" Foreground="#666" Margin="3,0,12,0"/>
                                    <TextBlock Text="Betrag: " FontSize="11" Foreground="#666"/>
                                    <TextBlock Text="{Binding AmountDisplay}" FontSize="11" Foreground="#333" FontWeight="SemiBold" Margin="3,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            </DockPanel>
        </Border>

        <!-- Optional input section (reason / level) -->
        <StackPanel Grid.Row="3" x:Name="InputPanel" Visibility="Collapsed" Margin="0,15,0,0">
            <TextBlock x:Name="InputLabelBlock" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <TextBox x:Name="InputTextBox"
                     Height="32" Padding="8,4"
                     FontSize="13"
                     BorderBrush="#D0D0D0" BorderThickness="1"
                     Background="{StaticResource SurfaceBrush}"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Abbrechen" Width="110" Height="35"
                    Margin="0,0,10,0" Click="Cancel_Click"
                    Style="{StaticResource ModernButton}"/>
            <Button Content="Auswählen" Width="110" Height="35"
                    Click="Select_Click"
                    Background="#4CAF50" Foreground="White"
                    Style="{StaticResource ModernButton}"/>
        </StackPanel>
    </Grid>
</Window>
