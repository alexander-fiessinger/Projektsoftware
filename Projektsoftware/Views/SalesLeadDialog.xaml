<Window x:Class="Projektsoftware.Views.SalesLeadDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lead" Width="520" Height="580"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F8FAFC">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Titel -->
        <TextBlock x:Name="TitleText" Text="📋 Neuer Lead" FontSize="18" FontWeight="Bold"
                   Foreground="#1E293B" Margin="0,0,0,20"/>

        <!-- Felder -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <TextBlock Text="Bezeichnung *" FontSize="12" Foreground="#64748B" Margin="0,0,0,4"/>
                <TextBox x:Name="TitleBox" Height="34" Padding="8,6" BorderBrush="#CBD5E1"
                         BorderThickness="1" Margin="0,0,0,12"/>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Kontaktperson" FontSize="12" Foreground="#64748B" Margin="0,0,0,4"/>
                        <TextBox x:Name="ContactNameBox" Height="34" Padding="8,6" BorderBrush="#CBD5E1" BorderThickness="1"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Unternehmen" FontSize="12" Foreground="#64748B" Margin="0,0,0,4"/>
                        <TextBox x:Name="ContactCompanyBox" Height="34" Padding="8,6" BorderBrush="#CBD5E1" BorderThickness="1"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="E-Mail" FontSize="12" Foreground="#64748B" Margin="0,0,0,4"/>
                        <TextBox x:Name="ContactEmailBox" Height="34" Padding="8,6" BorderBrush="#CBD5E1" BorderThickness="1"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Telefon" FontSize="12" Foreground="#64748B" Margin="0,0,0,4"/>
                        <TextBox x:Name="ContactPhoneBox" Height="34" Padding="8,6" BorderBrush="#CBD5E1" BorderThickness="1"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Datum" FontSize="12" Foreground="#64748B" Margin="0,0,0,4"/>
                        <DatePicker x:Name="LeadDatePicker" Height="34" BorderBrush="#CBD5E1" BorderThickness="1"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Status" FontSize="12" Foreground="#64748B" Margin="0,0,0,4"/>
                        <ComboBox x:Name="StatusCombo" Height="34" BorderBrush="#CBD5E1" BorderThickness="1">
                            <ComboBoxItem Content="🆕 Neu" Tag="0" IsSelected="True"/>
                            <ComboBoxItem Content="🔄 In Bearbeitung" Tag="1"/>
                            <ComboBoxItem Content="✅ Qualifiziert" Tag="2"/>
                            <ComboBoxItem Content="❌ Abgelehnt" Tag="3"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Quelle (z.B. Messe, Website, Empfehlung)" FontSize="12" Foreground="#64748B" Margin="0,0,0,4"/>
                <TextBox x:Name="SourceBox" Height="34" Padding="8,6" BorderBrush="#CBD5E1"
                         BorderThickness="1" Margin="0,0,0,12"/>

                <TextBlock Text="Notizen" FontSize="12" Foreground="#64748B" Margin="0,0,0,4"/>
                <TextBox x:Name="NotesBox" Height="70" Padding="8,6" BorderBrush="#CBD5E1"
                         BorderThickness="1" TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto" Margin="0,0,0,12"/>

                <!-- Datei-Upload -->
                <TextBlock Text="Leadbogen (PDF, Bild)" FontSize="12" Foreground="#64748B" Margin="0,0,0,4"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="4"
                            Background="White" Padding="8,6">
                        <TextBlock x:Name="SelectedFileText" Text="Keine Datei ausgewählt"
                                   Foreground="#94A3B8" FontStyle="Italic" VerticalAlignment="Center"/>
                    </Border>
                    <Button Grid.Column="2" Content="📂 Datei wählen" Height="34" Padding="12,0"
                            Background="#2563EB" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Click="SelectFile_Click"/>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Abbrechen" Width="100" Height="36" Margin="0,0,8,0"
                    Background="#F1F5F9" BorderBrush="#CBD5E1" BorderThickness="1"
                    Cursor="Hand" Click="Cancel_Click"/>
            <Button Content="Speichern" Width="100" Height="36"
                    Background="#2563EB" Foreground="White" BorderThickness="0"
                    Cursor="Hand" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
