<UserControl x:Class="Projektsoftware.Views.DashboardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="📊 Dashboard" FontSize="24" FontWeight="Bold" Foreground="#1976D2" Margin="0,0,0,20"/>

            <!-- Statistics Cards -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <!-- Projekte Card -->
                <Border Grid.Column="0" Background="#E3F2FD" CornerRadius="10" Padding="15">
                    <StackPanel>
                        <TextBlock Text="📁 Projekte" FontSize="14" FontWeight="Bold" Foreground="#1976D2"/>
                        <TextBlock x:Name="TotalProjectsText" FontSize="32" FontWeight="Bold" Foreground="#1976D2" Margin="0,10,0,0"/>
                        <TextBlock x:Name="ActiveProjectsText" FontSize="12" Foreground="#666" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Aufgaben Card -->
                <Border Grid.Column="2" Background="#FFF3E0" CornerRadius="10" Padding="15">
                    <StackPanel>
                        <TextBlock Text="✓ Aufgaben" FontSize="14" FontWeight="Bold" Foreground="#F57C00"/>
                        <TextBlock x:Name="TotalTasksText" FontSize="32" FontWeight="Bold" Foreground="#F57C00" Margin="0,10,0,0"/>
                        <TextBlock x:Name="OpenTasksText" FontSize="12" Foreground="#666" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Stunden Card -->
                <Border Grid.Column="4" Background="#E8F5E9" CornerRadius="10" Padding="15">
                    <StackPanel>
                        <TextBlock Text="⏱ Stunden" FontSize="14" FontWeight="Bold" Foreground="#4CAF50"/>
                        <TextBlock x:Name="TotalHoursText" FontSize="32" FontWeight="Bold" Foreground="#4CAF50" Margin="0,10,0,0"/>
                        <TextBlock Text="erfasst" FontSize="12" Foreground="#666" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Budget Card -->
                <Border Grid.Column="6" Background="#F3E5F5" CornerRadius="10" Padding="15">
                    <StackPanel>
                        <TextBlock Text="💰 Budget" FontSize="14" FontWeight="Bold" Foreground="#7B1FA2"/>
                        <TextBlock x:Name="TotalBudgetText" FontSize="32" FontWeight="Bold" Foreground="#7B1FA2" Margin="0,10,0,0"/>
                        <TextBlock Text="gesamt" FontSize="12" Foreground="#666" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Details Section -->
            <Grid Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <!-- Tasks Details -->
                <Border Grid.Column="0" Background="#FFEBEE" CornerRadius="10" Padding="15">
                    <StackPanel>
                        <TextBlock Text="⚠ Offene Aufgaben" FontSize="14" FontWeight="Bold" Foreground="#D32F2F" Margin="0,0,0,10"/>
                        <TextBlock x:Name="OverdueTasksText" FontSize="12" Foreground="#666"/>
                        <TextBlock x:Name="OpenTasksDetailText" FontSize="12" Foreground="#666" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Meetings & Employees -->
                <Border Grid.Column="2" Background="#E1F5FE" CornerRadius="10" Padding="15">
                    <StackPanel>
                        <TextBlock Text="📅 Kommende Events" FontSize="14" FontWeight="Bold" Foreground="#0277BD" Margin="0,0,0,10"/>
                        <TextBlock x:Name="UpcomingMeetingsText" FontSize="12" Foreground="#666"/>
                        <TextBlock x:Name="ActiveEmployeesText" FontSize="12" Foreground="#666" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Quick Actions -->
            <TextBlock Text="🚀 Schnellaktionen" FontSize="16" FontWeight="Bold" Margin="0,30,0,15"/>
            <WrapPanel>
                <Button Content="+ Neues Projekt" Width="150" Height="40" Margin="0,0,10,10" 
                        Background="#4CAF50" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="NewProject_Click"/>
                <Button Content="+ Neue Aufgabe" Width="150" Height="40" Margin="0,0,10,10"
                        Background="#FF9800" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="NewTask_Click"/>
                <Button Content="+ Neuer Kunde" Width="150" Height="40" Margin="0,0,10,10"
                        Background="#00BCD4" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="NewCustomer_Click"/>
                <Button Content="⏱ Zeiterfassung" Width="150" Height="40" Margin="0,0,10,10"
                        Background="#2196F3" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="TimeTracking_Click"/>
            </WrapPanel>

            <!-- Document Creation Section -->
            <TextBlock Text="📄 Dokumente erstellen" FontSize="16" FontWeight="Bold" Margin="0,30,0,15"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Angebot erstellen Card -->
                <Border Grid.Column="0" Background="#FFF8E1" CornerRadius="10" Padding="20" BorderBrush="#FFB300" BorderThickness="2">
                    <StackPanel>
                        <TextBlock Text="📋 Angebot erstellen" FontSize="18" FontWeight="Bold" Foreground="#FF6F00" Margin="0,0,0,10"/>
                        <TextBlock Text="Erstellen Sie schnell und einfach ein professionelles Angebot für Ihre Projekte und Kunden." 
                                   TextWrapping="Wrap" FontSize="12" Foreground="#666" Margin="0,0,0,15"/>
                        <Button Content="Angebot jetzt erstellen" Height="40" 
                                Background="#FF9800" Foreground="White" FontWeight="Bold" 
                                BorderThickness="0" Click="CreateOffer_Click"
                                HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>

                <!-- Rechnung erstellen Card -->
                <Border Grid.Column="2" Background="#E8F5E9" CornerRadius="10" Padding="20" BorderBrush="#4CAF50" BorderThickness="2">
                    <StackPanel>
                        <TextBlock Text="📄 Rechnung erstellen" FontSize="18" FontWeight="Bold" Foreground="#2E7D32" Margin="0,0,0,10"/>
                        <TextBlock Text="Erstellen Sie Rechnungen direkt aus Ihren erfassten Zeiten und Projektdaten mit Easybill." 
                                   TextWrapping="Wrap" FontSize="12" Foreground="#666" Margin="0,0,0,15"/>
                        <Button Content="Rechnung jetzt erstellen" Height="40" 
                                Background="#4CAF50" Foreground="White" FontWeight="Bold" 
                                BorderThickness="0" Click="CreateInvoice_Click"
                                HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Additional Document Types -->
            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Auftragsbestätigung Card -->
                <Border Grid.Column="0" Background="#F3E5F5" CornerRadius="10" Padding="15" BorderBrush="#9C27B0" BorderThickness="2">
                    <StackPanel>
                        <TextBlock Text="✅ Auftrag" FontSize="14" FontWeight="Bold" Foreground="#7B1FA2" Margin="0,0,0,8"/>
                        <TextBlock Text="Auftragsbestätigung erstellen" TextWrapping="Wrap" FontSize="11" Foreground="#666" Margin="0,0,0,10"/>
                        <Button Content="Auftrag erstellen" Height="35" 
                                Background="#9C27B0" Foreground="White" FontWeight="Bold" 
                                BorderThickness="0" Click="CreateOrderConfirmation_Click"
                                HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>

                <!-- Lieferschein Card -->
                <Border Grid.Column="2" Background="#E3F2FD" CornerRadius="10" Padding="15" BorderBrush="#2196F3" BorderThickness="2">
                    <StackPanel>
                        <TextBlock Text="📦 Lieferschein" FontSize="14" FontWeight="Bold" Foreground="#1976D2" Margin="0,0,0,8"/>
                        <TextBlock Text="Versandbestätigung für Ihre Kunden" TextWrapping="Wrap" FontSize="11" Foreground="#666" Margin="0,0,0,10"/>
                        <Button Content="Lieferschein erstellen" Height="35" 
                                Background="#2196F3" Foreground="White" FontWeight="Bold" 
                                BorderThickness="0" Click="CreateDeliveryNote_Click"
                                HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>

                <!-- Gutschrift Card -->
                <Border Grid.Column="4" Background="#FCE4EC" CornerRadius="10" Padding="15" BorderBrush="#E91E63" BorderThickness="2">
                    <StackPanel>
                        <TextBlock Text="💳 Gutschrift" FontSize="14" FontWeight="Bold" Foreground="#C2185B" Margin="0,0,0,8"/>
                        <TextBlock Text="Rechnungskorrektur oder Storno" TextWrapping="Wrap" FontSize="11" Foreground="#666" Margin="0,0,0,10"/>
                        <Button Content="Gutschrift erstellen" Height="35" 
                                Background="#E91E63" Foreground="White" FontWeight="Bold" 
                                BorderThickness="0" Click="CreateCreditNote_Click"
                                HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>

                <!-- Mahnung Card -->
                <Border Grid.Column="6" Background="#FFEBEE" CornerRadius="10" Padding="15" BorderBrush="#F44336" BorderThickness="2">
                    <StackPanel>
                        <TextBlock Text="⚠️ Mahnung" FontSize="14" FontWeight="Bold" Foreground="#D32F2F" Margin="0,0,0,8"/>
                        <TextBlock Text="Zahlungserinnerung versenden" TextWrapping="Wrap" FontSize="11" Foreground="#666" Margin="0,0,0,10"/>
                        <Button Content="Mahnung erstellen" Height="35" 
                                Background="#F44336" Foreground="White" FontWeight="Bold" 
                                BorderThickness="0" Click="CreateDunning_Click"
                                HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Easybill Shortcuts -->
            <TextBlock Text="💳 Easybill-Verwaltung" FontSize="16" FontWeight="Bold" Margin="0,30,0,15"/>
            <WrapPanel>
                <Button Content="📄 Dokumente anzeigen" Width="180" Height="40" Margin="0,0,10,10"
                        Background="#2196F3" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="ShowDocuments_Click"/>
                <Button Content="👤 Kunden verwalten" Width="180" Height="40" Margin="0,0,10,10"
                        Background="#00BCD4" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="ManageCustomers_Click"/>
                <Button Content="📦 Produkte anzeigen" Width="180" Height="40" Margin="0,0,10,10"
                        Background="#009688" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="ShowProducts_Click"/>
                <Button Content="📤 Zeiten exportieren" Width="180" Height="40" Margin="0,0,10,10"
                        Background="#FF5722" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="ExportTimes_Click"/>
            </WrapPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
