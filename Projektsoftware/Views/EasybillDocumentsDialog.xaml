<Window x:Class="Projektsoftware.Views.EasybillDocumentsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📄 Easybill Dokumentenverwaltung" 
        Height="700" 
        Width="1200"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="📄 Easybill Dokumente" 
                       FontSize="24" 
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"/>
            <TextBlock Text="Verwalten Sie Ihre Rechnungen, Angebote, Lieferscheine und weitere Dokumente"
                       FontSize="14"
                       Foreground="#666"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Filter & Actions -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Dokumenttyp Filter -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,15,0">
                <TextBlock Text="Typ:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
                <ComboBox x:Name="TypeFilterComboBox" 
                          Width="200"
                          Height="35"
                          SelectionChanged="TypeFilterComboBox_SelectionChanged">
                    <ComboBoxItem Content="Alle Dokumente" IsSelected="True" Tag=""/>
                    <ComboBoxItem Content="📄 Rechnungen" Tag="INVOICE"/>
                    <ComboBoxItem Content="🧾 Proforma-Rechnungen" Tag="PROFORMA_INVOICE"/>
                    <ComboBoxItem Content="📋 Angebote" Tag="OFFER"/>
                    <ComboBoxItem Content="✓ Auftragsbestätigungen" Tag="ORDER_CONFIRMATION"/>
                    <ComboBoxItem Content="📦 Lieferscheine" Tag="DELIVERY_NOTE"/>
                    <ComboBoxItem Content="💳 Gutschriften" Tag="CREDIT"/>
                    <ComboBoxItem Content="⚠️ Mahnungen" Tag="DUNNING"/>
                </ComboBox>
            </StackPanel>

            <!-- Refresh Button -->
            <Button Grid.Column="2"
                    Content="🔄 Aktualisieren"
                    Width="130"
                    Height="35"
                    Margin="0,0,10,0"
                    Click="Refresh_Click"
                    Background="{StaticResource PrimaryBrush}"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    FontWeight="SemiBold"/>

            <!-- Create Document Button with Dropdown -->
            <Button Grid.Column="3"
                    Content="➕ Dokument erstellen ▼"
                    Width="180"
                    Height="35"
                    Click="CreateDocument_Click"
                    Background="#4CAF50"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    FontWeight="SemiBold">
                <Button.ContextMenu>
                    <ContextMenu x:Name="CreateDocumentMenu">
                        <MenuItem Header="📄 Rechnung" Tag="INVOICE" Click="CreateDocumentType_Click"/>
                        <MenuItem Header="📋 Angebot" Tag="OFFER" Click="CreateDocumentType_Click"/>
                        <MenuItem Header="✓ Auftragsbestätigung" Tag="ORDER_CONFIRMATION" Click="CreateDocumentType_Click"/>
                        <MenuItem Header="📦 Lieferschein" Tag="DELIVERY_NOTE" Click="CreateDocumentType_Click"/>
                        <MenuItem Header="💳 Gutschrift" Tag="CREDIT" Click="CreateDocumentType_Click"/>
                        <MenuItem Header="⚠️ Mahnung" Tag="DUNNING" Click="CreateDocumentType_Click"/>
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>
        </Grid>

        <!-- Documents DataGrid -->
        <Border Grid.Row="2" 
                BorderBrush="#DDD" 
                BorderThickness="1" 
                CornerRadius="5"
                Background="White">
            <DataGrid x:Name="DocumentsDataGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      AlternatingRowBackground="#F9F9F9"
                      RowHeight="40"
                      FontSize="13">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nr." Binding="{Binding Number}" Width="100"/>
                    <DataGridTextColumn Header="Typ" Binding="{Binding DisplayType}" Width="150"/>
                    <DataGridTextColumn Header="Kunde" Binding="{Binding CustomerSnapshot.CompanyName}" Width="200"/>
                    <DataGridTextColumn Header="Datum" Binding="{Binding DocumentDate}" Width="100"/>
                    <DataGridTextColumn Header="Betreff" Binding="{Binding Subject}" Width="*" MinWidth="150"/>
                    <DataGridTextColumn Header="Betrag" Binding="{Binding TotalGrossDisplay}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextAlignment" Value="Right"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Status" Binding="{Binding DisplayStatus}" Width="120"/>
                    
                    <DataGridTemplateColumn Header="Aktionen" Width="450">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="📄 PDF" 
                                            Width="52" 
                                            Height="28"
                                            Margin="2"
                                            ToolTip="PDF herunterladen"
                                            Click="DownloadPdf_Click"
                                            Background="#2196F3"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            FontSize="11"/>
                                    <Button Content="📧 Senden" 
                                            Width="65" 
                                            Height="28"
                                            Margin="2"
                                            Click="SendDocument_Click"
                                            Background="#FF9800"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            FontSize="11"/>
                                    <Button Content="✔ Fertigstellen"
                                            Width="88"
                                            Height="28"
                                            Margin="2"
                                            ToolTip="Entwurf fertigstellen"
                                            Click="FinalizeDocument_Click"
                                            Background="#009688"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            FontSize="11">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDraft}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="🔄 Umwandeln"
                                            Width="88"
                                            Height="28"
                                            Margin="2"
                                            ToolTip="Dokument konvertieren"
                                            Click="Convert_Click"
                                            Background="#9C27B0"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            FontSize="11"/>
                                    <Button Content="✓ Bezahlt" 
                                            Width="60" 
                                            Height="28"
                                            Margin="2"
                                            Click="MarkAsPaid_Click"
                                            Background="#4CAF50"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            FontSize="11"/>
                                    <Button Content="❌ Löschen" 
                                            Width="65" 
                                            Height="28"
                                            Margin="2"
                                            Click="DeleteDocument_Click"
                                            Background="#F44336"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            FontSize="11"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="3" 
                Background="#F5F5F5" 
                BorderBrush="#DDD" 
                BorderThickness="1" 
                CornerRadius="5"
                Padding="10"
                Margin="0,15,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="StatusTextBlock" 
                           Text="Bereit" 
                           FontSize="12"
                           Foreground="#666"/>
                <TextBlock x:Name="DocumentCountTextBlock"
                           Text=""
                           FontSize="12"
                           Foreground="#666"
                           Margin="20,0,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
