<Window x:Class="Projektsoftware.Views.ProjectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Projekt bearbeiten" Height="700" Width="550"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Projektname *" Grid.Row="0" Margin="0,0,0,5" FontWeight="Bold"/>
        <TextBox x:Name="NameTextBox" Grid.Row="0" Margin="0,25,0,10"/>

        <TextBlock Text="Beschreibung" Grid.Row="1" Margin="0,0,0,5" FontWeight="Bold"/>
        <TextBox x:Name="DescriptionTextBox" Grid.Row="1" Margin="0,25,0,10" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>

        <TextBlock Text="Kundenname" Grid.Row="2" Margin="0,0,0,5" FontWeight="Bold"/>
        <Grid Grid.Row="2" Margin="0,25,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ComboBox x:Name="CustomerComboBox" 
                      Grid.Column="0"
                      IsEditable="True"
                      DisplayMemberPath="DisplayName"
                      SelectedValuePath="Id"
                      IsSynchronizedWithCurrentItem="False"
                      SelectionChanged="CustomerComboBox_SelectionChanged"/>

            <Button Content="📋" 
                    Grid.Column="2"
                    Width="35"
                    Height="30"
                    Click="OpenEasybillCustomers_Click"
                    Background="#2196F3" 
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    ToolTip="Easybill-Kunden verwalten"/>
        </Grid>

        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Startdatum *" Margin="0,0,0,5" FontWeight="Bold"/>
                <DatePicker x:Name="StartDatePicker"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Enddatum" Margin="0,0,0,5" FontWeight="Bold"/>
                <DatePicker x:Name="EndDatePicker"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="4" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Status *" Margin="0,0,0,5" FontWeight="Bold"/>
                <ComboBox x:Name="StatusComboBox">
                    <ComboBoxItem Content="Aktiv" IsSelected="True"/>
                    <ComboBoxItem Content="Abgeschlossen"/>
                    <ComboBoxItem Content="Pausiert"/>
                    <ComboBoxItem Content="Abgebrochen"/>
                </ComboBox>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Budget (€)" Margin="0,0,0,5" FontWeight="Bold"/>
                <TextBox x:Name="BudgetTextBox" Text="0"/>
            </StackPanel>
        </Grid>

        <!-- EASYBILL INTEGRATION BEREICH -->
        <Border Grid.Row="5" 
                BorderBrush="#2196F3" 
                BorderThickness="2" 
                CornerRadius="5" 
                Padding="10"
                Margin="0,10,0,10"
                Background="#F0F8FF">
            <StackPanel>
                <!-- Checkbox für Easybill-Integration -->
                <CheckBox x:Name="CreateInEasybillCheckBox" 
                          Content="📤 Automatisch in Easybill anlegen" 
                          FontWeight="Bold"
                          FontSize="14"
                          Foreground="#2196F3"
                          Checked="CreateInEasybillCheckBox_Checked"
                          Unchecked="CreateInEasybillCheckBox_Unchecked"
                          Margin="0,0,0,10"/>

                <!-- Erweiterte Easybill-Optionen (nur sichtbar wenn Checkbox aktiviert) -->
                <StackPanel x:Name="EasybillOptionsPanel" Visibility="Collapsed">
                    <Separator Margin="0,0,0,10"/>

                    <TextBlock Text="ℹ️ Easybill-Projekteinstellungen" 
                               FontWeight="SemiBold" 
                               Margin="0,0,0,10"
                               Foreground="#555"/>

                    <!-- Stundensatz -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Stundensatz (€)" Margin="0,0,0,5" FontWeight="SemiBold"/>
                            <TextBox x:Name="HourlyRateTextBox" Text="0,00"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Budget-Typ" Margin="0,0,0,5" FontWeight="SemiBold"/>
                            <ComboBox x:Name="BudgetTypeComboBox">
                                <ComboBoxItem Content="Stunden" IsSelected="True"/>
                                <ComboBoxItem Content="Geld"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <!-- Projekt-Status in Easybill -->
                    <StackPanel Margin="0,0,0,5">
                        <TextBlock Text="Projektstatus" Margin="0,0,0,5" FontWeight="SemiBold"/>
                        <ComboBox x:Name="EasybillStatusComboBox">
                            <ComboBoxItem Content="Offen" IsSelected="True"/>
                            <ComboBoxItem Content="Abgeschlossen"/>
                            <ComboBoxItem Content="Storniert"/>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Speichern" 
                    Width="100" 
                    Height="35" 
                    Margin="0,0,10,0"
                    Click="Save_Click"
                    Background="#4CAF50" 
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"/>
            <Button Content="Abbrechen" 
                    Width="100" 
                    Height="35"
                    Click="Cancel_Click"
                    Background="#9E9E9E" 
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
