<Window x:Class="Projektsoftware.Views.CreateOrderConfirmationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Auftragsbestätigung erstellen"
        Height="600" Width="750"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="📋 Auftragsbestätigung erstellen" 
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Info -->
        <Border Grid.Row="1" BorderBrush="#E0E0E0" BorderThickness="1" 
                Padding="15" Margin="0,0,0,15" Background="#F3E5F5">
            <StackPanel>
                <TextBlock Text="Wählen Sie ein Angebot aus der Liste unten aus" 
                           FontSize="13" Foreground="#7B1FA2" FontWeight="SemiBold"/>
                <TextBlock Text="Die Auftragsbestätigung wird mit allen Positionen und Daten des ausgewählten Angebots erstellt." 
                           FontSize="12" Foreground="#666" Margin="0,5,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Angebote-Liste -->
        <GroupBox Grid.Row="2" Header="Verfügbare Angebote" Padding="10" Margin="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Suche -->
                <TextBox x:Name="SearchTextBox" Grid.Row="0" 
                         Margin="0,0,0,10"
                         Height="32"
                         VerticalContentAlignment="Center"
                         TextChanged="Search_TextChanged"
                         GotFocus="SearchTextBox_GotFocus"
                         LostFocus="SearchTextBox_LostFocus"
                         Foreground="Gray"
                         Text="Suchen..."/>

                <!-- DataGrid -->
                <DataGrid x:Name="OffersDataGrid" Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionChanged="OffersDataGrid_SelectionChanged"
                          MouseDoubleClick="OffersDataGrid_MouseDoubleClick"
                          Height="250">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80"/>
                        <DataGridTextColumn Header="Nummer" Binding="{Binding Number}" Width="120"/>
                        <DataGridTextColumn Header="Kunde" Binding="{Binding CustomerDisplay}" Width="*"/>
                        <DataGridTextColumn Header="Betrag" Width="120">
                            <DataGridTextColumn.Binding>
                                <Binding Path="TotalGross" StringFormat="{}{0:N2} €"/>
                            </DataGridTextColumn.Binding>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Datum" Binding="{Binding DocumentDate}" Width="100"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding DisplayStatus}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>

        <!-- Optionaler Text -->
        <StackPanel Grid.Row="3" Margin="0,0,0,15">
            <TextBlock Text="Bestätigungstext (optional)" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="ConfirmationTextBox" Height="80" TextWrapping="Wrap" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     Text="Hiermit bestätigen wir Ihren Auftrag und bedanken uns für Ihr Vertrauen."/>
            
            <!-- Als Entwurf -->
            <CheckBox x:Name="IsDraftCheckBox" 
                      Content="Als Entwurf speichern"
                      IsChecked="False"
                      Margin="0,10,0,0"
                      FontWeight="SemiBold"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Abbrechen" Width="100" Height="35" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button x:Name="CreateButton" Content="Auftragsbestätigung erstellen" Width="220" Height="35" 
                    Click="Create_Click" 
                    IsEnabled="False"
                    Background="#9C27B0" 
                    Foreground="White"
                    FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</Window>
