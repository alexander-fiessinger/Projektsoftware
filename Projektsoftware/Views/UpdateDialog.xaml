<Window x:Class="Projektsoftware.Views.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Software-Update verfügbar"
        Height="460" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="🚀 Update verfügbar"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"/>
            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Aktuelle Version:" Foreground="#666" FontSize="13" VerticalAlignment="Center"/>
                <TextBlock x:Name="CurrentVersionText" Grid.Column="1"
                           Margin="8,0,20,0" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="Neue Version:" Foreground="#666" FontSize="13" VerticalAlignment="Center"/>
                <TextBlock x:Name="NewVersionText" Grid.Column="3"
                           Margin="8,0,0,0" FontSize="13" FontWeight="Bold"
                           Foreground="#4CAF50" VerticalAlignment="Center"/>
            </Grid>
        </StackPanel>

        <!-- Release Notes -->
        <GroupBox Grid.Row="1" Header="Was ist neu?" Margin="0,0,0,15" FontWeight="SemiBold">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="5">
                <TextBlock x:Name="ReleaseNotesText"
                           TextWrapping="Wrap" FontSize="13" LineHeight="20"
                           FontWeight="Normal"/>
            </ScrollViewer>
        </GroupBox>

        <!-- Progress Area -->
        <StackPanel Grid.Row="2" Margin="0,0,0,15" x:Name="ProgressPanel" Visibility="Collapsed">
            <TextBlock x:Name="ProgressStatusText"
                       FontSize="12" Foreground="#555" Margin="0,0,0,5"/>
            <ProgressBar x:Name="DownloadProgressBar" Height="18" Value="0" Maximum="100"/>
            <TextBlock x:Name="ProgressPercentText"
                       Text="0 %" FontSize="11" Foreground="#888"
                       HorizontalAlignment="Right" Margin="0,3,0,0"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton" Content="Später" Width="100" Height="38" Margin="0,0,10,0"
                    Click="Cancel_Click"
                    Background="#9E9E9E" Foreground="White" BorderThickness="0"
                    Cursor="Hand" FontWeight="SemiBold"/>
            <Button x:Name="UpdateButton" Content="Jetzt aktualisieren" Width="160" Height="38"
                    Click="Update_Click"
                    Background="#4CAF50" Foreground="White" BorderThickness="0"
                    Cursor="Hand" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</Window>
