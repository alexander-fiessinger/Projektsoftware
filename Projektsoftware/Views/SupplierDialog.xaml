<Window x:Class="Projektsoftware.Views.SupplierDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lieferant" Width="480" Height="560"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="TitleText" Text="🏭 Neuer Lieferant"
                   FontSize="18" FontWeight="Bold" Foreground="#1A237E" Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Name *" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox x:Name="NameBox" Height="32" Padding="6,4" Margin="0,0,0,10" FontSize="13"/>

                <TextBlock Text="Ansprechpartner" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox x:Name="ContactPersonBox" Height="32" Padding="6,4" Margin="0,0,0,10" FontSize="13"/>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="E-Mail" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox x:Name="EmailBox" Height="32" Padding="6,4" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Telefon" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox x:Name="PhoneBox" Height="32" Padding="6,4" FontSize="13"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Straße" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox x:Name="AddressBox" Height="32" Padding="6,4" Margin="0,0,0,10" FontSize="13"/>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="PLZ" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox x:Name="ZipCodeBox" Height="32" Padding="6,4" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Stadt" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox x:Name="CityBox" Height="32" Padding="6,4" FontSize="13"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Steuernummer / USt-IdNr." FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox x:Name="TaxNumberBox" Height="32" Padding="6,4" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Land" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox x:Name="CountryBox" Height="32" Padding="6,4" FontSize="13" Text="Deutschland"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="140"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="IBAN" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox x:Name="IbanBox" Height="32" Padding="6,4" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="BIC" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox x:Name="BicBox" Height="32" Padding="6,4" FontSize="13"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Notizen" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox x:Name="NotesBox" Height="70" Padding="6,4" FontSize="13"
                         TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Abbrechen" Width="100" Height="36" Margin="0,0,8,0"
                    IsCancel="True" Click="Cancel_Click"/>
            <Button Content="💾 Speichern" Width="110" Height="36"
                    Background="#1A237E" Foreground="White" BorderThickness="0"
                    IsDefault="True" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
