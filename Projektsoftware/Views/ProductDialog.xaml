<Window x:Class="Projektsoftware.Views.ProductDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Produkt bearbeiten" Height="600" Width="550"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" 
                   Text="📦 Produkt/Dienstleistung anlegen"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="{StaticResource PrimaryBrush}"
                   Margin="0,0,0,20"/>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Type -->
                <TextBlock Text="Typ: *" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox x:Name="TypeComboBox" 
                          Height="35"
                          Margin="0,0,0,15"
                          VerticalContentAlignment="Center"
                          SelectedIndex="1">
                    <ComboBoxItem Content="Produkt" Tag="PRODUCT"/>
                    <ComboBoxItem Content="Dienstleistung" Tag="SERVICE"/>
                </ComboBox>

                <!-- Number -->
                <TextBlock Text="Artikelnummer: *" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="NumberTextBox" 
                         Height="35"
                         Margin="0,0,0,15"
                         VerticalContentAlignment="Center"
                         ToolTip="Eindeutige Artikelnummer (z.B. PROD-001, SERVICE-001)"/>

                <!-- Description -->
                <TextBlock Text="Beschreibung: *" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="DescriptionTextBox" 
                         Height="70"
                         Margin="0,0,0,15"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         VerticalContentAlignment="Top"
                         Padding="5"
                         ToolTip="Beschreibung des Produkts/der Dienstleistung"/>

                <!-- Sale Price -->
                <TextBlock Text="Verkaufspreis (€): *" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="SalePriceTextBox" 
                         Height="35"
                         Margin="0,0,0,15"
                         VerticalContentAlignment="Center"
                         ToolTip="Verkaufspreis in Euro (z.B. 100.00 oder 99.99)"/>

                <!-- VAT Percent -->
                <TextBlock Text="Mehrwertsteuersatz: *" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox x:Name="VatPercentComboBox" 
                          Height="35"
                          Margin="0,0,0,15"
                          VerticalContentAlignment="Center"
                          SelectedIndex="2">
                    <ComboBoxItem Content="0% (steuerfrei)" Tag="0"/>
                    <ComboBoxItem Content="7% (ermäßigt)" Tag="7"/>
                    <ComboBoxItem Content="19% (Regelsteuersatz)" Tag="19"/>
                </ComboBox>

                <!-- Unit -->
                <TextBlock Text="Einheit: *" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox x:Name="UnitComboBox" 
                          Height="35"
                          Margin="0,0,0,15"
                          IsEditable="True"
                          VerticalContentAlignment="Center"
                          Text="Stunden">
                    <ComboBoxItem Content="Stunden"/>
                    <ComboBoxItem Content="Stück"/>
                    <ComboBoxItem Content="Tage"/>
                    <ComboBoxItem Content="Monate"/>
                    <ComboBoxItem Content="Pauschal"/>
                    <ComboBoxItem Content="kg"/>
                    <ComboBoxItem Content="Meter"/>
                    <ComboBoxItem Content="Liter"/>
                </ComboBox>

                <!-- Note -->
                <TextBlock Text="Notiz (optional):" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="NoteTextBox" 
                         Height="60"
                         Margin="0,0,0,15"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         VerticalContentAlignment="Top"
                         Padding="5"
                         ToolTip="Interne Notizen (werden an Easybill übertragen)"/>

                <!-- Required Fields Info -->
                <TextBlock Text="* Pflichtfelder" 
                           FontStyle="Italic"
                           Foreground="Gray"
                           Margin="0,10,0,0"/>

                <!-- Sync Status (only visible in edit mode) -->
                <TextBlock x:Name="SyncStatusTextBlock"
                           Margin="0,10,0,0"
                           FontWeight="Bold"
                           Visibility="Collapsed"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="Abbrechen"
                    Height="40"
                    Style="{StaticResource ModernButton}"
                    Background="#95A5A6"
                    Click="Cancel_Click"/>

            <Button Grid.Column="2"
                    Content="Speichern"
                    Height="40"
                    Style="{StaticResource ModernButton}"
                    Background="{StaticResource SuccessBrush}"
                    Click="Save_Click"/>
        </Grid>
    </Grid>
</Window>
