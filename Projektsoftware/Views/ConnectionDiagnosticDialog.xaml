<Window x:Class="Projektsoftware.Views.ConnectionDiagnosticDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Verbindungsdiagnose" Height="550" Width="700"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize">
    <DockPanel Margin="20">
        <TextBlock DockPanel.Dock="Top" FontSize="18" FontWeight="Bold" Margin="0,0,0,20" Foreground="#1976D2">
            🔍 MySQL Verbindungsdiagnose
        </TextBlock>
        
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Erneut testen" 
                    Width="130" 
                    Height="40" 
                    Margin="0,0,10,0"
                    Click="Retest_Click"
                    Background="#2196F3" 
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Cursor="Hand"/>
            <Button Content="Einstellungen öffnen" 
                    Width="160" 
                    Height="40" 
                    Margin="0,0,10,0"
                    Click="OpenSettings_Click"
                    Background="#FF9800" 
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Cursor="Hand"/>
            <Button Content="Schließen" 
                    Width="110" 
                    Height="40"
                    Click="Close_Click"
                    Background="#9E9E9E" 
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Cursor="Hand"/>
        </StackPanel>
        
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Aktuelle Konfiguration -->
                <Border Background="#E8F5E9" Padding="15" Margin="0,0,0,15" CornerRadius="5" BorderBrush="#4CAF50" BorderThickness="2">
                    <StackPanel>
                        <TextBlock FontWeight="Bold" FontSize="14" Margin="0,0,0,10">📋 Aktuelle Konfiguration:</TextBlock>
                        <TextBlock x:Name="ConfigInfoTextBlock" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"/>
                    </StackPanel>
                </Border>
                
                <!-- Test-Ergebnisse -->
                <Border x:Name="ResultBorder" Background="#FFEBEE" Padding="15" Margin="0,0,0,15" CornerRadius="5" BorderBrush="#f44336" BorderThickness="2">
                    <StackPanel>
                        <TextBlock FontWeight="Bold" FontSize="14" Margin="0,0,0,10">🔴 Testergebnis:</TextBlock>
                        <TextBlock x:Name="ResultTextBlock" TextWrapping="Wrap" FontSize="12"/>
                    </StackPanel>
                </Border>
                
                <!-- Checkliste -->
                <Border Background="#E3F2FD" Padding="15" Margin="0,0,0,15" CornerRadius="5" BorderBrush="#2196F3" BorderThickness="2">
                    <StackPanel>
                        <TextBlock FontWeight="Bold" FontSize="14" Margin="0,0,0,10">✅ Überprüfungs-Checkliste:</TextBlock>
                        <StackPanel x:Name="ChecklistPanel"/>
                    </StackPanel>
                </Border>
                
                <!-- Lösungsvorschläge -->
                <Border Background="#FFF3E0" Padding="15" CornerRadius="5" BorderBrush="#FF9800" BorderThickness="2">
                    <StackPanel>
                        <TextBlock FontWeight="Bold" FontSize="14" Margin="0,0,0,10">💡 Lösungsvorschläge:</TextBlock>
                        <TextBlock x:Name="SolutionsTextBlock" TextWrapping="Wrap" FontSize="12"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
