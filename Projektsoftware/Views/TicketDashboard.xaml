<Window x:Class="Projektsoftware.Views.TicketDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ticket-Dashboard" 
        Height="600" 
        Width="1000"
        WindowStartupLocation="CenterScreen" FontFamily="Segoe UI, Segoe UI Emoji"
        Loaded="Window_Loaded">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0" 
                       Text="📊 Ticket-Dashboard" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Foreground="#2196F3"/>
            
            <Button Grid.Column="1" 
                    Content="🔄 Aktualisieren" 
                    Width="150" 
                    Height="40" 
                    Click="Refresh_Click"
                    Background="#4CAF50"
                    Foreground="White"
                    FontWeight="Bold"/>
        </Grid>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- �bersicht Kacheln -->
                <TextBlock Text="📋 Übersicht" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Margin="0,0,0,15"/>
                
                <UniformGrid Columns="4" Rows="2" Margin="0,0,0,25">
                    <!-- Gesamt -->
                    <Border Background="#2196F3" 
                            CornerRadius="10" 
                            Margin="5" 
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="Gesamt" 
                                       Foreground="White" 
                                       FontSize="14" 
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="TotalTicketsText" 
                                       Text="0" 
                                       Foreground="White" 
                                       FontSize="36" 
                                       FontWeight="Bold" 
                                       Margin="0,10,0,0"/>
                            <TextBlock Text="Tickets" 
                                       Foreground="White" 
                                       FontSize="12" 
                                       Opacity="0.8"/>
                        </StackPanel>
                    </Border>

                    <!-- Neu -->
                    <Border Background="#FF9800" 
                            CornerRadius="10" 
                            Margin="5" 
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="🆕 Neu" 
                                       Foreground="White" 
                                       FontSize="14" 
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="NewTicketsText" 
                                       Text="0" 
                                       Foreground="White" 
                                       FontSize="36" 
                                       FontWeight="Bold" 
                                       Margin="0,10,0,0"/>
                            <TextBlock Text="Tickets" 
                                       Foreground="White" 
                                       FontSize="12" 
                                       Opacity="0.8"/>
                        </StackPanel>
                    </Border>

                    <!-- In Bearbeitung -->
                    <Border Background="#03A9F4" 
                            CornerRadius="10" 
                            Margin="5" 
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="🔧 In Arbeit" 
                                       Foreground="White" 
                                       FontSize="14" 
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="InProgressText" 
                                       Text="0" 
                                       Foreground="White" 
                                       FontSize="36" 
                                       FontWeight="Bold" 
                                       Margin="0,10,0,0"/>
                            <TextBlock Text="Tickets" 
                                       Foreground="White" 
                                       FontSize="12" 
                                       Opacity="0.8"/>
                        </StackPanel>
                    </Border>

                    <!-- Dringend -->
                    <Border Background="#F44336" 
                            CornerRadius="10" 
                            Margin="5" 
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="🚨 Dringend" 
                                       Foreground="White" 
                                       FontSize="14" 
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="UrgentText" 
                                       Text="0" 
                                       Foreground="White" 
                                       FontSize="36" 
                                       FontWeight="Bold" 
                                       Margin="0,10,0,0"/>
                            <TextBlock Text="Tickets" 
                                       Foreground="White" 
                                       FontSize="12" 
                                       Opacity="0.8"/>
                        </StackPanel>
                    </Border>

                    <!-- Gel�st -->
                    <Border Background="#4CAF50" 
                            CornerRadius="10" 
                            Margin="5" 
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="✅ Gelöst" 
                                       Foreground="White" 
                                       FontSize="14" 
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="ResolvedText" 
                                       Text="0" 
                                       Foreground="White" 
                                       FontSize="36" 
                                       FontWeight="Bold" 
                                       Margin="0,10,0,0"/>
                            <TextBlock Text="Tickets" 
                                       Foreground="White" 
                                       FontSize="12" 
                                       Opacity="0.8"/>
                        </StackPanel>
                    </Border>

                    <!-- Warten -->
                    <Border Background="#9C27B0" 
                            CornerRadius="10" 
                            Margin="5" 
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="⏳ Warten" 
                                       Foreground="White" 
                                       FontSize="14" 
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="WaitingText" 
                                       Text="0" 
                                       Foreground="White" 
                                       FontSize="36" 
                                       FontWeight="Bold" 
                                       Margin="0,10,0,0"/>
                            <TextBlock Text="Tickets" 
                                       Foreground="White" 
                                       FontSize="12" 
                                       Opacity="0.8"/>
                        </StackPanel>
                    </Border>

                    <!-- Nicht zugewiesen -->
                    <Border Background="#607D8B" 
                            CornerRadius="10" 
                            Margin="5" 
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="👤 Nicht zugewiesen" 
                                       Foreground="White" 
                                       FontSize="14" 
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="UnassignedText" 
                                       Text="0" 
                                       Foreground="White" 
                                       FontSize="36" 
                                       FontWeight="Bold" 
                                       Margin="0,10,0,0"/>
                            <TextBlock Text="Tickets" 
                                       Foreground="White" 
                                       FontSize="12" 
                                       Opacity="0.8"/>
                        </StackPanel>
                    </Border>

                    <!-- Geschlossen -->
                    <Border Background="#78909C" 
                            CornerRadius="10" 
                            Margin="5" 
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="🔒 Geschlossen" 
                                       Foreground="White" 
                                       FontSize="14" 
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="ClosedText" 
                                       Text="0" 
                                       Foreground="White" 
                                       FontSize="36" 
                                       FontWeight="Bold" 
                                       Margin="0,10,0,0"/>
                            <TextBlock Text="Tickets" 
                                       Foreground="White" 
                                       FontSize="12" 
                                       Opacity="0.8"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Zeitliche �bersicht -->
                <TextBlock Text="📋 Übersicht" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Margin="0,10,0,15"/>
                
                <UniformGrid Columns="3" Margin="0,0,0,25">
                    <Border Background="#E3F2FD" 
                            BorderBrush="#2196F3" 
                            BorderThickness="2" 
                            CornerRadius="10" 
                            Margin="5" 
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="📅 Heute" 
                                       Foreground="#2196F3" 
                                       FontSize="14" 
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="TodayText" 
                                       Text="0" 
                                       Foreground="#2196F3" 
                                       FontSize="32" 
                                       FontWeight="Bold" 
                                       Margin="0,10,0,0"/>
                            <TextBlock Text="neue Tickets" 
                                       Foreground="#2196F3" 
                                       FontSize="12"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#E8F5E9" 
                            BorderBrush="#4CAF50" 
                            BorderThickness="2" 
                            CornerRadius="10" 
                            Margin="5" 
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="📆 Diese Woche" 
                                       Foreground="#4CAF50" 
                                       FontSize="14" 
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="WeekText" 
                                       Text="0" 
                                       Foreground="#4CAF50" 
                                       FontSize="32" 
                                       FontWeight="Bold" 
                                       Margin="0,10,0,0"/>
                            <TextBlock Text="neue Tickets" 
                                       Foreground="#4CAF50" 
                                       FontSize="12"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#FFF3E0" 
                            BorderBrush="#FF9800" 
                            BorderThickness="2" 
                            CornerRadius="10" 
                            Margin="5" 
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="📊 Dieser Monat" 
                                       Foreground="#FF9800" 
                                       FontSize="14" 
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="MonthText" 
                                       Text="0" 
                                       Foreground="#FF9800" 
                                       FontSize="32" 
                                       FontWeight="Bold" 
                                       Margin="0,10,0,0"/>
                            <TextBlock Text="neue Tickets" 
                                       Foreground="#FF9800" 
                                       FontSize="12"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Performance -->
                <TextBlock Text="Performance" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Margin="0,10,0,15"/>
                
                <Border Background="#F5F5F5" 
                        BorderBrush="#CCCCCC" 
                        BorderThickness="1" 
                        CornerRadius="10" 
                        Padding="20" 
                        Margin="5">
                    <StackPanel>
                        <TextBlock Text="⏱️ Durchschnittliche Bearbeitungszeit" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Foreground="#333"/>
                        <TextBlock x:Name="AvgTimeText" 
                                   Text="Keine Daten" 
                                   FontSize="28" 
                                   FontWeight="Bold" 
                                   Foreground="#2196F3" 
                                   Margin="0,10,0,0"/>
                        <TextBlock Text="(Basierend auf gelösten Tickets)" 
                                   FontSize="12" 
                                   Foreground="#666" 
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    Margin="0,15,0,0" 
                    HorizontalAlignment="Right">
            <Button Content="📕 Dashboard als PDF"
                    Width="180"
                    Height="35"
                    Click="ExportPdf_Click"
                    Background="#E91E63"
                    Foreground="White"
                    Margin="0,0,10,0"/>
            <Button Content="📋 Alle Tickets anzeigen" 
                    Width="180" 
                    Height="35" 
                    Click="ShowAllTickets_Click"
                    Background="#2196F3"
                    Foreground="White"
                    Margin="0,0,10,0"/>
            <Button Content="Schließen" 
                    Width="100" 
                    Height="35" 
                    Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>

