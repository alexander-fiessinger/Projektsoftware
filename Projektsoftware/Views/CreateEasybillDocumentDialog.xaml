<Window x:Class="Projektsoftware.Views.CreateEasybillDocumentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:System="clr-namespace:System;assembly=mscorlib"
        Title="📄 Easybill Dokument erstellen" 
        Height="800" 
        Width="900"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,20">
            <TextBlock x:Name="HeaderTextBlock"
                       Text="📄 Dokument erstellen" 
                       FontSize="24" 
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"/>
            <TextBlock Text="Erstellen Sie ein neues Easybill-Dokument mit Positionen"
                       FontSize="14"
                       Foreground="#666"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Left Panel: Document Details -->
        <ScrollViewer Grid.Row="1" Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,10,0">
            <StackPanel>
                <TextBlock Text="Dokumentdetails" FontSize="16" FontWeight="Bold" Margin="0,0,0,15" Foreground="{StaticResource PrimaryBrush}"/>

                <!-- Dokumenttyp -->
                <TextBlock Text="Dokumenttyp *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <ComboBox x:Name="TypeComboBox" 
                          Height="35" 
                          Margin="0,0,0,15"
                          SelectionChanged="TypeComboBox_SelectionChanged">
                    <ComboBoxItem Content="📄 Rechnung" Tag="INVOICE" IsSelected="True"/>
                    <ComboBoxItem Content="🧾 Proforma-Rechnung" Tag="PROFORMA_INVOICE"/>
                    <ComboBoxItem Content="📋 Angebot" Tag="OFFER"/>
                    <ComboBoxItem Content="✓ Auftragsbestätigung" Tag="ORDER_CONFIRMATION"/>
                    <ComboBoxItem Content="📦 Lieferschein" Tag="DELIVERY_NOTE"/>
                    <ComboBoxItem Content="💳 Gutschrift" Tag="CREDIT"/>
                </ComboBox>

                <!-- Kunde -->
                <TextBlock Text="Kunde *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <ComboBox x:Name="CustomerComboBox" 
                          Height="35" 
                          Margin="0,0,0,5"
                          DisplayMemberPath="DisplayName"
                          SelectionChanged="CustomerComboBox_SelectionChanged"/>

                <!-- Steuerinfo Banner -->
                <Border x:Name="VatInfoBorder" 
                        Padding="10" CornerRadius="5" Margin="0,0,0,15" 
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock x:Name="VatInfoTextBlock" 
                                   FontSize="12" TextWrapping="Wrap" Foreground="White" FontWeight="SemiBold"/>
                        <TextBlock x:Name="VatDetailTextBlock" 
                                   FontSize="11" TextWrapping="Wrap" Foreground="#FFFFFFCC" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Projekt -->
                <TextBlock Text="Projekt" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <ComboBox x:Name="ProjectComboBox" 
                          Height="35" 
                          Margin="0,0,0,15"
                          DisplayMemberPath="Name"/>

                <!-- Dokumentdatum -->
                <TextBlock Text="Dokumentdatum *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <DatePicker x:Name="DocumentDatePicker" 
                            Height="35" 
                            Margin="0,0,0,15"
                            SelectedDate="{x:Static System:DateTime.Now}"/>

                <!-- Zahlungsziel -->
                <TextBlock Text="Zahlungsziel (Tage)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="DueInDaysTextBox" 
                         Height="35" 
                         Margin="0,0,0,15"
                         Text="14"
                         VerticalContentAlignment="Center"/>

                <!-- Währung -->
                <TextBlock Text="Währung" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <ComboBox x:Name="CurrencyComboBox" 
                          Height="35" 
                          Margin="0,0,0,15">
                    <ComboBoxItem Content="EUR (€)" Tag="EUR" IsSelected="True"/>
                    <ComboBoxItem Content="USD ($)" Tag="USD"/>
                    <ComboBoxItem Content="CHF (CHF)" Tag="CHF"/>
                    <ComboBoxItem Content="GBP (£)" Tag="GBP"/>
                </ComboBox>

                <!-- Titel -->
                <TextBlock Text="Titel" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="TitleTextBox" 
                         Height="35" 
                         Margin="0,0,0,15"
                         VerticalContentAlignment="Center"/>

                <!-- Betreff -->
                <TextBlock Text="Betreff" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="SubjectTextBox" 
                         Height="35" 
                         Margin="0,0,0,15"
                         VerticalContentAlignment="Center"/>

                <!-- Einleitungstext -->
                <TextBlock Text="Einleitungstext" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="TextTextBox" 
                         Height="60" 
                         Margin="0,0,0,15"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"/>

                <!-- Schlusstext -->
                <TextBlock Text="Schlusstext" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="TextSuffixTextBox" 
                         Height="60" 
                         Margin="0,0,0,15"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"/>

                <!-- Als Entwurf -->
                <CheckBox x:Name="IsDraftCheckBox" 
                          Content="Als Entwurf speichern"
                          IsChecked="True"
                          Margin="0,0,0,10"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Right Panel: Positions/Items -->
        <Grid Grid.Row="1" Grid.Column="1" Margin="10,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Items Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Positionen" FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                <Button Content="➕ Position hinzufügen"
                        Height="30"
                        Margin="15,0,0,0"
                        Padding="10,0"
                        Click="AddItem_Click"
                        Background="#4CAF50"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        FontSize="12"
                        FontWeight="SemiBold"/>
            </StackPanel>

            <!-- Items DataGrid -->
            <Border Grid.Row="1" BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" Background="White">
                <DataGrid x:Name="ItemsDataGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          AlternatingRowBackground="#F9F9F9"
                          RowHeight="35">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Beschreibung" Binding="{Binding Description}" Width="*" MinWidth="150"/>
                        <DataGridTextColumn Header="Menge" Binding="{Binding Quantity}" Width="60"/>
                        <DataGridTextColumn Header="Einheit" Binding="{Binding Unit}" Width="70"/>
                        <DataGridTextColumn Header="Einzelpreis (Netto)" Binding="{Binding SinglePriceNet, StringFormat=N2}" Width="110"/>
                        <DataGridTextColumn Header="MwSt %" Binding="{Binding VatPercent}" Width="60"/>
                        <DataGridTextColumn Header="Gesamt (Netto)" Binding="{Binding TotalPriceNet, StringFormat=N2}" Width="100" IsReadOnly="True"/>
                        <DataGridTemplateColumn Header="" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="🗑️" 
                                            Click="RemoveItem_Click"
                                            Background="#f44336"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Height="25"
                                            Width="40"
                                            FontSize="12"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Summary -->
            <Border Grid.Row="2" Background="#F5F5F5" Padding="10" Margin="0,10,0,0" CornerRadius="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Nettobetrag:" FontWeight="SemiBold" Margin="0,2"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="NetTotalTextBlock" Text="0,00 €" FontWeight="SemiBold" Margin="10,2,0,2" HorizontalAlignment="Right"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="MwSt:" FontWeight="SemiBold" Margin="0,2"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="VatTotalTextBlock" Text="0,00 €" FontWeight="SemiBold" Margin="10,2,0,2" HorizontalAlignment="Right"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Bruttobetrag:" FontWeight="Bold" FontSize="16" Foreground="{StaticResource PrimaryBrush}" Margin="0,5,0,0"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="GrossTotalTextBlock" Text="0,00 €" FontWeight="Bold" FontSize="16" Foreground="{StaticResource PrimaryBrush}" Margin="10,5,0,0" HorizontalAlignment="Right"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Grid.ColumnSpan="2"
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="Abbrechen"
                    Width="120"
                    Height="40"
                    Margin="0,0,10,0"
                    Click="Cancel_Click"
                    Background="#f44336"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    FontWeight="SemiBold"/>
            <Button x:Name="CreateButton"
                    Content="✓ Erstellen"
                    Width="120"
                    Height="40"
                    Click="Create_Click"
                    Background="#4CAF50"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    FontWeight="SemiBold"
                    IsEnabled="False"/>
        </StackPanel>
    </Grid>
</Window>
