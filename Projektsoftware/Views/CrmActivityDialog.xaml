<Window x:Class="Projektsoftware.Views.CrmActivityDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aktivität"
        Width="500" Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="TitleText" Text="Aktivität erfassen"
                   FontSize="18" FontWeight="SemiBold"
                   Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Typ *" Margin="0,0,0,4" Foreground="{StaticResource TextSecondaryBrush}"/>
                <ComboBox x:Name="TypeCombo" Height="34" Margin="0,0,0,12">
                    <ComboBoxItem Content="📝 Notiz" Tag="0" IsSelected="True"/>
                    <ComboBoxItem Content="📞 Anruf" Tag="1"/>
                    <ComboBoxItem Content="✉️ E-Mail" Tag="2"/>
                    <ComboBoxItem Content="🤝 Meeting" Tag="3"/>
                    <ComboBoxItem Content="✓ Aufgabe" Tag="4"/>
                </ComboBox>

                <TextBlock Text="Betreff *" Margin="0,0,0,4" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox x:Name="SubjectBox" Height="34" Margin="0,0,0,12"/>

                <TextBlock Text="Kontakt (optional)" Margin="0,0,0,4" Foreground="{StaticResource TextSecondaryBrush}"/>
                <ComboBox x:Name="ContactCombo" Height="34" Margin="0,0,0,12"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Id"/>

                <TextBlock Text="Kunde (optional)" Margin="0,0,0,4" Foreground="{StaticResource TextSecondaryBrush}"/>
                <ComboBox x:Name="CustomerCombo" Height="34" Margin="0,0,0,12"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Id"/>

                <TextBlock Text="Fällig am" Margin="0,0,0,4" Foreground="{StaticResource TextSecondaryBrush}"/>
                <DatePicker x:Name="DueDatePicker" Height="34" Margin="0,0,0,12"/>

                <TextBlock Text="Notizen" Margin="0,0,0,4" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox x:Name="NotesBox" Height="80" TextWrapping="Wrap"
                         AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12"/>

                <CheckBox x:Name="IsCompletedCheck" Content="Abgeschlossen" Margin="0,0,0,8"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Abbrechen" Width="100" Height="34" Margin="0,0,10,0"
                    Click="Cancel_Click"/>
            <Button Content="Speichern" Width="100" Height="34"
                    Style="{StaticResource ModernButton}"
                    Background="{StaticResource SuccessBrush}" Foreground="White"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
