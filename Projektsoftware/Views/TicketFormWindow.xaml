<Window x:Class="Projektsoftware.Views.TicketFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Support-Ticket erstellen" 
        Height="650" 
        Width="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="0,5,0,10"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="0,5,0,10"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Support-Ticket erstellen" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="#2196F3"/>
            <TextBlock Text="Bitte füllen Sie das Formular aus. Wir werden uns schnellstmöglich bei Ihnen melden." 
                       FontSize="13" 
                       Foreground="#666" 
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Kontaktinformationen -->
                <Border Background="#F5F5F5" 
                        Padding="15" 
                        Margin="0,0,0,15" 
                        CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="Ihre Kontaktdaten" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,10"/>
                        
                        <Label Content="Name *"/>
                        <TextBox x:Name="CustomerNameTextBox" 
                                 ToolTip="Ihr vollständiger Name oder Firmenname"/>

                        <Label Content="E-Mail *"/>
                        <TextBox x:Name="CustomerEmailTextBox" 
                                 ToolTip="Ihre E-Mail-Adresse für Rückmeldungen"/>

                        <Label Content="Telefon (optional)"/>
                        <TextBox x:Name="CustomerPhoneTextBox" 
                                 ToolTip="Ihre Telefonnummer"/>
                    </StackPanel>
                </Border>

                <!-- Ticket-Details -->
                <Border Background="#F5F5F5" 
                        Padding="15" 
                        Margin="0,0,0,15" 
                        CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="Ihr Anliegen" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,10"/>

                        <Label Content="Kategorie *"/>
                        <ComboBox x:Name="CategoryComboBox" 
                                  SelectedIndex="0">
                            <ComboBoxItem Content="Allgemein"/>
                            <ComboBoxItem Content="Technisch"/>
                            <ComboBoxItem Content="Abrechnung"/>
                            <ComboBoxItem Content="Feature-Anfrage"/>
                            <ComboBoxItem Content="Fehler"/>
                        </ComboBox>

                        <Label Content="Priorität *"/>
                        <ComboBox x:Name="PriorityComboBox" 
                                  SelectedIndex="1">
                            <ComboBoxItem Content="Niedrig"/>
                            <ComboBoxItem Content="Mittel"/>
                            <ComboBoxItem Content="Hoch"/>
                            <ComboBoxItem Content="Dringend"/>
                        </ComboBox>

                        <Label Content="Betreff *"/>
                        <TextBox x:Name="SubjectTextBox" 
                                 ToolTip="Kurze Zusammenfassung Ihres Problems"/>

                        <Label Content="Beschreibung *"/>
                        <TextBox x:Name="DescriptionTextBox" 
                                 Height="150" 
                                 TextWrapping="Wrap" 
                                 AcceptsReturn="True" 
                                 VerticalScrollBarVisibility="Auto"
                                 ToolTip="Detaillierte Beschreibung Ihres Anliegens"/>
                    </StackPanel>
                </Border>

                <!-- Projektzuordnung -->
                <Border Background="#E3F2FD" 
                        Padding="15" 
                        Margin="0,0,0,15" 
                        CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="Projektzuordnung (optional)" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="Für Abrechnung: Ticket einem Projekt zuordnen."
                                   FontSize="12" Foreground="#555" Margin="0,0,0,8"/>
                        <Label Content="Projekt"/>
                        <ComboBox x:Name="ProjectComboBox"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Id"
                                  ToolTip="Optionale Zuordnung zu einem Projekt für die Abrechnung"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="* Pflichtfelder" 
                           FontSize="11" 
                           Foreground="#666" 
                           FontStyle="Italic"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,20,0,0">
            <Button Content="Abbrechen" 
                    Width="120" 
                    Height="35" 
                    Margin="0,0,10,0" 
                    Click="Cancel_Click"
                    Background="#E0E0E0"/>
            <Button Content="Ticket absenden" 
                    Width="150" 
                    Height="35" 
                    Click="Submit_Click"
                    Background="#4CAF50"
                    Foreground="White"
                    FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
