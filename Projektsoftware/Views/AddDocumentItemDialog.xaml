<Window x:Class="Projektsoftware.Views.AddDocumentItemDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="➕ Position hinzufügen" 
        Height="500" 
        Width="500"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="➕ Position hinzufügen" 
                       FontSize="20" 
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"/>
            <TextBlock Text="Fügen Sie eine neue Position zum Dokument hinzu"
                       FontSize="13"
                       Foreground="#666"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Typ -->
                <TextBlock Text="Typ *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <ComboBox x:Name="TypeComboBox" 
                          Height="35" 
                          Margin="0,0,0,15">
                    <ComboBoxItem Content="📦 Position" Tag="POSITION" IsSelected="True"/>
                    <ComboBoxItem Content="📝 Text" Tag="TEXT"/>
                    <ComboBoxItem Content="➕ Zwischensumme" Tag="SUBTOTAL"/>
                </ComboBox>

                <!-- Beschreibung -->
                <TextBlock Text="Beschreibung *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="DescriptionTextBox" 
                         Height="80" 
                         Margin="0,0,0,15"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"/>

                <!-- Menge -->
                <TextBlock Text="Menge *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="QuantityTextBox" 
                         Height="35" 
                         Margin="0,0,0,15"
                         Text="1"
                         VerticalContentAlignment="Center"/>

                <!-- Einheit -->
                <TextBlock Text="Einheit" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <ComboBox x:Name="UnitComboBox" 
                          Height="35" 
                          Margin="0,0,0,15"
                          IsEditable="True"
                          Text="Stunden">
                    <ComboBoxItem Content="Stunden"/>
                    <ComboBoxItem Content="Tage"/>
                    <ComboBoxItem Content="Stück"/>
                    <ComboBoxItem Content="Pauschal"/>
                    <ComboBoxItem Content="km"/>
                    <ComboBoxItem Content="m"/>
                    <ComboBoxItem Content="m²"/>
                    <ComboBoxItem Content="kg"/>
                </ComboBox>

                <!-- Einzelpreis (Netto) -->
                <TextBlock Text="Einzelpreis (Netto) *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="SinglePriceNetTextBox" 
                         Height="35" 
                         Margin="0,0,0,15"
                         Text="0,00"
                         VerticalContentAlignment="Center"
                         TextChanged="Price_TextChanged"/>

                <!-- Steuerinfo Banner -->
                <Border x:Name="VatInfoBorder" 
                        Padding="10" CornerRadius="5" Margin="0,0,0,15" 
                        Visibility="Collapsed">
                    <TextBlock x:Name="VatInfoTextBlock" 
                               FontSize="12" TextWrapping="Wrap" Foreground="White" FontWeight="SemiBold"/>
                </Border>

                <!-- MwSt % -->
                <TextBlock Text="Mehrwertsteuer %" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <ComboBox x:Name="VatPercentComboBox" 
                          Height="35" 
                          Margin="0,0,0,15"
                          SelectionChanged="VatPercent_SelectionChanged">
                    <ComboBoxItem Content="19% (Standard)" Tag="19" IsSelected="True"/>
                    <ComboBoxItem Content="7% (Ermäßigt)" Tag="7"/>
                    <ComboBoxItem Content="0% (Steuerfrei / Reverse Charge / Export)" Tag="0"/>
                </ComboBox>

                <!-- Gesamtpreis Vorschau -->
                <Border Background="#F0F8FF" Padding="15" CornerRadius="5" Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="Vorschau" FontWeight="Bold" Margin="0,0,0,10" Foreground="{StaticResource PrimaryBrush}"/>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Nettobetrag:" Margin="0,2"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="PreviewNetTextBlock" Text="0,00 €" FontWeight="SemiBold" Margin="10,2,0,2" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="MwSt:" Margin="0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="PreviewVatTextBlock" Text="0,00 €" FontWeight="SemiBold" Margin="10,2,0,2" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Bruttobetrag:" FontWeight="Bold" Margin="0,5,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="PreviewGrossTextBlock" Text="0,00 €" FontWeight="Bold" Margin="10,5,0,0" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="Abbrechen"
                    Width="120"
                    Height="40"
                    Margin="0,0,10,0"
                    Click="Cancel_Click"
                    Background="#f44336"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    FontWeight="SemiBold"/>
            <Button x:Name="AddButton"
                    Content="✓ Hinzufügen"
                    Width="120"
                    Height="40"
                    Click="Add_Click"
                    Background="#4CAF50"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</Window>
