<Window x:Class="Projektsoftware.Views.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🔐 Passwort erforderlich" 
        Height="220" 
        Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Icon und Titel -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="🔐" FontSize="32" VerticalAlignment="Center" Margin="0,0,15,0"/>
            <TextBlock Text="Administrator-Authentifizierung" 
                       FontSize="18" 
                       FontWeight="Bold" 
                       VerticalAlignment="Center"
                       Foreground="{StaticResource PrimaryBrush}"/>
        </StackPanel>

        <!-- Beschreibung -->
        <TextBlock Grid.Row="1" 
                   Text="Diese Aktion erfordert Administrator-Rechte.&#x0a;Bitte geben Sie das Master-Passwort ein:"
                   TextWrapping="Wrap"
                   Margin="0,0,0,15"
                   Foreground="#555"/>

        <!-- Passwort-Eingabe -->
        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Passwort:" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <PasswordBox x:Name="PasswordBox" 
                         Height="35"
                         FontSize="14"
                         PasswordChar="●"
                         KeyDown="PasswordBox_KeyDown"/>
        </StackPanel>

        <!-- Fehlermeldung -->
        <TextBlock x:Name="ErrorTextBlock" 
                   Grid.Row="3"
                   Text=""
                   Foreground="Red"
                   FontWeight="SemiBold"
                   Visibility="Collapsed"
                   Margin="0,5,0,0"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">
            <Button Content="Abbrechen" 
                    Width="100" 
                    Height="35"
                    Margin="0,0,10,0"
                    Click="Cancel_Click"
                    Style="{StaticResource ModernButton}"/>
            <Button Content="✓ Bestätigen" 
                    Width="120" 
                    Height="35"
                    Click="Confirm_Click"
                    Background="{StaticResource PrimaryBrush}"
                    Foreground="White"
                    FontWeight="SemiBold"
                    Style="{StaticResource ModernButton}"/>
        </StackPanel>
    </Grid>
</Window>
