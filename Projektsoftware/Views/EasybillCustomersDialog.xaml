<Window x:Class="Projektsoftware.Views.EasybillCustomersDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Easybill Kundenverwaltung" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Background="#1976D2" Margin="0,0,0,10">
            <TextBlock Text="📊 Easybill Kundenverwaltung" FontSize="20" FontWeight="Bold" Foreground="White" Margin="15"/>
            <TextBlock Text="Synchronisieren Sie Ihre Kunden mit Easybill" FontSize="12" Foreground="#E3F2FD" Margin="15,0,15,15"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button Content="Schließen" Width="100" Height="35" Click="Close_Click"
                    Background="#9E9E9E" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
        </StackPanel>

        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="🔄 Kunden laden" 
                        Padding="12,8"
                        Margin="0,0,10,0"
                        Click="LoadCustomers_Click"
                        Background="#4CAF50"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand"/>
                
                <Button Content="➕ Neuer Kunde" 
                        Padding="12,8"
                        Margin="0,0,10,0"
                        Click="AddCustomer_Click"
                        Background="#2196F3"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand"/>

                <TextBox x:Name="SearchBox"
                         Width="250"
                         Height="35"
                         Margin="10,0,0,0"
                         VerticalContentAlignment="Center"
                         TextChanged="Search_TextChanged"
                         GotFocus="SearchBox_GotFocus"
                         LostFocus="SearchBox_LostFocus"
                         Foreground="Gray"
                         Text="Suchen..."/>

                <TextBlock x:Name="StatusText" 
                           Margin="20,0,0,0"
                           VerticalAlignment="Center"
                           FontWeight="Bold"/>
            </StackPanel>

            <DataGrid x:Name="CustomersDataGrid"
                      Grid.Row="1"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      SelectionMode="Single"
                      MouseDoubleClick="CustomersDataGrid_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Nummer" Binding="{Binding Number}" Width="100" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Name/Firma" Binding="{Binding DisplayName}" Width="*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="E-Mail" Binding="{Binding Email}" Width="200" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Telefon" Binding="{Binding Phone1}" Width="120" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Stadt" Binding="{Binding City}" Width="120" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Land" Binding="{Binding Country}" Width="80" IsReadOnly="True"/>
                    <DataGridTemplateColumn Header="Aktionen" Width="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Bearbeiten"
                                            Margin="2"
                                            Padding="8,4"
                                            Click="EditCustomer_Click"
                                            Background="#FF9800"
                                            Foreground="White"
                                            BorderThickness="0"/>
                                    <Button Content="Löschen"
                                            Margin="2"
                                            Padding="8,4"
                                            Click="DeleteCustomer_Click"
                                            Background="#f44336"
                                            Foreground="White"
                                            BorderThickness="0"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </DockPanel>
</Window>
