<Window x:Class="Projektsoftware.Views.CreateInvoiceFromProjectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rechnung aus Projekt erstellen"
        Height="650" Width="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock x:Name="HeaderTextBlock" Grid.Row="0" Text="Rechnung erstellen" 
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Projekt-Info -->
        <Border Grid.Row="1" BorderBrush="#E0E0E0" BorderThickness="1" 
                Padding="15" Margin="0,0,0,15" Background="#F9F9F9">
            <StackPanel>
                <TextBlock Text="Projekt" FontWeight="Bold" FontSize="12" Foreground="#666" Margin="0,0,0,5"/>
                <TextBlock x:Name="ProjectNameTextBlock" FontSize="16" FontWeight="SemiBold"/>

                <TextBlock Text="Zeiteinträge" FontWeight="Bold" FontSize="12" Foreground="#666" Margin="0,10,0,5"/>
                <TextBlock x:Name="TotalHoursTextBlock" FontSize="14"/>
            </StackPanel>
        </Border>

        <!-- Stundensatz -->
        <StackPanel Grid.Row="2" Margin="0,0,0,15">
            <TextBlock Text="Stundensatz (€/h) *" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="HourlyRateTextBox" Text="120,00" TextChanged="HourlyRate_TextChanged"/>
        </StackPanel>

        <!-- Vorschau -->
        <Border Grid.Row="3" BorderBrush="#2196F3" BorderThickness="2" 
                Padding="15" Margin="0,0,0,10" Background="#E3F2FD">
            <StackPanel>
                <TextBlock Text="Vorschau" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                <TextBlock x:Name="PreviewTextBlock" FontSize="13" LineHeight="20"/>
            </StackPanel>
        </Border>

        <!-- Steuerinfo -->
        <Border x:Name="VatInfoBorder" Grid.Row="4" 
                Padding="10" CornerRadius="5" Margin="0,0,0,10"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock x:Name="VatInfoTextBlock" 
                           FontSize="12" TextWrapping="Wrap" Foreground="White" FontWeight="SemiBold"/>
                <TextBlock x:Name="VatDetailTextBlock" 
                           FontSize="11" TextWrapping="Wrap" Foreground="#FFFFFFCC" Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <!-- Optionen -->
        <StackPanel Grid.Row="5" Margin="0,0,0,15">
            <CheckBox x:Name="GroupByActivityCheckBox" Content="Nach Aktivität gruppieren" 
                      Margin="0,0,0,10" IsChecked="False"/>

            <!-- Zahlungsziel (nur für Rechnungen) -->
            <StackPanel x:Name="DueInDaysPanel" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Zahlungsziel (Tage):" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox x:Name="DueInDaysTextBox" Text="14" Width="80"/>
            </StackPanel>

            <!-- Gültigkeit (nur für Angebote) -->
            <StackPanel x:Name="ValidityPanel" Orientation="Horizontal" Margin="0,0,0,10" Visibility="Collapsed">
                <TextBlock Text="Gültigkeit (Tage):" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox x:Name="ValidityDaysTextBox" Text="30" Width="80"/>
            </StackPanel>
        </StackPanel>

        <!-- Einleitungstext -->
        <StackPanel Grid.Row="6" Margin="0,0,0,15">
            <TextBlock x:Name="DocumentTypeTextBlock" Text="Rechnung" FontWeight="SemiBold" Margin="0,0,0,5" Visibility="Collapsed"/>
            <TextBlock Text="Einleitungstext (optional)" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="TextTextBox" Height="80" TextWrapping="Wrap" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"/>

            <!-- Als Entwurf -->
            <CheckBox x:Name="IsDraftCheckBox" 
                      Content="Als Entwurf speichern"
                      IsChecked="False"
                      Margin="0,10,0,0"
                      FontWeight="SemiBold"/>
        </StackPanel>

        <!-- Status -->
        <TextBlock x:Name="StatusTextBlock" Grid.Row="7" Text="Bereit" 
                   FontSize="11" Foreground="#666" HorizontalAlignment="Left" VerticalAlignment="Bottom"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Abbrechen" Width="100" Height="35" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button x:Name="CreateButton" Content="Rechnung erstellen" Width="150" Height="35" 
                    Click="Create_Click" Style="{StaticResource PrimaryButton}"/>
        </StackPanel>
    </Grid>
</Window>
