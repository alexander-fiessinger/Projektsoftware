<Window x:Class="Projektsoftware.Views.SalesAppointmentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sales-Termin" Height="560" Width="520"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F8F9FA">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock x:Name="TitleText" Grid.Row="0" Text="📅 Neuer Sales-Termin"
                   FontSize="18" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,20"/>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Betreff *" FontSize="12" Foreground="#475569" Margin="0,0,0,4"/>
                <TextBox x:Name="TitleBox" Height="36" Padding="8,0" FontSize="13" Margin="0,0,0,12"
                         BorderBrush="#CBD5E1" BorderThickness="1"/>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Datum *" FontSize="12" Foreground="#475569" Margin="0,0,0,4"/>
                        <DatePicker x:Name="DatePicker" Height="36" FontSize="13" BorderBrush="#CBD5E1" BorderThickness="1"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Von – Bis (HH:mm) *" FontSize="12" Foreground="#475569" Margin="0,0,0,4"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="StartTimeBox" Grid.Column="0" Height="36" Padding="8,0"
                                     FontSize="13" Text="09:00" BorderBrush="#CBD5E1" BorderThickness="1"/>
                            <TextBlock Grid.Column="1" Text="–" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <TextBox x:Name="EndTimeBox" Grid.Column="2" Height="36" Padding="8,0"
                                     FontSize="13" Text="10:00" BorderBrush="#CBD5E1" BorderThickness="1"/>
                        </Grid>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Kontaktperson *" FontSize="12" Foreground="#475569" Margin="0,0,0,4"/>
                <TextBox x:Name="ContactNameBox" Height="36" Padding="8,0" FontSize="13" Margin="0,0,0,12"
                         BorderBrush="#CBD5E1" BorderThickness="1"/>

                <TextBlock Text="E-Mail *" FontSize="12" Foreground="#475569" Margin="0,0,0,4"/>
                <TextBox x:Name="ContactEmailBox" Height="36" Padding="8,0" FontSize="13" Margin="0,0,0,12"
                         BorderBrush="#CBD5E1" BorderThickness="1"/>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Unternehmen" FontSize="12" Foreground="#475569" Margin="0,0,0,4"/>
                        <TextBox x:Name="CompanyBox" Height="36" Padding="8,0" FontSize="13"
                                 BorderBrush="#CBD5E1" BorderThickness="1"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Telefon" FontSize="12" Foreground="#475569" Margin="0,0,0,4"/>
                        <TextBox x:Name="PhoneBox" Height="36" Padding="8,0" FontSize="13"
                                 BorderBrush="#CBD5E1" BorderThickness="1"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Ort / Meeting-Link" FontSize="12" Foreground="#475569" Margin="0,0,0,4"/>
                <TextBox x:Name="LocationBox" Height="36" Padding="8,0" FontSize="13" Margin="0,0,0,12"
                         BorderBrush="#CBD5E1" BorderThickness="1"/>

                <TextBlock Text="Notizen" FontSize="12" Foreground="#475569" Margin="0,0,0,4"/>
                <TextBox x:Name="NotesBox" Height="80" Padding="8,6" FontSize="13" TextWrapping="Wrap"
                         AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                         BorderBrush="#CBD5E1" BorderThickness="1" Margin="0,0,0,12"/>

                <CheckBox x:Name="SendInviteCheck" Content="📧 Einladungs-E-Mail mit Kalender-RSVP senden"
                          FontSize="13" IsChecked="True" Margin="0,0,0,4"/>
                <CheckBox x:Name="CreateWebexCheck" Content="🎦 Webex-Meeting automatisch erstellen"
                          FontSize="13" IsChecked="True" Margin="16,0,0,0"
                          ToolTip="Erstellt ein Webex-Meeting und fügt den Join-Link in die Einladung ein. Erfordert eine aktive Webex-Konfiguration."/>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Abbrechen" Width="100" Height="36" Margin="0,0,8,0" IsCancel="True"
                    Click="Cancel_Click"/>
            <Button x:Name="SaveBtn" Content="Speichern" Width="120" Height="36"
                    Background="#2563EB" Foreground="White" BorderThickness="0"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>