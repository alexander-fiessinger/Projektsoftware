<Window x:Class="Projektsoftware.Views.CustomersListDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kundenverwaltung" Height="700" Width="1300"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="👥 Kundenverwaltung"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="{StaticResource PrimaryBrush}"
                   Margin="0,0,0,20"/>

        <!-- Toolbar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <Button Content="+ Neuer Kunde"
                    Width="140"
                    Height="36"
                    Margin="0,0,8,0"
                    Click="AddCustomer_Click"
                    Background="{StaticResource SuccessBrush}"
                    Foreground="White"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Cursor="Hand"/>

            <Button Content="🔄 Aktualisieren"
                    Width="140"
                    Height="36"
                    Margin="0,0,8,0"
                    Click="Refresh_Click"
                    Background="{StaticResource NeutralBrush}"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"/>

            <Button Content="📥 Von Easybill importieren"
                    Width="200"
                    Height="36"
                    Click="ImportFromEasybill_Click"
                    Background="{StaticResource NeutralBrush}"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"/>
        </StackPanel>

        <!-- Data Grid -->
        <DataGrid x:Name="CustomersDataGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  MouseDoubleClick="CustomersDataGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" IsReadOnly="True"/>
                <DataGridTextColumn Header="Anzeigename" Binding="{Binding DisplayName}" Width="*" IsReadOnly="True"/>
                <DataGridTextColumn Header="E-Mail" Binding="{Binding Email}" Width="200" IsReadOnly="True"/>
                <DataGridTextColumn Header="Telefon" Binding="{Binding Phone}" Width="120" IsReadOnly="True"/>
                <DataGridTextColumn Header="Stadt" Binding="{Binding City}" Width="120" IsReadOnly="True"/>
                <DataGridTextColumn Header="Sync-Status" Binding="{Binding SyncStatus}" Width="200" IsReadOnly="True"/>
                <DataGridTemplateColumn Header="Aktionen" Width="310">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="✏️" ToolTip="Bearbeiten"
                                         Margin="2" Padding="8,3"
                                        Click="EditCustomer_Click"
                                        Style="{StaticResource ActionButton}"
                                        Foreground="{StaticResource PrimaryBrush}"/>
                                <Button Content="📄" ToolTip="Dokumente"
                                         Margin="2" Padding="8,3"
                                        Click="DocumentsCustomer_Click"
                                        Style="{StaticResource ActionButton}"/>
                                <Button Content="🔄" ToolTip="Zu Easybill synchronisieren"
                                         Margin="2" Padding="8,3"
                                        Click="SyncCustomer_Click"
                                        Style="{StaticResource ActionButton}"/>
                                <Button Content="🗑️" ToolTip="Löschen"
                                         Margin="2" Padding="8,3"
                                        Click="DeleteCustomer_Click"
                                        Style="{StaticResource DangerActionButton}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status Bar -->
        <Border Grid.Row="3" 
                Background="#F5F5F5" 
                BorderBrush="#CCCCCC" 
                BorderThickness="0,1,0,0"
                Padding="10"
                Margin="0,15,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="StatusTextBlock"
                           Text="Bereit"
                           VerticalAlignment="Center"
                           Margin="0,0,20,0"/>
                <TextBlock x:Name="CountTextBlock"
                           Text="0 Kunden geladen"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
