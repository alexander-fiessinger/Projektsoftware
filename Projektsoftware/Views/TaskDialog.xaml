<Window x:Class="Projektsoftware.Views.TaskDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aufgabe" Height="600" Width="550"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button Content="Speichern" Width="100" Height="35" Margin="0,0,10,0" Click="Save_Click" 
                    Background="#4CAF50" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
            <Button Content="Abbrechen" Width="100" Height="35" Click="Cancel_Click"
                    Background="#9E9E9E" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                <TextBlock Text="Projekt *" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox x:Name="ProjectComboBox" 
                          Height="30" 
                          Margin="0,0,0,15" 
                          DisplayMemberPath="Name"/>

                <TextBlock Text="Titel *" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="TitleTextBox" Height="30" Margin="0,0,0,15"/>

                <TextBlock Text="Beschreibung" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="DescriptionTextBox" Height="80" Margin="0,0,0,15" TextWrapping="Wrap" AcceptsReturn="True"/>

                <TextBlock Text="Kunde" FontWeight="Bold" Margin="0,0,0,5"/>
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox x:Name="CustomerComboBox" 
                              Grid.Column="0"
                              Height="30"
                              IsEditable="True"
                              DisplayMemberPath="DisplayName"/>

                    <Button Content="📋" 
                            Grid.Column="2"
                            Width="35"
                            Height="30"
                            Click="OpenEasybillCustomers_Click"
                            Background="#2196F3" 
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="Easybill-Kunden verwalten"/>
                </Grid>

                <TextBlock Text="Zugewiesen an" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox x:Name="AssignedToComboBox" 
                          Height="30" 
                          Margin="0,0,0,15" 
                          IsEditable="True" 
                          DisplayMemberPath="FullName"/>

                <TextBlock Text="Status *" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox x:Name="StatusComboBox" Height="30" Margin="0,0,0,15"/>

                <TextBlock Text="Priorität *" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox x:Name="PriorityComboBox" Height="30" Margin="0,0,0,15"/>

                <TextBlock Text="Fälligkeitsdatum" FontWeight="Bold" Margin="0,0,0,5"/>
                <DatePicker x:Name="DueDatePicker" Height="30" Margin="0,0,0,15"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Geschätzte Stunden" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="EstimatedHoursTextBox" Height="30" Text="0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Tatsächliche Stunden" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="ActualHoursTextBox" Height="30" Text="0"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
