<Window x:Class="Projektsoftware.Views.EwsSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Exchange Posteingang – EWS-Konfiguration" Height="700" Width="500"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <DockPanel>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button Content="Verbindung testen" Width="140" Height="35" Margin="0,0,10,0" Click="TestConnection_Click"
                    Background="#FF9800" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
            <Button Content="Speichern" Width="100" Height="35" Margin="0,0,10,0" Click="Save_Click"
                    Background="#4CAF50" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
            <Button Content="Abbrechen" Width="100" Height="35" Click="Cancel_Click"
                    Background="#9E9E9E" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
        </StackPanel>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="25">
                <TextBlock Text="📬 Exchange Posteingang (EWS)" FontSize="18" FontWeight="Bold" Margin="0,0,0,25"/>

                <CheckBox x:Name="EnableEwsCheckBox" Content="Exchange Posteingang aktivieren" Margin="0,0,0,15"/>

                <TextBlock Text="EWS-URL *" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="EwsUrlTextBox" Height="32" Margin="0,0,0,4"
                         ToolTip="dogado: https://outlook.hex2013.com/EWS/exchange.asmx"/>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,15" Foreground="#757575" FontSize="11"
                           Text="dogado Hosted Exchange: https://outlook.hex2013.com/EWS/exchange.asmx"/>

                <TextBlock Text="E-Mail / Login-ID *" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="EwsEmailTextBox" Height="32" Margin="0,0,0,15"/>

                <TextBlock Text="Passwort *" FontWeight="Bold" Margin="0,0,0,5"/>
                <PasswordBox x:Name="EwsPasswordBox" Height="32" Margin="0,0,0,15"/>

                <CheckBox x:Name="AcceptInvalidCertificatesCheckBox" Margin="0,0,0,4"
                          Content="SSL-Zertifikatsfehler ignorieren"/>
                <TextBlock TextWrapping="Wrap" Margin="20,0,0,20" Foreground="#757575" FontSize="11"
                           Text="Aktivieren wenn der Servername nicht mit dem SSL-Zertifikat übereinstimmt."/>

                <Separator Margin="0,5,0,15"/>
                <TextBlock Text="Erweitert (optional)" FontSize="13" FontWeight="Bold" Margin="0,0,0,10"/>

                <CheckBox x:Name="UseWindowsAuthCheckBox" Margin="0,0,0,4"
                          Content="Windows-Authentifizierung (NTLM/Kerberos)"/>
                <TextBlock TextWrapping="Wrap" Margin="20,0,0,15" Foreground="#757575" FontSize="11"
                           Text="Nur für domänenverbundene Exchange-Server. Für dogado deaktiviert lassen."/>

                <TextBlock Text="EWS-Benutzername (optional)" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="EwsUsernameTextBox" Height="32" Margin="0,0,0,4"
                         ToolTip="Leer = E-Mail / Login-ID wird verwendet."/>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,15" Foreground="#757575" FontSize="11"
                           Text="Nur ausfüllen wenn EWS einen abweichenden Benutzernamen erfordert."/>

                <TextBlock Text="NTLM-Domäne (optional)" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="EwsDomainTextBox" Height="32" Margin="0,0,0,4"
                         ToolTip="dogado Hosted Exchange: X13"/>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,20" Foreground="#757575" FontSize="11"
                           Text="Nur zusammen mit EWS-Benutzername verwenden. Bei UPN/E-Mail-Login leer lassen."/>

                <CheckBox x:Name="UseBasicAuthCheckBox" Margin="0,0,0,4"
                          Content="Nur Basic Auth verwenden (kein NTLM/Negotiate)"/>
                <TextBlock TextWrapping="Wrap" Margin="20,0,0,20" Foreground="#757575" FontSize="11"
                           Text="Bei 401-Fehler: Diese Option aktivieren und erneut testen."/>

                <TextBlock x:Name="StatusTextBlock" Text="" Margin="0,5,0,0" FontWeight="Bold" TextWrapping="Wrap"/>
                <Border x:Name="SuccessPanel" Visibility="Collapsed" Background="#C8E6C9" Padding="12" Margin="0,10,0,0" CornerRadius="5">
                    <TextBlock x:Name="SuccessText" TextWrapping="Wrap" Foreground="#2E7D32"/>
                </Border>
                <Border x:Name="ErrorPanel" Visibility="Collapsed" Background="#FFCDD2" Padding="12" Margin="0,10,0,0" CornerRadius="5">
                    <TextBlock x:Name="ErrorText" TextWrapping="Wrap" Foreground="#C62828"/>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
