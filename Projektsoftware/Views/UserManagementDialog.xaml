<Window x:Class="Projektsoftware.Views.UserManagementDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="👥 Benutzerverwaltung" 
        Height="600" 
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="👥 Benutzerverwaltung" 
                       FontSize="24" 
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"/>
            <TextBlock Text="Verwalten Sie Benutzerkonten und Berechtigungen" 
                       FontSize="14"
                       Foreground="#666"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Benutzer-Liste -->
        <Border Grid.Row="1" 
                BorderBrush="#DDD" 
                BorderThickness="1" 
                CornerRadius="5"
                Background="White">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Toolbar -->
                <Border Grid.Row="0" 
                        Background="#F5F5F5" 
                        BorderBrush="#DDD"
                        BorderThickness="0,0,0,1"
                        Padding="10">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="+ Neuer Benutzer" 
                                Width="150"
                                Height="35"
                                Click="AddUser_Click"
                                Background="{StaticResource PrimaryBrush}"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"
                                FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <!-- DataGrid -->
                <DataGrid Grid.Row="1"
                          x:Name="UsersDataGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          RowHeight="50"
                          Margin="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                        <DataGridTextColumn Header="Benutzername" Binding="{Binding Username}" Width="150"/>
                        <DataGridTextColumn Header="Mitarbeiter" Binding="{Binding EmployeeName}" Width="200"/>
                        <DataGridTextColumn Header="Rolle" Binding="{Binding Role}" Width="100"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="100"/>
                        <DataGridTextColumn Header="Letzter Login" Binding="{Binding LastLogin, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}" Width="150"/>
                        <DataGridTemplateColumn Header="Aktionen" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="🔑 Passwort" 
                                                Width="90"
                                                Height="30"
                                                Margin="5,0"
                                                Click="ChangePassword_Click"
                                                Background="#FF9800"
                                                Foreground="White"
                                                BorderThickness="0"
                                                Cursor="Hand"/>
                                        <Button Content="✏️ Bearbeiten" 
                                                Width="90"
                                                Height="30"
                                                Margin="5,0"
                                                Click="EditUser_Click"
                                                Background="#2196F3"
                                                Foreground="White"
                                                BorderThickness="0"
                                                Cursor="Hand"/>
                                        <Button Content="🗑 Löschen" 
                                                Width="90"
                                                Height="30"
                                                Margin="5,0"
                                                Click="DeleteUser_Click"
                                                Background="#F44336"
                                                Foreground="White"
                                                BorderThickness="0"
                                                Cursor="Hand"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Footer -->
        <Button Grid.Row="2"
                Content="Schließen"
                Width="120"
                Height="40"
                HorizontalAlignment="Right"
                Margin="0,15,0,0"
                Click="Close_Click"
                Background="#9E9E9E"
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"/>
    </Grid>
</Window>
