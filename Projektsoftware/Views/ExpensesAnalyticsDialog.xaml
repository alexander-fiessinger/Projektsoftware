<Window x:Class="Projektsoftware.Views.ExpensesAnalyticsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ausgaben-Auswertung" Height="560" Width="900"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Monatsausgaben nach Kategorie" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="1" x:Name="TotalText" FontSize="14" Foreground="#444" Margin="0,0,0,10"/>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="BarsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,4" Height="28">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="130"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Label}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            <Border Grid.Column="1" Background="#F0F0F0" CornerRadius="3">
                                <Rectangle HorizontalAlignment="Left" Fill="#4A90E2" Width="{Binding BarWidth}" Height="20" RadiusX="3" RadiusY="3"/>
                            </Border>
                            <TextBlock Grid.Column="2" Text="{Binding ValueText}" VerticalAlignment="Center" TextAlignment="Right" Margin="8,0"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Aktualisieren" Width="120" Click="Refresh_Click"/>
            <Button Content="Schließen" Width="100" Margin="8,0,0,0" Click="Close_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
