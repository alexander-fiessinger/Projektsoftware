<Window x:Class="Projektsoftware.Views.KpiDashboardDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KPI-Dashboard" Height="480" Width="720"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Kennzahlen-Übersicht"
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>

        <UniformGrid Grid.Row="1" Columns="3" Rows="2" Margin="0,0,0,12">
            <Border BorderBrush="#DDD" BorderThickness="1" Margin="4" Padding="12" CornerRadius="6">
                <StackPanel>
                    <TextBlock Text="Offene Tickets" FontSize="12" Foreground="#666"/>
                    <TextBlock x:Name="OpenTicketsText" Text="–" FontSize="28" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border BorderBrush="#DDD" BorderThickness="1" Margin="4" Padding="12" CornerRadius="6">
                <StackPanel>
                    <TextBlock Text="Aktive Projekte" FontSize="12" Foreground="#666"/>
                    <TextBlock x:Name="ActiveProjectsText" Text="–" FontSize="28" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border BorderBrush="#DDD" BorderThickness="1" Margin="4" Padding="12" CornerRadius="6">
                <StackPanel>
                    <TextBlock Text="Lead-Conversion" FontSize="12" Foreground="#666"/>
                    <TextBlock x:Name="LeadConversionText" Text="–" FontSize="28" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border BorderBrush="#DDD" BorderThickness="1" Margin="4" Padding="12" CornerRadius="6">
                <StackPanel>
                    <TextBlock Text="Überfällige Aufgaben" FontSize="12" Foreground="#666"/>
                    <TextBlock x:Name="OverdueTasksText" Text="–" FontSize="28" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border BorderBrush="#67C23A" BorderThickness="1" Margin="4" Padding="12" CornerRadius="6">
                <StackPanel>
                    <TextBlock Text="Umsatz (Monat)" FontSize="12" Foreground="#666"/>
                    <TextBlock x:Name="MonthRevenueText" Text="–" FontSize="22" FontWeight="Bold" Foreground="#67C23A"/>
                </StackPanel>
            </Border>
            <Border BorderBrush="#4A90E2" BorderThickness="1" Margin="4" Padding="12" CornerRadius="6">
                <StackPanel>
                    <TextBlock Text="Umsatz (gesamt)" FontSize="12" Foreground="#666"/>
                    <TextBlock x:Name="TotalRevenueText" Text="–" FontSize="22" FontWeight="Bold" Foreground="#4A90E2"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <GroupBox Grid.Row="2" Header="Fälligkeitswarnungen">
            <DataGrid x:Name="WarningsGrid" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Typ" Binding="{Binding EntityType}" Width="100"/>
                    <DataGridTextColumn Header="Titel" Binding="{Binding Title}" Width="*"/>
                    <DataGridTextColumn Header="Fällig am" Binding="{Binding DueDate, StringFormat={}{0:dd.MM.yyyy}}" Width="100"/>
                    <DataGridTextColumn Header="Warnstufe" Binding="{Binding WarningLevel}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Aktualisieren" Width="120" Click="Refresh_Click"/>
            <Button Content="Schließen" Width="100" Margin="8,0,0,0" Click="Close_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
