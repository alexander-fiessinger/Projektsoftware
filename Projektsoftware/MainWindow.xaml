<Window x:Class="Projektsoftware.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Projektsoftware"
        xmlns:views="clr-namespace:Projektsoftware.Views"
        xmlns:converters="clr-namespace:Projektsoftware.Converters"
        mc:Ignorable="d"
        Title="Projektierungssoftware Professional" Height="950" Width="1600"
        MinHeight="700" MinWidth="1200"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">
    <Window.Resources>
        <converters:EuroCurrencyConverter x:Key="EuroCurrencyConverter"/>
        <converters:TimeSpanToHoursConverter x:Key="TimeSpanToHoursConverter"/>
    </Window.Resources>
    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{x:Static ApplicationCommands.Find}" />
        <KeyBinding Gesture="Ctrl+F" Command="{x:Static ApplicationCommands.Find}" />
        <KeyBinding Gesture="Ctrl+E" Command="{x:Static ApplicationCommands.SaveAs}" />
        <KeyBinding Gesture="Ctrl+N" Command="{x:Static ApplicationCommands.New}" />
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="{x:Static ApplicationCommands.Find}" Executed="GlobalSearch_Executed" />
        <CommandBinding Command="{x:Static ApplicationCommands.SaveAs}" Executed="CsvExport_Executed" />
        <CommandBinding Command="{x:Static ApplicationCommands.New}" Executed="QuickCreate_Executed" />
    </Window.CommandBindings>
    <DockPanel>

        <!-- StatusBar -->
        <StatusBar DockPanel.Dock="Bottom" Background="#FAFBFC" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Height="28">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="👤" Margin="0,0,4,0"/>
                    <TextBlock x:Name="StatusBarUser" Text="–" FontSize="11" Foreground="#475569"/>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🗄" Margin="0,0,4,0"/>
                    <TextBlock x:Name="StatusBarDb" Text="Datenbank: verbunden" FontSize="11" Foreground="#16A34A"/>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="StatusBarVersion" Text="v1.0.42" FontSize="11" Foreground="#64748B"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="StatusBarClock" Text="00:00" FontSize="11" Foreground="#475569" FontFamily="Consolas"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Simplified Menu -->
        <Menu DockPanel.Dock="Top" Style="{StaticResource ModernMenu}">
            <MenuItem Header="_Datei" Style="{StaticResource ModernMenuItem}">
                <MenuItem Header="Beenden" Click="Exit_Click" Style="{StaticResource ModernMenuItem}"/>
            </MenuItem>
            <MenuItem x:Name="MenuEinstellungen" Header="_Einstellungen" Style="{StaticResource ModernMenuItem}">
                <MenuItem Header="Benutzerverwaltung" Click="ManageUsers_Click" Style="{StaticResource ModernMenuItem}"/>
                <MenuItem Header="Passwort ändern" Click="ChangeOwnPassword_Click" Style="{StaticResource ModernMenuItem}"/>
                <Separator/>
                <MenuItem Header="Support-Tickets" Click="ManageTickets_Click" Style="{StaticResource ModernMenuItem}"/>
                <MenuItem Header="Ticket-Dashboard" Click="ShowTicketDashboard_Click" Style="{StaticResource ModernMenuItem}"/>
                <MenuItem Header="Ticket-SMTP E-Mail" Style="{StaticResource ModernMenuItem}">
                    <MenuItem Header="Konfiguration" Click="ConfigureTicketSmtp_Click" Style="{StaticResource ModernMenuItem}"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Datenbank" Style="{StaticResource ModernMenuItem}">
                    <MenuItem Header="Verbindung konfigurieren" Click="ConfigureDatabase_Click" Style="{StaticResource ModernMenuItem}"/>
                    <MenuItem Header="Diagnose" Click="DiagnoseConnection_Click" Style="{StaticResource ModernMenuItem}"/>
                    <MenuItem Header="Backup erstellen" Click="DatabaseBackup_Click" Style="{StaticResource ModernMenuItem}"/>
                    <MenuItem Header="Datenbank zurücksetzen" Click="ResetDatabase_Click" Style="{StaticResource ModernMenuItem}" Foreground="Red"/>
                </MenuItem>
                <MenuItem Header="Webex" Style="{StaticResource ModernMenuItem}">
                    <MenuItem Header="Konfiguration" Click="ConfigureWebex_Click" Style="{StaticResource ModernMenuItem}"/>
                </MenuItem>
                <MenuItem Header="SMTP E-Mail" Style="{StaticResource ModernMenuItem}">
                    <MenuItem Header="Konfiguration" Click="ConfigureExchange_Click" Style="{StaticResource ModernMenuItem}"/>
                </MenuItem>
<MenuItem Header="Exchange Posteingang" Style="{StaticResource ModernMenuItem}">
    <MenuItem Header="EWS-Konfiguration" Click="ConfigureEws_Click" Style="{StaticResource ModernMenuItem}"/>
    <MenuItem Header="Posteingang öffnen" Click="OpenExchangeInbox_Click" Style="{StaticResource ModernMenuItem}"/>
</MenuItem>
                <MenuItem Header="Easybill" Style="{StaticResource ModernMenuItem}">
                    <MenuItem Header="Konfiguration" Click="ConfigureEasybill_Click" Style="{StaticResource ModernMenuItem}"/>
                    <MenuItem Header="Dokumente anzeigen" Click="ShowEasybillDocuments_Click" Style="{StaticResource ModernMenuItem}"/>
                    <MenuItem Header="Produkte anzeigen" Click="ShowEasybillProducts_Click" Style="{StaticResource ModernMenuItem}"/>
                    <MenuItem Header="Zeiten exportieren" Click="ExportTimesToEasybill_Click" Style="{StaticResource ModernMenuItem}"/>
                </MenuItem>
                <MenuItem Header="Updates" Style="{StaticResource ModernMenuItem}">
                    <MenuItem Header="Nach Updates suchen" Click="CheckForUpdates_Click" Style="{StaticResource ModernMenuItem}"/>
                </MenuItem>
                <MenuItem Header="📋 _Audit-Log" Click="AuditLog_Click" Style="{StaticResource ModernMenuItem}"/>
                <Separator/>
                <MenuItem x:Name="DarkModeMenuItem" Header="🌙 Dark Mode" Click="ToggleDarkMode_Click" Style="{StaticResource ModernMenuItem}" IsCheckable="True"/>
                <Separator/>
                <MenuItem Header="Abmelden" Click="Logout_Click" Style="{StaticResource ModernMenuItem}" Foreground="Orange"/>
            </MenuItem>
            <MenuItem Header="📦 _Produkte" Style="{StaticResource ModernMenuItem}" Click="ShowEasybillProducts_Click"/>
            <MenuItem Header="📄 _Dokumente" Style="{StaticResource ModernMenuItem}">
                <MenuItem Header="📄 Rechnung erstellen" Click="CreateDocument_Invoice_Click" Style="{StaticResource ModernMenuItem}"/>
                <MenuItem Header="🧾 Proforma-Rechnung erstellen" Click="CreateDocument_Proforma_Click" Style="{StaticResource ModernMenuItem}"/>
                <MenuItem Header="📋 Angebot erstellen" Click="CreateDocument_Offer_Click" Style="{StaticResource ModernMenuItem}"/>
                <MenuItem Header="✓ Auftragsbestätigung erstellen" Click="CreateDocument_OrderConfirmation_Click" Style="{StaticResource ModernMenuItem}"/>
                <MenuItem Header="📦 Lieferschein erstellen" Click="CreateDocument_DeliveryNote_Click" Style="{StaticResource ModernMenuItem}"/>
                <Separator/>
                <MenuItem Header="⚠️ Mahnung erstellen" Click="CreateDocument_Dunning_Click" Style="{StaticResource ModernMenuItem}"/>
                <MenuItem Header="💳 Gutschrift erstellen" Click="CreateDocument_CreditNote_Click" Style="{StaticResource ModernMenuItem}"/>
                <Separator/>
                <MenuItem Header="📝 Vertrag erstellen" Click="CreateContract_Click" Style="{StaticResource ModernMenuItem}"/>
            </MenuItem>
            <MenuItem Header="_Hilfe" Style="{StaticResource ModernMenuItem}">
                <MenuItem Header="Über" Click="About_Click" Style="{StaticResource ModernMenuItem}"/>
            </MenuItem>
            <MenuItem Header="📤 _Export" Style="{StaticResource ModernMenuItem}">
                <MenuItem Header="Kunden als CSV" Click="ExportCustomersCsv_Click" Style="{StaticResource ModernMenuItem}"/>
                <MenuItem Header="Projekte als CSV" Click="ExportProjectsCsv_Click" Style="{StaticResource ModernMenuItem}"/>
                <MenuItem Header="Zeiterfassung als CSV" Click="ExportTimeEntriesCsv_Click" Style="{StaticResource ModernMenuItem}"/>
                <MenuItem Header="Aufgaben als CSV" Click="ExportTasksCsv_Click" Style="{StaticResource ModernMenuItem}"/>
                <MenuItem Header="Mitarbeiter als CSV" Click="ExportEmployeesCsv_Click" Style="{StaticResource ModernMenuItem}"/>
            </MenuItem>
        </Menu>

        <!-- Notification toolbar -->
        <Border DockPanel.Dock="Top"
                Background="#F5F5F5"
                BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1"
                Height="36">
            <DockPanel Margin="10,0">
                <Button x:Name="NotificationBellButton"
                        DockPanel.Dock="Right"
                        Click="NotificationBell_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="Benachrichtigungen anzeigen"
                        Padding="6,2">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔔" FontSize="16" VerticalAlignment="Center"/>
                        <Border x:Name="NotificationBadge"
                                Background="#F44336"
                                CornerRadius="8"
                                MinWidth="18"
                                Height="18"
                                Margin="2,0,0,0"
                                Visibility="Collapsed"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="NotificationBadgeText"
                                       Text="0"
                                       Foreground="White"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="4,0"/>
                        </Border>
                    </StackPanel>
                </Button>
                <TextBlock x:Name="NotificationStatusText"
                           DockPanel.Dock="Right"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="#666"
                           Margin="0,0,8,0"/>
                <!-- Globale Suche -->
                <Grid DockPanel.Dock="Left" Width="280" Margin="0,3">
                    <TextBox x:Name="GlobalSearchBox"
                             Height="28"
                             VerticalContentAlignment="Center"
                             Padding="24,0,8,0"
                             FontSize="12"
                             KeyDown="GlobalSearchBox_KeyDown"
                             ToolTip="Globale Suche (Strg+F)"/>
                    <TextBlock Text="🔍 Suche…"
                               IsHitTestVisible="False"
                               VerticalAlignment="Center"
                               Margin="6,0,0,0"
                               Foreground="Gray"
                               FontSize="12"
                               FontStyle="Italic">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=GlobalSearchBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </DockPanel>
        </Border>

        <!-- Timer Leiste -->
        <Border DockPanel.Dock="Top"
                Background="#F1F8E9"
                BorderBrush="#C8E6C9"
                BorderThickness="0,0,0,1"
                Height="46">
            <DockPanel Margin="10,0" VerticalAlignment="Center">
                <Button x:Name="TimerStopBtn"
                        DockPanel.Dock="Right"
                        Content="⏹ Stoppen"
                        Click="TimerStop_Click"
                        Visibility="Collapsed"
                        Background="#F44336" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Padding="10,4" Margin="4,0" Height="30"/>
                <Button x:Name="TimerStartBtn"
                        DockPanel.Dock="Right"
                        Content="▶ Starten"
                        Click="TimerStart_Click"
                        Background="#4CAF50" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Padding="10,4" Margin="4,0" Height="30"/>
                <TextBlock x:Name="TimerDisplay"
                           DockPanel.Dock="Right"
                           Text="00:00:00"
                           FontFamily="Consolas"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="#2E7D32"
                           VerticalAlignment="Center"
                           Margin="8,0"/>
                <Ellipse x:Name="TimerRunningDot"
                         DockPanel.Dock="Right"
                         Width="10" Height="10"
                         Fill="#4CAF50"
                         VerticalAlignment="Center"
                         Margin="4,0"
                         Visibility="Collapsed"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⏱ Timer:" FontWeight="SemiBold" VerticalAlignment="Center"
                               Margin="0,0,10,0" Foreground="#33691E"/>
                    <TextBlock Text="Projekt:" VerticalAlignment="Center"
                               Foreground="#555" FontSize="11" Margin="0,0,4,0"/>
                    <ComboBox x:Name="TimerProjectCombo"
                              Width="200" Height="30"
                              DisplayMemberPath="Name"
                              ItemsSource="{Binding Projects}"
                              ToolTip="Projekt auswählen"
                              Margin="0,0,12,0"/>
                    <TextBlock Text="Tätigkeit:" VerticalAlignment="Center"
                               Foreground="#555" FontSize="11" Margin="0,0,4,0"/>
                    <Grid Width="200" Height="30" Margin="0,0,12,0">
                        <TextBox x:Name="TimerActivityBox"
                                 VerticalContentAlignment="Center"
                                 ToolTip="Tätigkeit eingeben"/>
                        <TextBlock Text="z.B. Entwicklung..."
                                   IsHitTestVisible="False"
                                   Foreground="Gray"
                                   VerticalAlignment="Center"
                                   Margin="5,0,0,0"
                                   FontStyle="Italic">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=TimerActivityBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <TextBlock Text="Kunde:" VerticalAlignment="Center"
                               Foreground="#555" FontSize="11" Margin="0,0,4,0"/>
                    <ComboBox x:Name="TimerCustomerCombo"
                              Width="180" Height="30"
                              DisplayMemberPath="DisplayName"
                              ItemsSource="{Binding Customers}"
                              ToolTip="Kunde auswählen (optional)"
                              Margin="0,0,8,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main Content Area -->
        <Grid Margin="10">
        <TabControl x:Name="MainTabControl"
                     SelectedIndex="{Binding SelectedTabIndex}"
                    Style="{StaticResource ModernTabControl}">
            
            <!-- Dashboard Tab -->
            <TabItem Header="📊 Dashboard" Style="{StaticResource ModernTabItem}">
                <views:DashboardControl x:Name="DashboardControl"
                    NewProjectClicked="DashboardNewProject_Click"
                    NewTaskClicked="DashboardNewTask_Click"
                    NewCustomerClicked="DashboardNewCustomer_Click"
                    TimeTrackingClicked="DashboardTimeTracking_Click"
                    CreateOfferClicked="DashboardCreateOffer_Click"
                    CreateInvoiceClicked="DashboardCreateInvoice_Click"
                    CreateOrderConfirmationClicked="DashboardCreateOrderConfirmation_Click"
                    CreateDeliveryNoteClicked="DashboardCreateDeliveryNote_Click"
                    CreateCreditNoteClicked="DashboardCreateCreditNote_Click"
                    CreateDunningClicked="DashboardCreateDunning_Click"
                    ShowDocumentsClicked="ShowEasybillDocuments_Click"
                    ManageCustomersClicked="ManageCustomers_Click"
                    ExportTimesClicked="ExportTimesToEasybill_Click"
                    RefreshFinancialClicked="DashboardRefreshFinancial_Click"
                    ViewPurchasesClicked="DashboardViewPurchases_Click"/>
            </TabItem>

            <!-- Kunden Tab -->
            <TabItem x:Name="TabKunden" Header="👤 Kunden" Style="{StaticResource ModernTabItem}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <Button Content="+ Neuer Kunde" Style="{StaticResource ModernButton}"
                                Padding="12,6" Margin="0,0,8,0"
                                Click="AddCustomer_Click"
                                        Background="{DynamicResource SuccessBrush}" Foreground="White"/>
                        <Button Content="📥 Von Easybill importieren" Style="{StaticResource ModernButton}"
                                Padding="12,6"
                                Click="ImportCustomersFromEasybill_Click"
                                        Background="{DynamicResource NeutralBrush}" Foreground="White"/>
                    </StackPanel>
                    <DataGrid x:Name="CustomersDataGrid"
                              Grid.Row="1"
                              ItemsSource="{Binding Customers}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              MouseDoubleClick="CustomersDataGrid_MouseDoubleClick">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Bearbeiten" Click="EditCustomer_Click"/>
                                <MenuItem Header="📄 Dokumente" Click="DocumentsCustomer_Click"/>
                                <MenuItem Header="📝 Vertrag erstellen" Click="CreateContractForCustomer_Click"/>
                                <MenuItem Header="Synchronisieren" Click="SyncCustomer_Click"/>
                                <Separator/>
                                <MenuItem Header="Löschen" Click="DeleteCustomer_Click" Foreground="Red"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="2*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="E-Mail" Binding="{Binding Email}" Width="2*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Telefon" Binding="{Binding Phone}" Width="1.2*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Stadt" Binding="{Binding City}" Width="1.2*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Easybill-Status" Binding="{Binding SyncStatus}" Width="1.5*" IsReadOnly="True"/>
                            <DataGridTemplateColumn Header="Aktionen" Width="330">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Content="✏️ Bearbeiten" ToolTip="Kunde bearbeiten"
                                                    Style="{StaticResource ActionButton}"
                                                    Foreground="{DynamicResource PrimaryBrush}"
                                                    Margin="2"
                                                    Click="EditCustomer_Click"/>
                                            <Button Content="📄" ToolTip="Dokumente"
                                                    Style="{StaticResource ActionButton}"
                                                    Margin="2"
                                                    Click="DocumentsCustomer_Click"/>
                                            <Button Content="🔄" ToolTip="Zu Easybill synchronisieren"
                                                                    Style="{StaticResource ActionButton}"
                                                                    Margin="2"
                                                                    Click="SyncCustomer_Click"/>
                                                            <Button Content="📝" ToolTip="Vertrag erstellen"
                                                                    Style="{StaticResource ActionButton}"
                                                                    Margin="2"
                                                                    Click="CreateContractForCustomer_Click"/>
                                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Projekte Tab -->
            <TabItem x:Name="TabProjekte" Header="📁 Projekte" Style="{StaticResource ModernTabItem}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <Button Content="+ Neues Projekt" Style="{StaticResource ModernButton}"
                                Padding="12,6"
                                Click="AddProject_Click"
                                        Background="{DynamicResource SuccessBrush}" Foreground="White"/>
                        <TextBlock Text="Status:" VerticalAlignment="Center" Margin="16,0,4,0" FontSize="12"/>
                        <ComboBox x:Name="ProjectStatusFilter" Width="140" Height="30"
                                  SelectionChanged="ProjectStatusFilter_Changed">
                            <ComboBoxItem Content="Alle" IsSelected="True"/>
                            <ComboBoxItem Content="Aktiv"/>
                            <ComboBoxItem Content="Abgeschlossen"/>
                            <ComboBoxItem Content="Pausiert"/>
                            <ComboBoxItem Content="Geplant"/>
                        </ComboBox>
                    </StackPanel>
                    <DataGrid x:Name="ProjectsDataGrid"
                              Grid.Row="1"
                              ItemsSource="{Binding Projects}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              MouseDoubleClick="ProjectsDataGrid_MouseDoubleClick">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Bearbeiten" Click="EditProject_Click"/>
                                <MenuItem Header="📄 Dokumente" Click="DocumentsProject_Click"/>
                                <MenuItem Header="Angebot erstellen" Click="CreateOfferFromProject_Click"/>
                                <MenuItem Header="Rechnung erstellen" Click="CreateInvoiceFromProject_Click"/>
                                <MenuItem Header="Proforma-Rechnung erstellen" Click="CreateProformaFromProject_Click"/>
                                <Separator/>
                                <MenuItem Header="Löschen" Click="DeleteProject_Click" Foreground="Red"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Projektname" Binding="{Binding Name}" Width="2*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Kunde" Binding="{Binding ClientName}" Width="1.5*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="1*" IsReadOnly="True"/>
                            <DataGridTemplateColumn Header="Fortschritt" Width="0.8*" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid ToolTip="{Binding ProgressPercent, StringFormat={}{0}%}">
                                            <ProgressBar Value="{Binding ProgressPercent, Mode=OneWay}" Minimum="0" Maximum="100"
                                                         Height="14" Foreground="{DynamicResource SuccessBrush}"/>
                                            <TextBlock Text="{Binding ProgressPercent, StringFormat={}{0}%}"
                                                       FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Tags" Binding="{Binding Tags}" Width="1*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Start" Binding="{Binding StartDate, StringFormat=dd.MM.yyyy}" Width="0.8*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Budget" Binding="{Binding Budget, Converter={StaticResource EuroCurrencyConverter}}" Width="0.8*" IsReadOnly="True"/>
                            <DataGridTemplateColumn Header="Aktionen" Width="250">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Content="✏️" ToolTip="Projekt bearbeiten"
                                                    Style="{StaticResource ActionButton}"
                                                    Foreground="{DynamicResource PrimaryBrush}"
                                                    Margin="2"
                                                    Click="EditProject_Click"/>
                                            <Button Content="📄" ToolTip="Dokumente"
                                                    Style="{StaticResource ActionButton}"
                                                    Margin="2"
                                                    Click="DocumentsProject_Click"/>
                                            <Button Content="Angebot" ToolTip="Angebot erstellen"
                                                    Style="{StaticResource ActionButton}"
                                                    Margin="2"
                                                    Click="CreateOfferFromProject_Click"/>
                                            <Button Content="Rechnung" ToolTip="Rechnung erstellen"
                                                    Style="{StaticResource ActionButton}"
                                                    Margin="2"
                                                    Click="CreateInvoiceFromProject_Click"/>
                                            <Button Content="Proforma" ToolTip="Proforma-Rechnung erstellen"
                                                    Style="{StaticResource ActionButton}"
                                                    Margin="2"
                                                    Click="CreateProformaFromProject_Click"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            
            <!-- Zeiterfassung Tab -->
            <TabItem x:Name="TabZeiterfassung" Header="⏱ Zeiterfassung" Style="{StaticResource ModernTabItem}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <Button Content="+ Neue Zeiterfassung" Style="{StaticResource ModernButton}"
                                HorizontalAlignment="Left"
                                Padding="12,6" Margin="0,0,10,0"
                                Click="AddTimeEntry_Click"
                                        Background="{DynamicResource SuccessBrush}" Foreground="White"/>
                        <TextBlock Text="Von:" VerticalAlignment="Center" Margin="10,0,4,0" FontSize="12"/>
                        <DatePicker x:Name="TimeFilterFrom" Width="130" Height="30"
                                    SelectedDateChanged="TimeFilter_Changed"/>
                        <TextBlock Text="Bis:" VerticalAlignment="Center" Margin="10,0,4,0" FontSize="12"/>
                        <DatePicker x:Name="TimeFilterTo" Width="130" Height="30"
                                    SelectedDateChanged="TimeFilter_Changed"/>
                        <Button Content="✕ Filter zurücksetzen" Style="{StaticResource ActionButton}"
                                Padding="8,4" Margin="10,0,0,0" Click="TimeFilterReset_Click"/>
                    </StackPanel>
                    <DataGrid x:Name="TimeEntriesDataGrid"
                              Grid.Row="1"
                              ItemsSource="{Binding TimeEntries}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              SelectionMode="Single">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Löschen" Click="DeleteTimeEntry_Click" Foreground="Red"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Projekt" Binding="{Binding ProjectName}" Width="2*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Mitarbeiter" Binding="{Binding EmployeeName}" Width="1.5*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Datum" Binding="{Binding Date, StringFormat=dd.MM.yyyy}" Width="1*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Stunden" Binding="{Binding Duration, Converter={StaticResource TimeSpanToHoursConverter}}" Width="0.8*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Tätigkeit" Binding="{Binding Activity}" Width="2*" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            
            <!-- Kalender Tab -->
            <TabItem x:Name="TabKalender" Header="📅 Kalender" Style="{StaticResource ModernTabItem}">
                <views:MeetingCalendarView x:Name="MeetingCalendarView" Margin="10"/>
            </TabItem>

            <!-- Besprechungsprotokolle Tab -->
            <TabItem x:Name="TabProtokolle" Header="📋 Besprechungsprotokolle" Style="{StaticResource ModernTabItem}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Button Content="+ Neues Protokoll" Style="{StaticResource ModernButton}"
                            Grid.Row="0"
                            HorizontalAlignment="Left"
                            Padding="12,6" Margin="0,0,0,15"
                            Click="AddMeetingProtocol_Click"
                            Background="{DynamicResource SuccessBrush}" Foreground="White"/>
                    <DataGrid x:Name="MeetingProtocolsDataGrid"
                              Grid.Row="1"
                              ItemsSource="{Binding MeetingProtocols}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              MouseDoubleClick="MeetingProtocolsDataGrid_MouseDoubleClick">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Bearbeiten" Click="EditMeetingProtocol_Click"/>
                                <Separator/>
                                <MenuItem Header="Löschen" Click="DeleteMeetingProtocol_Click" Foreground="Red"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Titel" Binding="{Binding Title}" Width="2*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Projekt" Binding="{Binding ProjectName}" Width="1.5*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Datum" Binding="{Binding MeetingDate, StringFormat=dd.MM.yyyy HH:mm}" Width="1.2*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Ort" Binding="{Binding Location}" Width="1.2*" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            
            <!-- Aufgaben Tab -->
            <TabItem x:Name="TabAufgaben" Header="✓ Aufgaben" Style="{StaticResource ModernTabItem}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <Button Content="+ Neue Aufgabe" Style="{StaticResource ModernButton}"
                                Padding="12,6" Margin="0,0,10,0"
                                Click="AddTask_Click"
                                        Background="{DynamicResource SuccessBrush}" Foreground="White"/>
                        <TextBox x:Name="TaskSearchBox"
                                 Width="250" Height="32"
                                 Margin="10,0,0,0"
                                 VerticalContentAlignment="Center"
                                 TextChanged="TaskSearch_TextChanged"
                                 GotFocus="TaskSearchBox_GotFocus"
                                 LostFocus="TaskSearchBox_LostFocus"
                                 Foreground="Gray"
                                 Text="Suchen..."/>
                        <TextBlock Text="Status:" VerticalAlignment="Center" Margin="16,0,4,0" FontSize="12"/>
                        <ComboBox x:Name="TaskStatusFilter" Width="130" Height="30"
                                  SelectionChanged="TaskStatusFilter_Changed">
                            <ComboBoxItem Content="Alle" IsSelected="True"/>
                            <ComboBoxItem Content="Offen"/>
                            <ComboBoxItem Content="In Bearbeitung"/>
                            <ComboBoxItem Content="Erledigt"/>
                            <ComboBoxItem Content="Blockiert"/>
                        </ComboBox>
                    </StackPanel>
                    <DataGrid x:Name="TasksDataGrid"
                              Grid.Row="1"
                              ItemsSource="{Binding Tasks}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              MouseDoubleClick="TasksDataGrid_MouseDoubleClick">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Bearbeiten" Click="EditTask_Click"/>
                                <Separator/>
                                <MenuItem Header="Löschen" Click="DeleteTask_Click" Foreground="Red"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Titel" Binding="{Binding Title}" Width="2*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Projekt" Binding="{Binding ProjectName}" Width="1.5*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Zugewiesen" Binding="{Binding AssignedTo}" Width="1.2*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="1*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Priorität" Binding="{Binding Priority}" Width="1*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Fällig" Binding="{Binding DueDate, StringFormat=dd.MM.yyyy}" Width="0.9*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="🔁" Binding="{Binding RecurrenceDisplay}" Width="0.9*" IsReadOnly="True"/>
                            <DataGridTemplateColumn Header="Aktion" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="✏️" ToolTip="Aufgabe bearbeiten"
                                                Style="{StaticResource ActionButton}"
                                                Foreground="{DynamicResource PrimaryBrush}"
                                                Margin="2"
                                                Click="EditTask_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Tickets Tab -->
            <TabItem x:Name="TabTickets" Header="🎫 Tickets" Style="{StaticResource ModernTabItem}">
                <views:TicketsView x:Name="TicketsView" Margin="10"/>
            </TabItem>

            <!-- Kanban Tab -->
            <TabItem x:Name="TabKanban" Header="📌 Kanban" Style="{StaticResource ModernTabItem}">
                <views:KanbanBoardView x:Name="KanbanBoardView" Margin="0"/>
            </TabItem>

<!-- CRM Tab -->
<TabItem x:Name="TabCrm" Header="🤝 CRM" Style="{StaticResource ModernTabItem}">
    <views:CrmView x:Name="CrmView" Margin="0"/>
</TabItem>

            <!-- Einkauf Tab -->
            <TabItem x:Name="TabEinkauf" Header="🛒 Einkauf" Style="{StaticResource ModernTabItem}">
                <views:PurchaseView x:Name="PurchaseView" Margin="0"/>
            </TabItem>

            <!-- Mitarbeiter Tab -->
            <TabItem x:Name="TabMitarbeiter" Header="👥 Mitarbeiter" Style="{StaticResource ModernTabItem}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <Button Content="+ Neuer Mitarbeiter" Style="{StaticResource ModernButton}"
                                Padding="12,6"
                                Click="AddEmployee_Click"
                                        Background="{DynamicResource SuccessBrush}" Foreground="White"/>
                    </StackPanel>
                    <DataGrid x:Name="EmployeesDataGrid"
                              Grid.Row="1"
                              ItemsSource="{Binding Employees}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              MouseDoubleClick="EmployeesDataGrid_MouseDoubleClick">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Bearbeiten" Click="EditEmployee_Click"/>
                                <Separator/>
                                <MenuItem Header="Löschen" Click="DeleteEmployee_Click" Foreground="Red"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding FullName}" Width="1.8*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Position" Binding="{Binding Position}" Width="1.5*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Abteilung" Binding="{Binding Department}" Width="1.2*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="E-Mail" Binding="{Binding Email}" Width="2*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Stundensatz" Binding="{Binding HourlyRate, Converter={StaticResource EuroCurrencyConverter}}" Width="1*" IsReadOnly="True"/>
                            <DataGridCheckBoxColumn Header="Aktiv" Binding="{Binding IsActive}" Width="0.6*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Urlaub" Binding="{Binding VacationDaysRemaining}" Width="0.6*" IsReadOnly="True"/>
                            <DataGridTemplateColumn Header="Aktion" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="✏️" ToolTip="Mitarbeiter bearbeiten"
                                                Style="{StaticResource ActionButton}"
                                                Foreground="{DynamicResource PrimaryBrush}"
                                                Margin="2"
                                                Click="EditEmployee_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
        </Grid>
    </DockPanel>
</Window>
