<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Projektsoftware.Mobile.Pages.TasksPage"
             Title="Aufgaben"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto,*" Padding="16" RowSpacing="12">
        <ActivityIndicator x:Name="LoadingIndicator" Grid.Row="0" IsRunning="True" IsVisible="True" Color="#1565C0"/>

        <CollectionView x:Name="TasksList" Grid.Row="1">
            <CollectionView.EmptyView>
                <Label Text="Keine Aufgaben vorhanden." HorizontalOptions="Center" VerticalOptions="Center" TextColor="#999"/>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems Mode="Execute">
                                <SwipeItem Text="Status ändern" BackgroundColor="#1565C0"
                                           Invoked="OnChangeStatus"/>
                            </SwipeItems>
                        </SwipeView.RightItems>

                        <Frame Margin="0,0,0,8" Padding="14" BackgroundColor="White" CornerRadius="10" HasShadow="True">
                            <VerticalStackLayout Spacing="6">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Text="{Binding Title}" FontSize="16" FontAttributes="Bold" TextColor="#212121"/>
                                    <Frame Grid.Column="1" CornerRadius="8" Padding="8,3" HasShadow="False"
                                           BackgroundColor="{Binding PriorityBackgroundColor}">
                                        <Label Text="{Binding Priority}" FontSize="11" TextColor="White"/>
                                    </Frame>
                                </Grid>

                                <Label Text="{Binding ProjectName}" FontSize="13" TextColor="#757575"/>

                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <Frame Grid.Column="0" CornerRadius="6" Padding="6,2" HasShadow="False"
                                           BackgroundColor="{Binding StatusBackgroundColor}">
                                        <Label Text="{Binding Status}" FontSize="11" TextColor="White"/>
                                    </Frame>
                                    <Label Grid.Column="1"/>
                                    <Label Grid.Column="2" Text="{Binding DueDateDisplay}" FontSize="12" TextColor="#999"
                                           VerticalOptions="Center"/>
                                </Grid>

                                <Label Text="{Binding AssignedTo}" FontSize="12" TextColor="#757575"
                                       IsVisible="{Binding HasAssignee}"/>
                            </VerticalStackLayout>
                        </Frame>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
