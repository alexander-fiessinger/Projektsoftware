@inject SessionService Session
@inject IJSRuntime JS

<div class="app-container">
    <div class="app-header">
        <div class="app-header-left">
            <span class="app-header-logo">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <rect x="4" y="6" width="16" height="14" rx="1.5" fill="#fff" opacity="0.95"/>
                    <rect x="4" y="6" width="16" height="3" rx="1.5" fill="#C8A251"/>
                    <circle cx="6.5" cy="11.5" r="0.8" fill="#34D399"/>
                    <rect x="8.5" y="11" width="9" height="1" rx="0.5" fill="#E3F2FD" opacity="0.7"/>
                    <circle cx="6.5" cy="14" r="0.8" fill="#34D399"/>
                    <rect x="8.5" y="13.5" width="7" height="1" rx="0.5" fill="#E3F2FD" opacity="0.7"/>
                    <circle cx="6.5" cy="16.5" r="0.8" fill="#E3F2FD" opacity="0.5"/>
                    <rect x="8.5" y="16" width="8" height="1" rx="0.5" fill="#E3F2FD" opacity="0.5"/>
                </svg>
            </span>
            <div>
                <h1>Projektsoftware</h1>
                <div class="app-header-subtitle">@_tabLabels.GetValueOrDefault(_activeTab, "Dashboard")</div>
            </div>
        </div>
        <div class="app-header-actions">
            <button class="theme-toggle" title="Design wechseln" @onclick="ToggleTheme">@(_isDark ? "☀️" : "🌙")</button>
            <button @onclick="Logout">Abmelden</button>
        </div>
    </div>

    <div class="app-content">
        @switch (_activeTab)
        {
            case "dashboard":
                <DashboardTab/>
                break;
            case "projects":
                <ProjectsTab/>
                break;
            case "tasks":
                <TasksTab/>
                break;
            case "kanban":
                <KanbanTab/>
                break;
            case "employees":
                <EmployeesTab/>
                break;
            case "time":
                <TimeEntriesTab/>
                break;
            case "customers":
                <CustomersTab/>
                break;
            case "tickets":
                <TicketsTab/>
                break;
            case "crm":
                <CrmTab/>
                break;
            case "meetings":
                <MeetingsTab/>
                break;
            case "purchase":
                <PurchaseTab/>
                break;
            case "protocols":
                <ProtocolsTab/>
                break;
            case "suppliers":
                <SuppliersTab/>
                break;
            case "sales":
                <SalesTab/>
                break;
            case "search":
                <SearchTab/>
                break;
            case "notifications":
                <NotificationsTab/>
                break;
            case "audit":
                <AuditLogTab/>
                break;
            case "analytics":
                <AnalyticsTab/>
                break;
            case "users":
                <UserManagementTab/>
                break;
            case "settings":
                <SettingsTab/>
                break;
            case "timeline":
                <TimelineTab/>
                break;
            case "export":
                <ExportTab/>
                break;
            case "letter":
                <LetterTab/>
                break;
            case "contract":
                <ContractTab/>
                break;
            case "budget":
                <BudgetTab/>
                break;
            case "sla":
                <SlaTab/>
                break;
            case "followup":
                <FollowUpTab/>
                break;
            case "vat":
                <VatTab/>
                break;
            case "templates":
                <TemplateTab/>
                break;
            case "kpi":
                <KpiTab/>
                break;
            case "salescal":
                <SalesCalendarTab/>
                break;
            case "supplierrating":
                <SupplierRatingTab/>
                break;
            case "expenses":
                <ExpenseAnalysisTab/>
                break;
            case "easybillexport":
                <EasybillExportTab/>
                break;
            case "documents":
                <DocumentsTab/>
                break;
        }
    </div>

    @* ── Bottom Tab Bar (5 primary) ── *@
    <div class="tab-bar">
        <button class="@TabClass("dashboard")" @onclick='() => SwitchTab("dashboard")'>
            <span class="tab-icon">📊</span> Dashboard
        </button>
        @if (Session.HasAccess("projekte"))
        {
            <button class="@TabClass("projects")" @onclick='() => SwitchTab("projects")'>
                <span class="tab-icon">📁</span> Projekte
            </button>
        }
        @if (Session.HasAccess("aufgaben"))
        {
            <button class="@TabClass("tasks")" @onclick='() => SwitchTab("tasks")'>
                <span class="tab-icon">📋</span> Aufgaben
            </button>
        }
        <button class="@TabClass("documents")" @onclick='() => SwitchTab("documents")'>
            <span class="tab-icon">📄</span> Dokumente
        </button>
        <button class="@(_showMore ? "active" : "") @(_moreTabActive ? "active" : "")" @onclick="ToggleMore">
            <span class="tab-icon">☰</span> Mehr
        </button>
    </div>

    @* ── More-Menu Overlay ── *@
    @if (_showMore)
    {
        <div class="more-overlay" @onclick="() => _showMore = false">
            <div class="more-menu" @onclick:stopPropagation="true">
                <div class="more-handle"></div>
                <div class="more-title">Alle Module</div>
                <div class="more-grid">
                    @foreach (var item in _moreItems)
                    {
                        if (item.Permission == null || Session.HasAccess(item.Permission))
                        {
                            <button class="more-item @(item.Key == _activeTab ? "active" : "")"
                                    @onclick="() => SelectMore(item.Key)">
                                <span class="more-icon">@item.Icon</span>
                                <span class="more-label">@item.Label</span>
                            </button>
                        }
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    private string _activeTab = "dashboard";
    private bool _showMore;
    private bool _isDark;

    [Parameter] public EventCallback OnLogout { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var theme = await JS.InvokeAsync<string>("appTheme.get");
                var dark = theme == "dark";
                if (dark != _isDark)
                {
                    _isDark = dark;
                    StateHasChanged();
                }
            }
            catch { }
        }
    }

    private async Task ToggleTheme()
    {
        try
        {
            var theme = await JS.InvokeAsync<string>("appTheme.toggle");
            _isDark = theme == "dark";
        }
        catch { }
    }

    private record MoreItem(string Key, string Icon, string Label, string? Permission);

    private static readonly Dictionary<string, string> _tabLabels = new()
    {
        { "dashboard", "Übersicht" },
        { "projects", "Projekte" },
        { "tasks", "Aufgaben" },
        { "kanban", "Kanban-Board" },
        { "employees", "Team" },
        { "time", "Zeiterfassung" },
        { "customers", "Kunden" },
        { "tickets", "Tickets" },
        { "crm", "CRM" },
        { "meetings", "Meetings" },
        { "purchase", "Einkauf" },
        { "protocols", "Protokolle" },
        { "suppliers", "Lieferanten" },
        { "sales", "Vertrieb" },
        { "search", "Globale Suche" },
        { "notifications", "Benachrichtigungen" },
        { "audit", "Audit-Log" },
        { "analytics", "Auswertungen" },
        { "users", "Benutzerverwaltung" },
        { "settings", "Einstellungen" },
        { "timeline", "Projekt-Zeitstrahl" },
        { "export", "Datenexport" },
        { "letter", "Briefgenerator" },
        { "contract", "Vertragsgenerator" },
        { "budget", "Budget-Tracking" },
        { "sla", "SLA-Monitoring" },
        { "followup", "Wiedervorlagen" },
        { "vat", "MwSt-Rechner" },
        { "templates", "Projektvorlagen" },
        { "kpi", "KPI-Dashboard" },
        { "salescal", "Sales-Kalender" },
        { "supplierrating", "Lieferanten-Bewertung" },
        { "expenses", "Ausgaben-Analyse" },
        { "easybillexport", "Easybill Export" },
        { "documents", "Dokumente" }
    };

    private static readonly string[] _primaryTabs = ["dashboard", "projects", "tasks", "documents"];

    private static readonly MoreItem[] _moreItems =
    [
        new("kanban", "📌", "Kanban", "aufgaben"),
        new("employees", "👥", "Team", "mitarbeiter"),
        new("time", "⏱️", "Zeiten", "zeiterfassung"),
        new("customers", "🏢", "Kunden", "kunden"),
        new("tickets", "🎫", "Tickets", "tickets"),
        new("crm", "💼", "CRM", "crm"),
        new("meetings", "📅", "Meetings", "kalender"),
        new("purchase", "🛒", "Einkauf", "einkauf"),
        new("protocols", "📝", "Protokolle", "protokolle"),
        new("suppliers", "🚚", "Lieferanten", "einkauf"),
        new("sales", "💼", "Vertrieb", "sales"),
        new("search", "🔍", "Suche", null),
        new("notifications", "🔔", "Hinweise", null),
        new("audit", "🛡️", "Audit-Log", "admin"),
        new("analytics", "📈", "Auswertungen", null),
        new("users", "👥", "Benutzer", "admin"),
        new("settings", "⚙️", "Einstellungen", null),
        new("timeline", "📅", "Zeitstrahl", "projekte"),
        new("export", "📤", "Export", "export"),
        new("letter", "✉️", "Brief", null),
        new("contract", "📜", "Vertrag", null),
        new("budget", "💰", "Budget", null),
        new("sla", "🛡️", "SLA", null),
        new("followup", "🔔", "Wiedervorlage", null),
        new("vat", "🧾", "MwSt", null),
        new("templates", "📋", "Vorlagen", "projekte"),
        new("kpi", "📊", "KPIs", null),
        new("supplierrating", "⭐", "Lieferanten-Bew.", "einkauf"),
        new("expenses", "💸", "Ausgaben", "einkauf"),
        new("easybillexport", "🧾", "Easybill Export", null),
    ];

    private bool _moreTabActive => !_primaryTabs.Contains(_activeTab);

    private string TabClass(string tab) => tab == _activeTab ? "active" : "";

    private void SwitchTab(string tab)
    {
        _activeTab = tab;
        _showMore = false;
    }

    private void ToggleMore()
    {
        _showMore = !_showMore;
    }

    private void SelectMore(string key)
    {
        _activeTab = key;
        _showMore = false;
    }

    private void Logout()
    {
        _ = OnLogout.InvokeAsync();
    }
}
