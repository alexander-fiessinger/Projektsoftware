@* Sales-Reiter mit zwei Untertabs (wie in der WPF-App): Termine & Leads *@

<div class="section-title" style="display:flex;flex-direction:column;gap:2px;">
    <span>📅 Sales</span>
    <span class="sub" style="font-weight:400;">Neukunden-Terminplanung via sales@af-software-engineering.de</span>
</div>

<div class="sub-tabs" style="margin-bottom:12px;">
    <button class="sub-tab @(_active == "appointments" ? "active" : "")" @onclick='() => _active = "appointments"'>📅 Termine</button>
    <button class="sub-tab @(_active == "leads" ? "active" : "")" @onclick='() => _active = "leads"'>📋 Leads</button>
</div>

@if (_active == "appointments")
{
    <SalesCalendarTab />
}
else
{
    <SalesLeadsTab />
}

@code {
    private string _active = "appointments";
}
